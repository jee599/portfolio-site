---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'AI로 프로덕트를 만들고 수익화하는 기록', ogImage } = Astro.props;
const siteUrl = 'https://jidonglab.com';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | JiDong Lab</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage || `${siteUrl}/og/default.png`} />
    <meta property="og:url" content={canonicalUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="jidonglab" href="/rss.xml" />

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: 'jidonglab',
        url: siteUrl,
        author: { '@type': 'Person', name: 'jidonglab' },
      })}
    />
    <style is:inline>
      .prose .callout-stats{background:#f9fafb;border:1px solid #f2f4f6;border-radius:12px;padding:1.75rem 2rem;margin:2.5rem 0}
      .prose .callout-stats .stat-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1rem}
      @media(min-width:480px){.prose .callout-stats .stat-grid{grid-template-columns:repeat(auto-fit,minmax(120px,1fr))}}
      .prose .callout-stats .stat-item{text-align:center;padding:.5rem 0}
      .prose .callout-stats .stat-value{display:block;font-size:1.5rem;font-weight:700;color:#191f28}
      .prose .callout-stats .stat-label{display:block;font-size:.7rem;color:#8b95a1;letter-spacing:.04em;margin-top:.2rem}
      .prose .highlight{font-weight:600;color:#191f28}
      .prose .commit-log{background:#191f28;color:#e4e9f0;border-radius:12px;padding:1.5rem 1.75rem;margin:2.5rem 0;font-family:'JetBrains Mono',monospace;font-size:.8rem;line-height:2}
      .prose .commit-log .commit-row{display:flex;gap:1rem;align-items:baseline;padding:.15rem 0}
      .prose .commit-log .hash{color:#3182f6;flex-shrink:0}
      .prose .commit-log .msg{color:#8b95a1}
      .prose .change-summary{margin:2rem 0 2.5rem;border:1px solid #f2f4f6;border-radius:12px;overflow:hidden}
      .prose .change-summary table{width:100%;margin:0;border-collapse:collapse;font-size:.875rem}
      .prose .change-summary thead{background:#f9fafb;border-bottom:1px solid #e5e8eb}
      .prose .change-summary th{padding:.75rem 1.25rem;font-weight:600;color:#191f28;font-size:.8rem;text-transform:uppercase;letter-spacing:.04em}
      .prose .change-summary td{padding:.7rem 1.25rem;color:#333d4b;border-bottom:1px solid #f2f4f6}
      .prose .change-summary tr:last-child td{border-bottom:none}
      .prose .change-summary .label{font-weight:500;color:#191f28}
      .prose .change-summary .before{color:#8b95a1}
      .prose .change-summary .after{color:#3182f6;font-weight:500}
      .prose .feature-list{display:flex;flex-direction:column;gap:1rem;margin:1.5rem 0 2rem;padding:0;list-style:none}
      .prose .feature-list li{background:#f9fafb;border:1px solid #f2f4f6;border-radius:10px;padding:1.25rem 1.5rem;list-style:none;margin:0}
      .prose .feature-list .feat-title{font-weight:600;color:#191f28;display:block;margin-bottom:.35rem}
      .prose .feature-list .feat-desc{color:#6b7684;font-size:.925rem;line-height:1.7}
      .prose .section-break{height:1px;background:#f2f4f6;border:none;margin:3rem 0}
      .prose .tip{background:#e8f3ff;border-left:3px solid #3182f6;border-radius:0 8px 8px 0;padding:1rem 1.25rem;margin:1.5rem 0;color:#333d4b;font-size:.95rem;line-height:1.7}
    </style>
  </head>
  <body class="min-h-screen" style="background: #fff;">
    <header style="border-bottom: 1px solid #f2f4f6;">
      <nav style="max-width: 960px; margin: 0 auto; padding: 1rem 1.5rem; display: flex; align-items: center; justify-content: space-between;">
        <a href="/" style="font-family: 'IBM Plex Sans KR', sans-serif; font-weight: 700; font-size: 1.1rem; color: #191f28; text-decoration: none;">
          JiDong Lab
        </a>
        <div style="display: flex; align-items: center; gap: 1.75rem; font-size: 0.9rem;">
          <a href="/projects" style="color: #4e5968; text-decoration: none;">Projects</a>
          <a href="/posts" style="color: #4e5968; text-decoration: none;">Posts</a>
          <a href="/about" style="color: #4e5968; text-decoration: none;">About</a>
          <a
            href="https://github.com/jee599"
            target="_blank"
            rel="noopener"
            style="color: #4e5968; text-decoration: none;"
          >
            GitHub
          </a>
        </div>
      </nav>
    </header>

    <main style="max-width: 960px; margin: 0 auto; padding: 3rem 1.5rem;">
      <slot />
    </main>

    <footer style="border-top: 1px solid #f2f4f6; margin-top: 4rem;">
      <div style="max-width: 960px; margin: 0 auto; padding: 2rem 1.5rem; text-align: center; font-size: 0.8rem; color: #8b95a1;">
        <p>Built with Astro + Claude Code. All build logs auto-generated.</p>
        <p style="margin-top: 0.25rem;">© {new Date().getFullYear()} jidonglab</p>
      </div>
    </footer>
  </body>
</html>
