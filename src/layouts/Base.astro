---
import { getCollection } from 'astro:content';
import { getAllProjects } from '../lib/projects';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'AI를 사용하고, 연구합니다.', ogImage } = Astro.props;
const siteUrl = 'https://jidonglab.com';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const currentPath = Astro.url.pathname;

const projects = await getAllProjects();
const activeProjects = projects.filter(p => p.status === '운영중' || p.status === '개발중');
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | JiDong Lab</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage || `${siteUrl}/og/default.png`} />
    <meta property="og:url" content={canonicalUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="jidonglab" href="/rss.xml" />

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: 'jidonglab',
        url: siteUrl,
        author: { '@type': 'Person', name: 'jidonglab' },
      })}
    />
    <style is:inline>
      .prose .callout-stats{background:#1a1a2e;border:1px solid #2a2a3e;border-radius:12px;padding:1.75rem 2rem;margin:2.5rem 0}
      .prose .callout-stats .stat-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1rem}
      @media(min-width:480px){.prose .callout-stats .stat-grid{grid-template-columns:repeat(auto-fit,minmax(120px,1fr))}}
      .prose .callout-stats .stat-item{text-align:center;padding:.5rem 0}
      .prose .callout-stats .stat-value{display:block;font-size:1.5rem;font-weight:700;color:#e8e8f0}
      .prose .callout-stats .stat-label{display:block;font-size:.7rem;color:#7a7a9a;letter-spacing:.04em;margin-top:.2rem}
      .prose .highlight{font-weight:600;color:#e8e8f0}
      .prose .commit-log{background:#0f0f1a;color:#e4e9f0;border-radius:12px;padding:1.5rem 1.75rem;margin:2.5rem 0;font-family:'JetBrains Mono',monospace;font-size:.8rem;line-height:2;border:1px solid #2a2a3e}
      .prose .commit-log .commit-row{display:flex;gap:1rem;align-items:baseline;padding:.15rem 0}
      .prose .commit-log .hash{color:#6c63ff;flex-shrink:0}
      .prose .commit-log .msg{color:#7a7a9a}
      .prose .change-summary{margin:2rem 0 2.5rem;border:1px solid #2a2a3e;border-radius:12px;overflow:hidden}
      .prose .change-summary table{width:100%;margin:0;border-collapse:collapse;font-size:.875rem}
      .prose .change-summary thead{background:#1a1a2e;border-bottom:1px solid #2a2a3e}
      .prose .change-summary th{padding:.75rem 1.25rem;font-weight:600;color:#e8e8f0;font-size:.8rem;text-transform:uppercase;letter-spacing:.04em}
      .prose .change-summary td{padding:.7rem 1.25rem;color:#c8c8e0;border-bottom:1px solid #1a1a2e}
      .prose .change-summary tr:last-child td{border-bottom:none}
      .prose .change-summary .label{font-weight:500;color:#e8e8f0}
      .prose .change-summary .before{color:#7a7a9a}
      .prose .change-summary .after{color:#8b83ff;font-weight:500}
      .prose .feature-list{display:flex;flex-direction:column;gap:1rem;margin:1.5rem 0 2rem;padding:0;list-style:none}
      .prose .feature-list li{background:#1a1a2e;border:1px solid #2a2a3e;border-radius:10px;padding:1.25rem 1.5rem;list-style:none;margin:0}
      .prose .feature-list .feat-title{font-weight:600;color:#e8e8f0;display:block;margin-bottom:.35rem}
      .prose .feature-list .feat-desc{color:#7a7a9a;font-size:.925rem;line-height:1.7}
      .prose .section-break{height:1px;background:#2a2a3e;border:none;margin:3rem 0}
      .prose .tip{background:rgba(108,99,255,0.08);border-left:3px solid #6c63ff;border-radius:0 8px 8px 0;padding:1rem 1.25rem;margin:1.5rem 0;color:#c8c8e0;font-size:.95rem;line-height:1.7}
    </style>
  </head>
  <body class="min-h-screen" style="background: #0a0a0f;">
    <header style="border-bottom: 1px solid #1a1a2e;">
      <nav style="max-width: 1200px; margin: 0 auto; padding: 1rem 1.5rem; display: flex; align-items: center; justify-content: space-between;">
        <a href="/" style="font-family: 'IBM Plex Sans KR', sans-serif; font-weight: 700; font-size: 1.1rem; color: #e8e8f0; text-decoration: none; display: flex; align-items: center; gap: 0.5rem;">
          <span style="color: #6c63ff;">*</span> JiDong Lab
        </a>
        <div style="display: flex; align-items: center; gap: 1.75rem; font-size: 0.9rem;">
          <a href="/projects" style="color: #7a7a9a; text-decoration: none;">Projects</a>
          <a href="/posts" style="color: #7a7a9a; text-decoration: none;">Posts</a>
          <a href="/ai-news" style="color: #7a7a9a; text-decoration: none;">AI News</a>
          <a href="/about" style="color: #7a7a9a; text-decoration: none;">About</a>
          <a
            href="https://github.com/jee599"
            target="_blank"
            rel="noopener"
            style="color: #7a7a9a; text-decoration: none;"
          >
            GitHub
          </a>
        </div>
      </nav>
    </header>

    <div class="site-layout">
      <aside class="site-sidebar">
        <div class="sidebar-section">
          <div class="sidebar-title">Navigate</div>
          <a href="/" class:list={["sidebar-link", { active: currentPath === '/' }]}>Home</a>
          <a href="/projects" class:list={["sidebar-link", { active: currentPath.startsWith('/projects') }]}>Projects</a>
          <a href="/posts" class:list={["sidebar-link", { active: currentPath === '/posts' || currentPath === '/posts/' }]}>Posts</a>
          <a href="/ai-news" class:list={["sidebar-link", { active: currentPath.startsWith('/ai-news') }]}>AI News</a>
          <a href="/about" class:list={["sidebar-link", { active: currentPath === '/about' }]}>About</a>
        </div>

        {activeProjects.length > 0 && (
          <div class="sidebar-section">
            <div class="sidebar-title">Active Projects</div>
            {activeProjects.map(p => (
              <a href={`/projects/${p.slug}`} class="sidebar-link">
                <span class="sidebar-dot" style={`background: ${p.status === '운영중' ? '#10b981' : '#f59e0b'}`}></span>
                {p.title}
              </a>
            ))}
          </div>
        )}

        <div class="sidebar-section">
          <div class="sidebar-title">AI Tips</div>
          <a href="/posts" class="sidebar-link">Prompt Engineering</a>
          <a href="/posts" class="sidebar-link">AI Automation</a>
        </div>

        <div class="sidebar-section">
          <div class="sidebar-title">LLM News</div>
          <a href="/ai-news?model=claude" class="sidebar-link">
            <span class="sidebar-dot" style="background: #d97757;"></span>
            Claude
          </a>
          <a href="/ai-news?model=gemini" class="sidebar-link">
            <span class="sidebar-dot" style="background: #4285f4;"></span>
            Gemini
          </a>
          <a href="/ai-news?model=gpt" class="sidebar-link">
            <span class="sidebar-dot" style="background: #10a37f;"></span>
            GPT
          </a>
          <a href="/ai-news?model=etc" class="sidebar-link">
            <span class="sidebar-dot" style="background: #7a7a9a;"></span>
            Others
          </a>
        </div>
      </aside>

      <main class="site-main">
        <slot />
      </main>
    </div>

    <footer style="border-top: 1px solid #1a1a2e; margin-top: 4rem;">
      <div style="max-width: 1200px; margin: 0 auto; padding: 2rem 1.5rem; text-align: center; font-size: 0.8rem; color: #7a7a9a;">
        <p>AI를 사용하고, 연구합니다. Built with Astro + Claude Code.</p>
        <p style="margin-top: 0.25rem;">&copy; {new Date().getFullYear()} jidonglab</p>
      </div>
    </footer>
  </body>
</html>
