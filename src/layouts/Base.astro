---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'AI로 프로덕트를 만들고 수익화하는 기록', ogImage } = Astro.props;
const siteUrl = 'https://jidonglab.com';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | Make Me Rich, AI</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage || `${siteUrl}/og/default.png`} />
    <meta property="og:url" content={canonicalUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="jidonglab" href="/rss.xml" />

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: 'jidonglab',
        url: siteUrl,
        author: { '@type': 'Person', name: 'jidonglab' },
      })}
    />
  </head>
  <body class="min-h-screen bg-bg">
    <header class="border-b border-border">
      <nav class="max-w-4xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="font-display font-bold text-lg text-heading no-underline hover:text-accent-dark transition-colors">
          Make Me Rich, AI
        </a>
        <div class="flex items-center gap-6 text-sm text-muted">
          <a href="/projects" class="hover:text-heading no-underline transition-colors">Projects</a>
          <a href="/posts" class="hover:text-heading no-underline transition-colors">Posts</a>
          <a href="/about" class="hover:text-heading no-underline transition-colors">About</a>
          <a
            href="https://github.com/jee599"
            target="_blank"
            rel="noopener"
            class="hover:text-heading no-underline transition-colors"
          >
            GitHub
          </a>
        </div>
      </nav>
    </header>

    <main class="max-w-4xl mx-auto px-6 py-12">
      <slot />
    </main>

    <footer class="border-t border-border mt-20">
      <div class="max-w-4xl mx-auto px-6 py-8 text-center text-sm text-muted">
        <p>Built with Astro + Claude Code. All build logs auto-generated.</p>
        <p class="mt-1">© {new Date().getFullYear()} jidonglab</p>
      </div>
    </footer>
  </body>
</html>
