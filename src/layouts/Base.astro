---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'AI를 사용하고, 연구합니다.', ogImage } = Astro.props;
const siteUrl = 'https://jidonglab.com';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/projects', label: 'Projects', labelEn: 'Projects' },
  { href: '/posts', label: 'AI Posts', labelEn: 'AI Posts' },
  { href: '/ai-news', label: 'AI News', labelEn: 'AI News' },
  { href: '/about', label: 'About', labelEn: 'About' },
];
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | Jidong Lab</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage || `${siteUrl}/og/default.svg`} />
    <meta property="og:url" content={canonicalUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="jidonglab" href="/rss.xml" />

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: 'jidonglab',
        url: siteUrl,
        author: { '@type': 'Person', name: 'jidonglab' },
      })}
    />
    <style is:inline>
      .prose{font-size:1.05rem;color:#333d4b;line-height:1.9;word-break:keep-all;overflow-wrap:break-word}
      .prose h2{font-size:1.5rem;font-weight:700;color:#191f28;margin:3.5rem 0 1.25rem;padding-bottom:.6rem;border-bottom:1px solid #f2f4f6;letter-spacing:-.02em;line-height:1.4}
      .prose h3{font-size:1.2rem;font-weight:700;color:#191f28;margin:2.5rem 0 .75rem;letter-spacing:-.01em;line-height:1.5}
      .prose h4{font-size:1.05rem;font-weight:600;color:#333d4b;margin:2rem 0 .5rem;line-height:1.5}
      .prose p{margin:1.25rem 0;line-height:1.9}
      .prose p+p{margin-top:1.5rem}
      .prose strong{font-weight:600;color:#191f28}
      .prose a{color:#00c471;text-decoration:underline;text-decoration-color:rgba(0,196,113,.3);text-underline-offset:2px;transition:all .15s}
      .prose a:hover{text-decoration-color:#00c471}
      .prose ul,.prose ol{margin:1.25rem 0;padding-left:1.5rem}
      .prose li{margin:.5rem 0;line-height:1.8;color:#333d4b}
      .prose li::marker{color:#00c471}
      .prose code{font-family:'JetBrains Mono',monospace;font-size:.875em;color:#e45649;background:#f2f4f6;padding:.15rem .4rem;border-radius:4px}
      .prose pre{margin:2rem 0;padding:1.5rem 1.75rem;background:#191f28;border-radius:12px;overflow-x:auto;line-height:1.7}
      .prose pre code{color:#e4e9f0;background:none;padding:0;font-size:.85rem;border-radius:0}
      .prose blockquote{margin:2rem 0;padding:1rem 1.5rem;border-left:3px solid #00c471;background:#f9fafb;border-radius:0 8px 8px 0;color:#6b7684;line-height:1.8}
      .prose blockquote p{margin:.5rem 0}
      .prose hr{border:none;height:1px;background:#f2f4f6;margin:3rem 0}
      .prose img{max-width:100%;height:auto;border-radius:12px;margin:2rem 0;border:1px solid #f2f4f6}
      .prose table{width:100%;margin:2rem 0;border-collapse:collapse;font-size:.925rem}
      .prose thead{background:#f9fafb;border-bottom:2px solid #e5e8eb}
      .prose th{padding:.75rem 1rem;font-weight:600;color:#191f28;text-align:left;font-size:.8rem;text-transform:uppercase;letter-spacing:.04em}
      .prose td{padding:.7rem 1rem;color:#333d4b;border-bottom:1px solid #f2f4f6}
      .prose tr:last-child td{border-bottom:none}
      .prose .callout-stats{background:#f9fafb;border:1px solid #f2f4f6;border-radius:12px;padding:1.75rem 2rem;margin:2.5rem 0}
      .prose .callout-stats .stat-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1rem}
      @media(min-width:480px){.prose .callout-stats .stat-grid{grid-template-columns:repeat(auto-fit,minmax(120px,1fr))}}
      .prose .callout-stats .stat-item{text-align:center;padding:.5rem 0}
      .prose .callout-stats .stat-value{display:block;font-size:1.5rem;font-weight:700;color:#191f28}
      .prose .callout-stats .stat-label{display:block;font-size:.7rem;color:#8b95a1;letter-spacing:.04em;margin-top:.2rem}
      .prose .highlight{font-weight:600;color:#191f28}
      .prose .commit-log{background:#191f28;color:#e4e9f0;border-radius:12px;padding:1.5rem 1.75rem;margin:2.5rem 0;font-family:'JetBrains Mono',monospace;font-size:.8rem;line-height:2}
      .prose .commit-log .commit-row{display:flex;gap:1rem;align-items:baseline;padding:.15rem 0}
      .prose .commit-log .hash{color:#00c471;flex-shrink:0}
      .prose .commit-log .msg{color:#8b95a1}
      .prose .change-summary{margin:2rem 0 2.5rem;border:1px solid #f2f4f6;border-radius:12px;overflow:hidden}
      .prose .change-summary table{width:100%;margin:0;border-collapse:collapse;font-size:.875rem}
      .prose .change-summary thead{background:#f9fafb;border-bottom:1px solid #e5e8eb}
      .prose .change-summary th{padding:.75rem 1.25rem;font-weight:600;color:#191f28;font-size:.8rem;text-transform:uppercase;letter-spacing:.04em}
      .prose .change-summary td{padding:.7rem 1.25rem;color:#333d4b;border-bottom:1px solid #f2f4f6}
      .prose .change-summary tr:last-child td{border-bottom:none}
      .prose .change-summary .label{font-weight:500;color:#191f28}
      .prose .change-summary .before{color:#8b95a1}
      .prose .change-summary .after{color:#00c471;font-weight:500}
      .prose .feature-list{display:flex;flex-direction:column;gap:1rem;margin:1.5rem 0 2rem;padding:0;list-style:none}
      .prose .feature-list li{background:#f9fafb;border:1px solid #f2f4f6;border-radius:10px;padding:1.25rem 1.5rem;list-style:none;margin:0}
      .prose .feature-list .feat-title{font-weight:600;color:#191f28;display:block;margin-bottom:.35rem}
      .prose .feature-list .feat-desc{color:#6b7684;font-size:.925rem;line-height:1.7}
      .prose .section-break{height:1px;background:#f2f4f6;border:none;margin:3rem 0}
      .prose .tip{background:#e6f9f0;border-left:3px solid #00c471;border-radius:0 8px 8px 0;padding:1rem 1.25rem;margin:1.5rem 0;color:#333d4b;font-size:.95rem;line-height:1.7}
    </style>
  </head>
  <body class="min-h-screen" style="background: #fff;">
    <!-- Header -->
    <header class="site-header">
      <nav class="site-nav">
        <a href="/" class="site-logo">
          <svg class="logo-icon" width="26" height="26" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><circle cx="16" cy="16" r="16" fill="#00c471"/><text x="16" y="23" text-anchor="middle" font-family="'JetBrains Mono',monospace" font-weight="800" font-size="20" fill="#fff">j</text></svg>
          <span class="logo-text">jidonglab</span>
        </a>
        <div class="nav-right">
          <div class="nav-tabs">
            {navItems.map(item => (
              <a
                href={item.href}
                class:list={['nav-tab', { active: currentPath.startsWith(item.href) }]}
              >
                {item.label}
              </a>
            ))}
          </div>
          <div class="nav-utils">
            <a href="https://dev.to/ji_ai" target="_blank" rel="noopener" class="nav-icon" title="DEV.to">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M7.42 10.05c-.18-.16-.46-.23-.84-.23H6v4.36h.58c.37 0 .65-.08.83-.23s.27-.43.27-.85v-2.19c0-.42-.09-.69-.27-.86zM0 4.94v14.12h24V4.94H0zM8.56 15.3c-.44.58-1.06.77-2.53.77H4.71V8.53h1.4c1.67 0 2.16.18 2.6.9.27.43.29.6.29 2.72 0 2.24-.02 2.38-.44 3.15zm4.93-1.97c0 1.03-.1 1.44-.4 1.83-.38.49-.87.7-1.63.7-.76 0-1.26-.22-1.63-.7-.3-.39-.4-.8-.4-1.83V9.2c0-1.03.1-1.44.4-1.83.38-.49.87-.7 1.63-.7s1.26.22 1.63.7c.3.39.4.8.4 1.83v4.13zm5.67-3.4c0 .36-.29.65-.65.65h-.97v1.61h.97c.36 0 .65.29.65.65v.65c0 .36-.29.65-.65.65h-.97v1.61h.97c.36 0 .65.29.65.65v.65c0 .36-.29.65-.65.65h-2.27c-.36 0-.65-.29-.65-.65v-8c0-.36.29-.65.65-.65h2.27c.36 0 .65.29.65.65v.65zm-5.67.65c0-.48-.15-.72-.46-.72-.31 0-.46.24-.46.72v4.13c0 .48.15.72.46.72.31 0 .46-.24.46-.72V10.58z"/></svg>
            </a>
            <button id="lang-toggle" class="lang-btn" title="Switch language">
              EN
            </button>
          </div>
        </div>
      </nav>
    </header>

    <main class="site-main">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-grid">
          <div class="footer-col">
            <div class="footer-logo">
              <svg class="footer-logo-icon" width="20" height="20" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"><circle cx="16" cy="16" r="16" fill="#00c471"/><text x="16" y="23" text-anchor="middle" font-family="'JetBrains Mono',monospace" font-weight="800" font-size="20" fill="#fff">j</text></svg>
              jidonglab
            </div>
            <p class="footer-desc" data-ko="AI를 사용하고, 연구한다." data-en="Using AI, Researching.">AI를 사용하고, 연구한다.</p>
          </div>
          <div class="footer-col">
            <div class="footer-heading">Links</div>
            <a href="/projects" class="footer-link">Projects</a>
            <a href="/posts" class="footer-link">AI Posts</a>
            <a href="/ai-news" class="footer-link">AI News</a>
            <a href="/about" class="footer-link">About</a>
          </div>
          <div class="footer-col">
            <div class="footer-heading">Connect</div>
            <a href="https://dev.to/ji_ai" target="_blank" rel="noopener" class="footer-link">DEV.to</a>
            <a href="/rss.xml" class="footer-link">RSS Feed</a>
          </div>
        </div>
        <div class="footer-bottom">
          <p>&copy; {new Date().getFullYear()} jidonglab. Built with Astro + Claude Code.</p>
        </div>
      </div>
    </footer>

    <script is:inline>
      // Language toggle
      function applyLang(lang) {
        document.documentElement.lang = lang;
        document.querySelectorAll('[data-ko][data-en]').forEach(function(el) {
          var text = lang === 'ko' ? el.dataset.ko : el.dataset.en;
          // If element has child elements (svg, span, etc), only update the first text node
          var hasChildren = el.querySelector('*');
          if (hasChildren) {
            var found = false;
            for (var i = 0; i < el.childNodes.length; i++) {
              if (el.childNodes[i].nodeType === 3 && el.childNodes[i].textContent.trim()) {
                el.childNodes[i].textContent = text;
                found = true;
                break;
              }
            }
            if (!found) {
              // Prepend text node before first child
              el.insertBefore(document.createTextNode(text), el.firstChild);
            }
          } else {
            el.textContent = text;
          }
        });
        // Translate placeholders
        document.querySelectorAll('[data-ph-ko][data-ph-en]').forEach(function(el) {
          el.placeholder = lang === 'ko' ? el.dataset.phKo : el.dataset.phEn;
        });
        document.querySelectorAll('.lang-item').forEach(function(el) {
          var itemLang = el.dataset.lang;
          if (!itemLang || itemLang === 'all') return;
          el.style.display = itemLang === lang ? '' : 'none';
        });
      }

      var langBtn = document.getElementById('lang-toggle');
      var lang = localStorage.getItem('lang') || 'ko';
      if (langBtn) {
        langBtn.textContent = lang === 'ko' ? 'EN' : 'KO';
        applyLang(lang);
        langBtn.addEventListener('click', function() {
          lang = lang === 'ko' ? 'en' : 'ko';
          localStorage.setItem('lang', lang);
          langBtn.textContent = lang === 'ko' ? 'EN' : 'KO';
          applyLang(lang);
        });
      }
    </script>
  </body>
</html>

<style>
  /* ═══ Header ═══ */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid #f2f4f6;
  }

  .site-nav {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }

  .site-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .site-logo:hover {
    opacity: 0.7;
  }

  .logo-icon {
    flex-shrink: 0;
  }

  .logo-text {
    font-family: 'JetBrains Mono', monospace;
    font-weight: 700;
    font-size: 1.1rem;
    color: #191f28;
    letter-spacing: -0.03em;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1rem;
    height: 100%;
  }

  .nav-tabs {
    display: flex;
    align-items: center;
    height: 100%;
    gap: 0;
  }

  .nav-tab {
    display: flex;
    align-items: center;
    height: 100%;
    padding: 0 1rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: #6b7684;
    text-decoration: none;
    border-bottom: 2px solid transparent;
    transition: all 0.2s;
  }

  .nav-tab:hover {
    color: #333d4b;
  }

  .nav-tab.active {
    color: #00c471;
    border-bottom-color: #00c471;
    font-weight: 600;
  }

  .nav-utils {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-left: 0.5rem;
    padding-left: 1rem;
    border-left: 1px solid #f2f4f6;
  }

  .nav-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    color: #8b95a1;
    text-decoration: none;
    transition: all 0.15s;
  }

  .nav-icon:hover {
    background: #f2f4f6;
    color: #333d4b;
  }

  .lang-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    border: 1px solid #e5e8eb;
    background: #fff;
    color: #6b7684;
    font-size: 0.7rem;
    font-weight: 600;
    font-family: 'JetBrains Mono', monospace;
    cursor: pointer;
    transition: all 0.15s;
  }

  .lang-btn:hover {
    border-color: #00c471;
    color: #00c471;
    background: #e6f9f0;
  }

  /* ═══ Main ═══ */
  .site-main {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ═══ Footer ═══ */
  .site-footer {
    margin-top: 6rem;
    background: #f9fafb;
    border-top: 1px solid #f2f4f6;
  }

  .footer-inner {
    max-width: 1080px;
    margin: 0 auto;
    padding: 3.5rem 1.5rem 2rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 3rem;
    margin-bottom: 2.5rem;
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: 'JetBrains Mono', monospace;
    font-weight: 700;
    font-size: 1rem;
    color: #191f28;
    margin-bottom: 0.5rem;
    letter-spacing: -0.03em;
  }

  .footer-desc {
    font-size: 0.875rem;
    color: #8b95a1;
    line-height: 1.6;
  }

  .footer-heading {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #8b95a1;
    margin-bottom: 0.75rem;
  }

  .footer-link {
    display: block;
    font-size: 0.875rem;
    color: #6b7684;
    text-decoration: none;
    padding: 0.25rem 0;
    transition: color 0.15s;
  }

  .footer-link:hover {
    color: #00c471;
  }

  .footer-bottom {
    padding-top: 1.5rem;
    border-top: 1px solid #e5e8eb;
    font-size: 0.8rem;
    color: #8b95a1;
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .nav-tabs {
      display: none;
    }
  }
</style>
