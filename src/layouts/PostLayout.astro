---
import Base from './Base.astro';

interface Props {
  title: string;
  date: Date;
  project?: string;
  tags?: string[];
  pair?: string;
  lang?: string;
}

const { title, date, project, tags = [], pair, lang } = Astro.props;
const dateStr = date.toISOString().split('T')[0];
const formattedDate = date.toLocaleDateString('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const slug = Astro.url.pathname;
---

<Base title={title}>
  <article class="post fade-in">
    <header class="post-header">
      <h1 class="post-title">{title}</h1>
      <div class="post-meta">
        <time datetime={dateStr}>{formattedDate}</time>
        {project && (
          <>
            <span class="post-sep">&middot;</span>
            <a href={`/projects/${project}`} class="post-project">{project}</a>
          </>
        )}
        {lang && pair && (
          <>
            <span class="post-sep">&middot;</span>
            <a href={`/posts/${pair}`} class="post-lang">
              {lang === 'ko' ? 'English' : '한국어'}
            </a>
          </>
        )}
        <span class="post-sep">&middot;</span>
        <span class="post-views" id="view-count">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          <span id="view-num">0</span>
        </span>
      </div>
      {tags.length > 0 && (
        <div class="post-tags">
          {tags.map((tag) => (
            <span class="post-tag">#{tag}</span>
          ))}
        </div>
      )}
    </header>

    <div class="prose">
      <slot />
    </div>

    <!-- Engagement: 추천 + 공유 -->
    <div class="engagement" id="engagement">
      <button class="like-btn" id="btn-like">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3H14z"/><path d="M7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>
        <span data-ko="추천" data-en="Like">추천</span>
        <span class="like-count" id="like-count">0</span>
      </button>
      <div class="share-btns">
        <button class="share-btn" id="btn-share-x" title="X (Twitter)">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </button>
        <button class="share-btn" id="btn-share-linkedin" title="LinkedIn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </button>
        <button class="share-btn" id="btn-share-copy" title="링크 복사">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
        </button>
      </div>
    </div>

    <!-- Comments: 댓글 -->
    <div class="comments-section" id="comments-section">
      <h3 class="comments-title">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        <span data-ko="댓글" data-en="Comments">댓글</span>
        <span class="comment-count" id="comment-count">0</span>
      </h3>

      <!-- Comment Form -->
      <form class="comment-form" id="comment-form">
        <div class="comment-form-row">
          <input
            type="text"
            id="comment-name"
            class="comment-input comment-name-input"
            placeholder="이름"
            data-ph-ko="이름"
            data-ph-en="Name"
            maxlength="50"
            required
          />
        </div>
        <textarea
          id="comment-text"
          class="comment-input comment-textarea"
          placeholder="댓글을 남겨주세요..."
          data-ph-ko="댓글을 남겨주세요..."
          data-ph-en="Leave a comment..."
          maxlength="1000"
          rows="3"
          required
        ></textarea>
        <div class="comment-form-actions">
          <span class="comment-char-count" id="char-count">0 / 1000</span>
          <button type="submit" class="comment-submit" id="comment-submit">
            <span data-ko="등록" data-en="Submit">등록</span>
          </button>
        </div>
      </form>

      <!-- Comment List -->
      <div class="comment-list" id="comment-list">
        <!-- populated by JS -->
      </div>
      <p class="comments-empty" id="comments-empty" style="display:none;" data-ko="아직 댓글이 없다. 첫 댓글을 남겨보자." data-en="No comments yet. Be the first!">
        아직 댓글이 없다. 첫 댓글을 남겨보자.
      </p>
    </div>

    <footer class="post-footer">
      <a href="/posts" class="post-back" data-ko="← 모든 글 보기" data-en="← All posts">&larr; 모든 글 보기</a>
    </footer>
  </article>
</Base>

<script is:inline define:vars={{ slug }}>
  const API = '/api/engagement';
  const likedKey = `liked:${slug}`;
  const viewedKey = `viewed:${slug}`;
  const savedName = localStorage.getItem('comment-name') || '';

  // Elements
  const viewEl = document.getElementById('view-num');
  const likeCountEl = document.getElementById('like-count');
  const likeBtnEl = document.getElementById('btn-like');
  const commentCountEl = document.getElementById('comment-count');
  const commentListEl = document.getElementById('comment-list');
  const commentFormEl = document.getElementById('comment-form');
  const commentNameEl = document.getElementById('comment-name');
  const commentTextEl = document.getElementById('comment-text');
  const commentSubmitEl = document.getElementById('comment-submit');
  const charCountEl = document.getElementById('char-count');
  const emptyEl = document.getElementById('comments-empty');

  // Restore saved name
  if (commentNameEl && savedName) commentNameEl.value = savedName;

  // Character count
  if (commentTextEl && charCountEl) {
    commentTextEl.addEventListener('input', () => {
      charCountEl.textContent = `${commentTextEl.value.length} / 1000`;
    });
  }

  // Track view (once per session)
  async function trackView() {
    if (!sessionStorage.getItem(viewedKey)) {
      try {
        const res = await fetch(API, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ slug, action: 'view' }),
        });
        const data = await res.json();
        if (viewEl && data.views) viewEl.textContent = String(data.views);
        sessionStorage.setItem(viewedKey, '1');
      } catch { /* silent */ }
    }
  }

  // Load engagement data
  async function loadEngagement() {
    try {
      const res = await fetch(`${API}?slug=${encodeURIComponent(slug)}`);
      const data = await res.json();

      if (viewEl) viewEl.textContent = String(data.views || 0);
      if (likeCountEl) likeCountEl.textContent = String(data.likes || 0);

      // Like state
      if (likeBtnEl && localStorage.getItem(likedKey)) {
        likeBtnEl.classList.add('active');
      }

      // Comments
      renderComments(data.comments || []);
    } catch { /* silent */ }
  }

  // Render comments
  function renderComments(comments) {
    if (!commentListEl || !commentCountEl || !emptyEl) return;
    commentCountEl.textContent = String(comments.length);

    if (comments.length === 0) {
      commentListEl.innerHTML = '';
      emptyEl.style.display = 'block';
      return;
    }

    emptyEl.style.display = 'none';
    commentListEl.innerHTML = comments.map(c => {
      const d = new Date(c.date);
      const dateStr = `${d.getFullYear()}.${String(d.getMonth()+1).padStart(2,'0')}.${String(d.getDate()).padStart(2,'0')} ${String(d.getHours()).padStart(2,'0')}:${String(d.getMinutes()).padStart(2,'0')}`;
      const safeName = escapeHtml(c.name);
      const safeText = escapeHtml(c.text).replace(/\n/g, '<br/>');
      return `<div class="comment">
        <div class="comment-header">
          <span class="comment-author">${safeName}</span>
          <span class="comment-date">${dateStr}</span>
        </div>
        <div class="comment-body">${safeText}</div>
      </div>`;
    }).join('');
  }

  function escapeHtml(str) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  // Like toggle
  if (likeBtnEl) {
    likeBtnEl.addEventListener('click', async () => {
      const isLiked = localStorage.getItem(likedKey);
      const action = isLiked ? 'unlike' : 'like';

      try {
        const res = await fetch(API, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ slug, action }),
        });
        const data = await res.json();
        if (likeCountEl && data.likes !== undefined) {
          likeCountEl.textContent = String(data.likes);
        }

        if (isLiked) {
          localStorage.removeItem(likedKey);
          likeBtnEl.classList.remove('active');
        } else {
          localStorage.setItem(likedKey, '1');
          likeBtnEl.classList.add('active');
        }
      } catch { /* silent */ }
    });
  }

  // Submit comment
  if (commentFormEl) {
    commentFormEl.addEventListener('submit', async (e) => {
      e.preventDefault();
      const name = commentNameEl?.value.trim();
      const text = commentTextEl?.value.trim();
      if (!name || !text) return;

      if (commentSubmitEl) {
        commentSubmitEl.disabled = true;
        commentSubmitEl.textContent = '...';
      }

      try {
        const res = await fetch(API, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ slug, action: 'comment', name, text }),
        });
        const data = await res.json();
        if (data.success) {
          localStorage.setItem('comment-name', name);
          if (commentTextEl) commentTextEl.value = '';
          if (charCountEl) charCountEl.textContent = '0 / 1000';
          // Reload comments
          await loadEngagement();
        }
      } catch { /* silent */ }

      if (commentSubmitEl) {
        commentSubmitEl.disabled = false;
        commentSubmitEl.textContent = '등록';
      }
    });
  }

  // Share buttons
  const shareUrl = window.location.href;
  const shareTitle = document.title;

  const shareXEl = document.getElementById('btn-share-x');
  const shareLinkedinEl = document.getElementById('btn-share-linkedin');
  const shareCopyEl = document.getElementById('btn-share-copy');

  if (shareXEl) {
    shareXEl.addEventListener('click', () => {
      window.open(`https://x.com/intent/tweet?url=${encodeURIComponent(shareUrl)}&text=${encodeURIComponent(shareTitle)}`, '_blank', 'width=550,height=420');
    });
  }

  if (shareLinkedinEl) {
    shareLinkedinEl.addEventListener('click', () => {
      window.open(`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(shareUrl)}`, '_blank', 'width=550,height=420');
    });
  }

  if (shareCopyEl) {
    shareCopyEl.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(shareUrl);
        shareCopyEl.classList.add('copied');
        setTimeout(() => shareCopyEl.classList.remove('copied'), 1500);
      } catch {
        // fallback
        const ta = document.createElement('textarea');
        ta.value = shareUrl;
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        shareCopyEl.classList.add('copied');
        setTimeout(() => shareCopyEl.classList.remove('copied'), 1500);
      }
    });
  }

  // Init
  trackView();
  loadEngagement();
</script>

<style>
  .post {
    max-width: 680px;
    margin: 0 auto;
    padding: 2rem 0 6rem;
  }

  .post-header {
    margin-bottom: 3.5rem;
  }

  .post-title {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 700;
    color: #191f28;
    line-height: 1.35;
    letter-spacing: -0.03em;
    margin: 0 0 1rem;
    word-break: keep-all;
  }

  .post-meta {
    font-size: 0.9rem;
    color: #8b95a1;
    display: flex;
    align-items: center;
    gap: 0;
    flex-wrap: wrap;
  }

  .post-sep {
    margin: 0 0.4rem;
    color: #d1d6db;
  }

  .post-views {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: #8b95a1;
  }

  .post-project,
  .post-lang {
    color: #8b95a1;
    text-decoration: none;
    transition: color 0.15s;
  }

  .post-project:hover,
  .post-lang:hover {
    color: #00c471;
    text-decoration: none;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 1rem;
  }

  .post-tag {
    font-size: 0.8rem;
    color: #8b95a1;
    padding: 0.2rem 0.6rem;
    background: #f2f4f6;
    border-radius: 4px;
  }

  /* ═══ Engagement (추천 + 공유) ═══ */
  .engagement {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    margin-top: 3rem;
    padding: 1.5rem;
    background: #f9fafb;
    border-radius: 12px;
    border: 1px solid #f2f4f6;
  }

  .share-btns {
    display: flex;
    gap: 0.4rem;
  }

  .share-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 1px solid #e5e8eb;
    border-radius: 50%;
    background: #fff;
    color: #8b95a1;
    cursor: pointer;
    transition: all 0.2s;
  }

  .share-btn:hover {
    border-color: #00c471;
    color: #00c471;
    transform: translateY(-1px);
    box-shadow: 0 2px 8px rgba(0, 196, 113, 0.1);
  }

  .share-btn.copied {
    background: #e6f9f0;
    border-color: #00c471;
    color: #00a85e;
  }

  .like-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1.5rem;
    border: 1px solid #e5e8eb;
    border-radius: 100px;
    background: #fff;
    color: #8b95a1;
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    -webkit-user-select: none;
    user-select: none;
  }

  .like-btn:hover {
    border-color: #00c471;
    color: #00c471;
    transform: translateY(-1px);
    box-shadow: 0 2px 8px rgba(0, 196, 113, 0.1);
  }

  .like-btn.active {
    background: #e6f9f0;
    border-color: #00c471;
    color: #00a85e;
  }

  .like-btn.active svg {
    fill: #00c471;
  }

  .like-count {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    min-width: 1.5ch;
    text-align: center;
  }

  /* ═══ Comments (댓글) ═══ */
  .comments-section {
    margin-top: 3rem;
  }

  .comments-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.1rem;
    font-weight: 700;
    color: #191f28;
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid #191f28;
  }

  .comment-count {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    color: #00c471;
    font-weight: 600;
  }

  /* Comment Form */
  .comment-form {
    margin-bottom: 2rem;
  }

  .comment-form-row {
    margin-bottom: 0.5rem;
  }

  .comment-input {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid #e5e8eb;
    border-radius: 8px;
    font-size: 0.9rem;
    font-family: inherit;
    color: #333d4b;
    background: #fff;
    transition: border-color 0.15s;
    box-sizing: border-box;
  }

  .comment-input:focus {
    outline: none;
    border-color: #00c471;
    box-shadow: 0 0 0 3px rgba(0, 196, 113, 0.1);
  }

  .comment-input::placeholder {
    color: #b0b8c1;
  }

  .comment-name-input {
    max-width: 240px;
  }

  .comment-textarea {
    resize: vertical;
    min-height: 80px;
    max-height: 300px;
    line-height: 1.6;
  }

  .comment-form-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 0.5rem;
  }

  .comment-char-count {
    font-size: 0.75rem;
    color: #b0b8c1;
    font-family: 'JetBrains Mono', monospace;
  }

  .comment-submit {
    padding: 0.5rem 1.25rem;
    background: #00c471;
    color: #fff;
    border: none;
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
  }

  .comment-submit:hover {
    background: #00a85e;
  }

  .comment-submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* Comment List */
  .comment-list {
    display: flex;
    flex-direction: column;
  }

  .comments-empty {
    text-align: center;
    color: #b0b8c1;
    font-size: 0.9rem;
    padding: 2rem 0;
  }

  /* Individual comments styled via JS innerHTML + global styles below */

  .post-footer {
    margin-top: 5rem;
    padding-top: 2rem;
    border-top: 1px solid #f2f4f6;
  }

  .post-back {
    font-size: 0.9rem;
    color: #8b95a1;
    text-decoration: none;
    transition: color 0.15s;
  }

  .post-back:hover {
    color: #00c471;
    text-decoration: none;
  }

  /* ═══ Prose (toss.tech 스타일 가독성) ═══ */
  .prose {
    font-size: 1.05rem;
    color: #333d4b;
    line-height: 1.9;
    word-break: keep-all;
    overflow-wrap: break-word;
  }

  /* 제목 */
  .prose :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    color: #191f28;
    margin: 3.5rem 0 1.25rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid #f2f4f6;
    letter-spacing: -0.02em;
    line-height: 1.4;
  }

  .prose :global(h3) {
    font-size: 1.2rem;
    font-weight: 700;
    color: #191f28;
    margin: 2.5rem 0 0.75rem;
    letter-spacing: -0.01em;
    line-height: 1.5;
  }

  .prose :global(h4) {
    font-size: 1.05rem;
    font-weight: 600;
    color: #333d4b;
    margin: 2rem 0 0.5rem;
    line-height: 1.5;
  }

  /* 문단 */
  .prose :global(p) {
    margin: 1.25rem 0;
    line-height: 1.9;
  }

  .prose :global(p + p) {
    margin-top: 1.5rem;
  }

  /* 강조 */
  .prose :global(strong) {
    font-weight: 600;
    color: #191f28;
  }

  .prose :global(em) {
    font-style: italic;
    color: #6b7684;
  }

  /* 링크 */
  .prose :global(a) {
    color: #00c471;
    text-decoration: underline;
    text-decoration-color: rgba(0, 196, 113, 0.3);
    text-underline-offset: 2px;
    transition: all 0.15s;
  }

  .prose :global(a:hover) {
    text-decoration-color: #00c471;
  }

  /* 리스트 */
  .prose :global(ul),
  .prose :global(ol) {
    margin: 1.25rem 0;
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    margin: 0.5rem 0;
    line-height: 1.8;
    color: #333d4b;
  }

  .prose :global(li::marker) {
    color: #00c471;
  }

  .prose :global(ul ul),
  .prose :global(ol ol),
  .prose :global(ul ol),
  .prose :global(ol ul) {
    margin: 0.35rem 0;
  }

  /* 코드 (인라인) */
  .prose :global(code) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.875em;
    color: #e45649;
    background: #f2f4f6;
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    word-break: break-all;
  }

  /* 코드 블록 */
  .prose :global(pre) {
    margin: 2rem 0;
    padding: 1.5rem 1.75rem;
    background: #191f28;
    border-radius: 12px;
    overflow-x: auto;
    line-height: 1.7;
  }

  .prose :global(pre code) {
    color: #e4e9f0;
    background: none;
    padding: 0;
    font-size: 0.85rem;
    border-radius: 0;
  }

  /* 인용 */
  .prose :global(blockquote) {
    margin: 2rem 0;
    padding: 1rem 1.5rem;
    border-left: 3px solid #00c471;
    background: #f9fafb;
    border-radius: 0 8px 8px 0;
    color: #6b7684;
    font-size: 1rem;
    line-height: 1.8;
  }

  .prose :global(blockquote p) {
    margin: 0.5rem 0;
  }

