---
import Base from './Base.astro';

interface Props {
  title: string;
  date: Date;
  project?: string;
  tags?: string[];
  pair?: string;
  lang?: string;
}

const { title, date, project, tags = [], pair, lang } = Astro.props;
const dateStr = date.toISOString().split('T')[0];
const formattedDate = date.toLocaleDateString('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const slug = Astro.url.pathname;
---

<Base title={title}>
  <article class="post fade-in">
    <header class="post-header">
      <h1 class="post-title">{title}</h1>
      <div class="post-meta">
        <time datetime={dateStr}>{formattedDate}</time>
        {project && (
          <>
            <span class="post-sep">&middot;</span>
            <a href={`/projects/${project}`} class="post-project">{project}</a>
          </>
        )}
        {lang && pair && (
          <>
            <span class="post-sep">&middot;</span>
            <a href={`/posts/${pair}`} class="post-lang">
              {lang === 'ko' ? 'English' : '한국어'}
            </a>
          </>
        )}
        <span class="post-sep">&middot;</span>
        <span class="post-views" id="view-count">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          <span id="view-num">0</span>
        </span>
      </div>
      {tags.length > 0 && (
        <div class="post-tags">
          {tags.map((tag) => (
            <span class="post-tag">#{tag}</span>
          ))}
        </div>
      )}
    </header>

    <div class="prose">
      <slot />
    </div>

    <!-- Reactions -->
    <div class="reactions" id="reactions">
      <button class="reaction-btn" data-reaction="like" id="btn-like">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3H14z"/><path d="M7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>
        <span id="like-count">0</span>
      </button>
      <button class="reaction-btn" data-reaction="fire" id="btn-fire">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 12c2-2.96 0-7-1-8 0 3.038-1.773 4.741-3 6-1.226 1.26-2 3.24-2 5a6 6 0 1 0 12 0c0-1.532-1.056-3.94-2-5-1.786 3-2.791 3-4 2z"/></svg>
        <span id="fire-count">0</span>
      </button>
      <button class="reaction-btn" data-reaction="clap" id="btn-clap">
        <span style="font-size: 1.1rem;">👏</span>
        <span id="clap-count">0</span>
      </button>
    </div>

    <footer class="post-footer">
      <a href="/posts" class="post-back">&larr; 모든 글 보기</a>
    </footer>
  </article>
</Base>

<script is:inline define:vars={{ slug }}>
  // View counter (localStorage-based)
  const viewKey = `views:${slug}`;
  const viewedKey = `viewed:${slug}`;
  let views = parseInt(localStorage.getItem(viewKey) || '0');

  if (!sessionStorage.getItem(viewedKey)) {
    views++;
    localStorage.setItem(viewKey, String(views));
    sessionStorage.setItem(viewedKey, '1');
  }

  const viewEl = document.getElementById('view-num');
  if (viewEl) viewEl.textContent = String(views);

  // Reactions (localStorage-based)
  const reactKey = `reactions:${slug}`;
  const myReactKey = `my-reactions:${slug}`;
  const reactions = JSON.parse(localStorage.getItem(reactKey) || '{"like":0,"fire":0,"clap":0}');
  const myReactions = JSON.parse(localStorage.getItem(myReactKey) || '{}');

  ['like', 'fire', 'clap'].forEach(type => {
    const countEl = document.getElementById(`${type}-count`);
    const btnEl = document.getElementById(`btn-${type}`);
    if (countEl) countEl.textContent = String(reactions[type] || 0);
    if (btnEl && myReactions[type]) btnEl.classList.add('active');

    if (btnEl) {
      btnEl.addEventListener('click', () => {
        if (myReactions[type]) {
          reactions[type] = Math.max(0, (reactions[type] || 0) - 1);
          delete myReactions[type];
          btnEl.classList.remove('active');
        } else {
          reactions[type] = (reactions[type] || 0) + 1;
          myReactions[type] = true;
          btnEl.classList.add('active');
        }
        localStorage.setItem(reactKey, JSON.stringify(reactions));
        localStorage.setItem(myReactKey, JSON.stringify(myReactions));
        if (countEl) countEl.textContent = String(reactions[type] || 0);
      });
    }
  });
</script>

<style>
  .post {
    max-width: 680px;
    margin: 0 auto;
    padding: 2rem 0 6rem;
  }

  .post-header {
    margin-bottom: 3.5rem;
  }

  .post-title {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 700;
    color: #191f28;
    line-height: 1.35;
    letter-spacing: -0.03em;
    margin: 0 0 1rem;
    word-break: keep-all;
  }

  .post-meta {
    font-size: 0.9rem;
    color: #8b95a1;
    display: flex;
    align-items: center;
    gap: 0;
    flex-wrap: wrap;
  }

  .post-sep {
    margin: 0 0.4rem;
    color: #d1d6db;
  }

  .post-views {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: #8b95a1;
  }

  .post-project,
  .post-lang {
    color: #8b95a1;
    text-decoration: none;
    transition: color 0.15s;
  }

  .post-project:hover,
  .post-lang:hover {
    color: #00c471;
    text-decoration: none;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 1rem;
  }

  .post-tag {
    font-size: 0.8rem;
    color: #8b95a1;
    padding: 0.2rem 0.6rem;
    background: #f2f4f6;
    border-radius: 4px;
  }

  /* ═══ Reactions ═══ */
  .reactions {
    display: flex;
    gap: 0.75rem;
    margin-top: 3rem;
    padding: 1.5rem;
    background: #f9fafb;
    border-radius: 12px;
    border: 1px solid #f2f4f6;
    justify-content: center;
  }

  .reaction-btn {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 1rem;
    border: 1px solid #e5e8eb;
    border-radius: 100px;
    background: #fff;
    color: #8b95a1;
    font-size: 0.85rem;
    font-family: 'JetBrains Mono', monospace;
    cursor: pointer;
    transition: all 0.2s;
    -webkit-user-select: none;
    user-select: none;
  }

  .reaction-btn:hover {
    border-color: #00c471;
    color: #00c471;
    transform: translateY(-1px);
    box-shadow: 0 2px 8px rgba(0, 196, 113, 0.1);
  }

  .reaction-btn.active {
    background: #e6f9f0;
    border-color: #00c471;
    color: #00a85e;
  }

  .post-footer {
    margin-top: 5rem;
    padding-top: 2rem;
    border-top: 1px solid #f2f4f6;
  }

  .post-back {
    font-size: 0.9rem;
    color: #8b95a1;
    text-decoration: none;
    transition: color 0.15s;
  }

  .post-back:hover {
    color: #00c471;
    text-decoration: none;
  }
</style>
