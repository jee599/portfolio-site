---
import Base from './Base.astro';

interface Props {
  title: string;
  date: Date;
  project?: string;
  tags?: string[];
  pair?: string;
  lang?: string;
}

const { title, date, project, tags = [], pair, lang } = Astro.props;
const dateStr = date.toISOString().split('T')[0];
---

<Base title={title}>
  <article class="fade-in max-w-2xl">
    <header class="mb-14 pb-8 border-b border-border/40">
      {project && (
        <a
          href={`/projects/${project}`}
          class="inline-block text-xs font-mono text-accent-dark no-underline uppercase tracking-widest mb-3 px-2.5 py-1 bg-accent-light rounded-md"
        >
          {project}
        </a>
      )}
      <h1 class="text-3xl font-display font-bold text-heading mt-1 mb-5 leading-snug">{title}</h1>
      <div class="flex items-center gap-4 text-sm text-muted">
        <time datetime={dateStr}>{dateStr}</time>
        {lang && pair && (
          <a href={`/posts/${pair}`} class="text-xs font-mono px-2 py-0.5 bg-surface rounded border border-border/50 no-underline hover:bg-border/20">
            {lang === 'ko' ? 'EN →' : 'KO →'}
          </a>
        )}
      </div>
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {tags.map((tag) => (
            <span class="text-xs font-mono px-2.5 py-1 rounded-md bg-surface text-muted border border-border/40">
              #{tag}
            </span>
          ))}
        </div>
      )}
    </header>

    <div class="prose">
      <slot />
    </div>
  </article>
</Base>
