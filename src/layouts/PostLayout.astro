---
import Base from './Base.astro';

interface Props {
  title: string;
  date: Date;
  project?: string;
  tags?: string[];
  pair?: string;
  lang?: string;
}

const { title, date, project, tags = [], pair, lang } = Astro.props;
const dateStr = date.toISOString().split('T')[0];
const formattedDate = date.toLocaleDateString('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base title={title}>
  <article class="post fade-in">
    <header class="post-header">
      <h1 class="post-title">{title}</h1>
      <div class="post-meta">
        <time datetime={dateStr}>{formattedDate}</time>
        {project && (
          <>
            <span class="post-sep">&middot;</span>
            <a href={`/projects/${project}`} class="post-project">{project}</a>
          </>
        )}
        {lang && pair && (
          <>
            <span class="post-sep">&middot;</span>
            <a href={`/posts/${pair}`} class="post-lang">
              {lang === 'ko' ? 'English' : '한국어'}
            </a>
          </>
        )}
      </div>
      {tags.length > 0 && (
        <div class="post-tags">
          {tags.map((tag) => (
            <span class="post-tag">#{tag}</span>
          ))}
        </div>
      )}
    </header>

    <div class="prose">
      <slot />
    </div>

    <footer class="post-footer">
      <a href="/posts" class="post-back">&larr; 모든 글 보기</a>
    </footer>
  </article>
</Base>

<style>
  .post {
    max-width: 680px;
    margin: 0 auto;
    padding: 2rem 0 6rem;
  }

  .post-header {
    margin-bottom: 3.5rem;
  }

  .post-title {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 700;
    color: #e8e8f0;
    line-height: 1.35;
    letter-spacing: -0.03em;
    margin: 0 0 1rem;
    word-break: keep-all;
  }

  .post-meta {
    font-size: 0.9rem;
    color: #7a7a9a;
    display: flex;
    align-items: center;
    gap: 0;
  }

  .post-sep {
    margin: 0 0.4rem;
    color: #2a2a3e;
  }

  .post-project,
  .post-lang {
    color: #7a7a9a;
    text-decoration: none;
    transition: color 0.15s;
  }

  .post-project:hover,
  .post-lang:hover {
    color: #8b83ff;
    text-decoration: none;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 1rem;
  }

  .post-tag {
    font-size: 0.8rem;
    color: #7a7a9a;
    padding: 0.2rem 0.6rem;
    background: #1a1a2e;
    border-radius: 4px;
    border: 1px solid #2a2a3e;
  }

  .post-footer {
    margin-top: 5rem;
    padding-top: 2rem;
    border-top: 1px solid #1a1a2e;
  }

  .post-back {
    font-size: 0.9rem;
    color: #7a7a9a;
    text-decoration: none;
    transition: color 0.15s;
  }

  .post-back:hover {
    color: #8b83ff;
    text-decoration: none;
  }
</style>
