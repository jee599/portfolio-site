    <script is:inline>
      const AUTH_KEY = 'admin_secret';
      const authWall = document.getElementById('auth-wall');
      const dashboard = document.getElementById('dashboard');
      const tabNav = document.getElementById('tab-nav');
      const secretInput = document.getElementById('secret-input');
      const authBtn = document.getElementById('auth-btn');
      const authError = document.getElementById('auth-error');
      const logoutBtn = document.getElementById('logout-btn');

      let currentSecret = '';
      let allContent = [];

      const saved = sessionStorage.getItem(AUTH_KEY);
      if (saved) {
        currentSecret = saved;
        authWall.style.display = 'none';
        dashboard.classList.add('active');
        tabNav.classList.add('active');
        logoutBtn.style.display = '';
        loadDashboard(saved);
      }

      authBtn.addEventListener('click', tryAuth);
      secretInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') tryAuth(); });

      logoutBtn.addEventListener('click', () => {
        sessionStorage.removeItem(AUTH_KEY);
        currentSecret = '';
        authWall.style.display = '';
        dashboard.classList.remove('active');
        tabNav.classList.remove('active');
        logoutBtn.style.display = 'none';
        secretInput.value = '';
        authError.style.display = 'none';
      });

      document.querySelectorAll('.tab-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
          document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
          btn.classList.add('active');
          document.getElementById('panel-' + btn.dataset.tab).classList.add('active');
          if (btn.dataset.tab === 'comments') loadComments();
          if (btn.dataset.tab === 'projects') loadProjects();
          if (btn.dataset.tab === 'build-logs') loadBuildLogs();
        });
      });

      async function tryAuth() {
        const secret = secretInput.value.trim();
        if (!secret) return;
        authBtn.textContent = '...';
        authBtn.disabled = true;
        try {
          const res = await fetch(`/api/admin-stats?secret=${encodeURIComponent(secret)}`);
          if (res.ok) {
            currentSecret = secret;
            sessionStorage.setItem(AUTH_KEY, secret);
            authWall.style.display = 'none';
            dashboard.classList.add('active');
            tabNav.classList.add('active');
            logoutBtn.style.display = '';
            renderDashboard(await res.json());
          } else {
            authError.style.display = 'block';
          }
        } catch { authError.style.display = 'block'; }
        authBtn.textContent = 'Enter';
        authBtn.disabled = false;
      }

      async function loadDashboard(secret) {
        try {
          const res = await fetch(`/api/admin-stats?secret=${encodeURIComponent(secret)}`);
          if (!res.ok) {
            sessionStorage.removeItem(AUTH_KEY);
            currentSecret = '';
            authWall.style.display = '';
            dashboard.classList.remove('active');
            tabNav.classList.remove('active');
            logoutBtn.style.display = 'none';
            return;
          }
          renderDashboard(await res.json());
        } catch {
          document.getElementById('loading').textContent = 'Failed to load.';
        }
      }

      function fmt(n) { return (n || 0).toLocaleString(); }

      function renderDashboard(data) {
        document.getElementById('loading').style.display = 'none';
        document.getElementById('stats-grid').style.display = '';
        document.getElementById('platforms-overview').style.display = '';
        document.getElementById('heatmap-section').style.display = '';
        document.getElementById('top-sections').style.display = '';

        // Stats
        document.getElementById('stat-today').textContent = fmt(data.visitors?.today);
        document.getElementById('stat-total').textContent = fmt(data.visitors?.total);
        document.getElementById('stat-views').textContent = fmt(data.summary?.totalViews);
        document.getElementById('stat-likes').textContent = fmt(data.summary?.totalLikes);
        document.getElementById('stat-comments').textContent = fmt(data.summary?.totalComments);
        document.getElementById('stat-posts').textContent = fmt(data.summary?.totalPosts);
        const bt = data.summary?.byType || {};
        document.getElementById('stat-posts-sub').textContent =
          `BL${bt['build-log']||0} T${bt['tip']||0} N${bt['ai-news']||0} B${bt['blog']||0}`;

        // Heatmap
        renderHeatmap(data.visitors?.daily || []);

        // Content
        allContent = data.content || [];
        renderContentList('all');
        document.querySelectorAll('#content-filter .filter-btn').forEach(btn => {
          btn.addEventListener('click', () => {
            document.querySelectorAll('#content-filter .filter-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            renderContentList(btn.dataset.filter);
          });
        });

        // Build logs by project
        renderProjectLogs(data.content || []);

        // Top lists
        renderTopLists(data.content || []);

        // Platform stats (async, non-blocking)
        loadPlatformStats();
      }

      // ═══ Heatmap ═══
      function renderHeatmap(daily) {
        const container = document.getElementById('heatmap');
        const rangeEl = document.getElementById('heatmap-range');

        const dateMap = {};
        daily.forEach(d => { dateMap[d.date] = d.count; });

        // Generate 90 days
        const today = new Date();
        const days = [];
        for (let i = 89; i >= 0; i--) {
          const d = new Date(today);
          d.setDate(d.getDate() - i);
          const key = d.toISOString().split('T')[0];
          days.push({ date: key, count: dateMap[key] || 0, day: d.getDay(), month: d.getMonth(), dateObj: d });
        }

        const totalVisitors = days.reduce((s, d) => s + d.count, 0);
        const activeDays = days.filter(d => d.count > 0).length;
        rangeEl.textContent = activeDays > 0
          ? `최근 90일 · ${totalVisitors.toLocaleString()}명 · ${activeDays}일 활동`
          : '최근 90일';

        const max = Math.max(...days.map(d => d.count), 1);

        function level(count) {
          if (count === 0) return '';
          const ratio = count / max;
          if (ratio <= 0.25) return 'l1';
          if (ratio <= 0.5) return 'l2';
          if (ratio <= 0.75) return 'l3';
          return 'l4';
        }

        const MONTHS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

        // Group into weeks
        const weeks = [];
        let currentWeek = [];
        const firstDay = days[0].day;
        for (let i = 0; i < firstDay; i++) currentWeek.push(null);

        days.forEach(d => {
          if (d.day === 0 && currentWeek.length > 0) {
            weeks.push(currentWeek);
            currentWeek = [];
          }
          currentWeek.push(d);
        });
        if (currentWeek.length > 0) weeks.push(currentWeek);

        // Build month labels
        const monthLabels = [];
        let lastMonth = -1;
        weeks.forEach((week, wi) => {
          const firstReal = week.find(d => d !== null);
          if (firstReal && firstReal.month !== lastMonth) {
            monthLabels.push({ index: wi, label: MONTHS[firstReal.month] });
            lastMonth = firstReal.month;
          }
        });

        // Month label row
        let monthHtml = '<div style="display:flex;gap:3px;margin-left:22px;margin-bottom:2px;">';
        let pos = 0;
        monthLabels.forEach((m, i) => {
          const gap = m.index - pos;
          if (gap > 0) monthHtml += `<div style="width:${gap * 17}px;"></div>`;
          const nextIdx = (i + 1 < monthLabels.length) ? monthLabels[i + 1].index : weeks.length;
          const span = nextIdx - m.index;
          monthHtml += `<div class="heatmap-month" style="width:${span * 17}px;">${m.label}</div>`;
          pos = nextIdx;
        });
        monthHtml += '</div>';

        const weeksHtml = weeks.map(week => {
          const cells = [];
          for (let i = 0; i < 7; i++) {
            const d = week[i];
            if (!d) {
              cells.push('<div class="heatmap-cell" style="visibility:hidden;"></div>');
            } else {
              const dateLabel = `${d.dateObj.getMonth()+1}/${d.dateObj.getDate()}`;
              const tip = d.count > 0 ? `${dateLabel} · ${d.count}명` : `${dateLabel}`;
              cells.push(`<div class="heatmap-cell ${level(d.count)}"><div class="tip">${tip}</div></div>`);
            }
          }
          return `<div class="heatmap-week">${cells.join('')}</div>`;
        }).join('');

        // Insert month labels above the heatmap
        container.parentElement.querySelector('.heatmap-month-row')?.remove();
        const monthRow = document.createElement('div');
        monthRow.className = 'heatmap-month-row';
        monthRow.innerHTML = monthHtml;
        container.parentElement.insertBefore(monthRow, container.parentElement.querySelector('[style*="display:flex"]'));

        container.innerHTML = weeksHtml;
      }

      // ═══ Project Logs ═══
      function renderProjectLogs(content) {
        const logs = content.filter(c => c.type !== 'placeholder').sort((a, b) => b.views - a.views);
        if (logs.length === 0) return;

        document.getElementById('project-logs-section').style.display = '';
        const types = [...new Set(logs.map(c => c.type))];

        const filterBar = document.getElementById('project-filter');
        filterBar.innerHTML = `<button class="filter-btn active" data-project="all">All (${logs.length})</button>` +
          types.map(t => {
            const count = logs.filter(c => c.type === t).length;
            return `<button class="filter-btn" data-project="${esc(t)}">${esc(t)} (${count})</button>`;
          }).join('');

        function renderLogs(filter) {
          const filtered = filter === 'all' ? logs : logs.filter(c => c.type === filter);
          const container = document.getElementById('project-logs-list');
          container.innerHTML = filtered.sort((a, b) => b.views - a.views).map(c => {
            const viewClass = c.views > 0 ? 'has-data' : '';
            return `<div class="content-item">
              <div class="content-left">
                <div class="content-title-row">
                  <span class="type-badge ${c.type}">${esc(c.type)}</span>
                  <a href="${c.slug}" target="_blank" class="content-title">${esc(c.title)}</a>
                </div>
                <span class="content-date">${c.date}</span>
              </div>
              <div class="content-stats">
                <span class="content-stat ${viewClass}">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                  ${c.views}
                </span>
              </div>
            </div>`;
          }).join('');
        }

        renderLogs('all');
        filterBar.addEventListener('click', (e) => {
          const btn = e.target.closest('.filter-btn');
          if (!btn) return;
          filterBar.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          renderLogs(btn.dataset.project);
        });
      }

      // ═══ Content List ═══
      function renderContentList(filter) {
        const container = document.getElementById('content-list');
        const filtered = filter === 'all' ? allContent : allContent.filter(c => c.type === filter);

        if (filtered.length === 0) {
          container.innerHTML = '<div class="empty-state">No content</div>';
          return;
        }

        container.innerHTML = filtered.map(c => {
          const viewClass = c.views > 0 ? 'has-data' : '';
          const likeClass = c.likes > 0 ? 'has-data' : '';
          const commentClass = c.comments > 0 ? 'has-data' : '';
          return `<div class="content-item">
            <div class="content-left">
              <div class="content-title-row">
                <span class="type-badge ${c.type}">${c.type}</span>
                <a href="${c.slug}" target="_blank" class="content-title">${esc(c.title)}</a>
              </div>
              <span class="content-date">${c.date}</span>
            </div>
            <div class="content-stats">
              <span class="content-stat ${viewClass}">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                ${c.views}
              </span>
              <span class="content-stat ${likeClass}">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3H14z"/><path d="M7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>
                ${c.likes}
              </span>
              <span class="content-stat ${commentClass}">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                ${c.comments}
              </span>
            </div>
          </div>`;
        }).join('');
      }

      // ═══ Top Lists ═══
      function renderTopLists(content) {
        const viewsList = document.getElementById('top-views');
        const engList = document.getElementById('top-engagement');

        const byViews = [...content].sort((a, b) => b.views - a.views).slice(0, 10);
        const byEng = [...content].sort((a, b) =>
          (b.views + b.likes * 5 + b.comments * 10) - (a.views + a.likes * 5 + a.comments * 10)
        ).slice(0, 10);

        function renderList(list, container, mainStat) {
          if (list.every(c => c.views === 0 && c.likes === 0 && c.comments === 0)) {
            container.innerHTML = '<div class="empty-state">No engagement data yet.</div>';
            return;
          }
          container.innerHTML = list.map((c, i) => {
            const score = c.views + c.likes * 5 + c.comments * 10;
            const stat = mainStat === 'views'
              ? `<span class="top-stat-highlight">${c.views}v</span>`
              : `<span class="top-stat-highlight">${score}pt</span>`;
            return `<div class="top-item">
              <span class="top-rank">${i + 1}</span>
              <span class="type-badge ${c.type}" style="font-size:0.55rem;">${c.type}</span>
              <span class="top-title">${esc(c.title)}</span>
              <div class="top-stats">
                ${stat}
                <span>${c.likes}L ${c.comments}C</span>
              </div>
            </div>`;
          }).join('');
        }

        renderList(byViews, viewsList, 'views');
        renderList(byEng, engList, 'engagement');
      }

      // ═══ Quick Actions ═══
      document.getElementById('btn-generate-news').addEventListener('click', async function() {
        await runAction(this, 'status-generate-news', 'generate-ai-news', 300000);
      });
      document.getElementById('btn-revalidate').addEventListener('click', async function() {
        await runAction(this, 'status-revalidate', 'revalidate');
      });

      async function runAction(btn, statusId, action, timeout = 30000) {
        const status = document.getElementById(statusId);
        btn.disabled = true;
        status.className = 'action-status loading';
        status.textContent = action === 'generate-ai-news' ? 'Generating... (1~2 min)' : 'Processing...';
        try {
          const controller = new AbortController();
          const timer = setTimeout(() => controller.abort(), timeout);
          const res = await fetch('/api/admin-actions', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ secret: currentSecret, action }),
            signal: controller.signal,
          });
          clearTimeout(timer);
          const data = await res.json();
          if (res.ok && data.ok) {
            status.className = 'action-status success';
            status.textContent = data.message || 'Success';
            if (data.generated) status.textContent += ` (${data.generated} posts)`;
          } else {
            status.className = 'action-status error';
            status.textContent = data.error || 'Failed';
          }
        } catch (e) {
          status.className = 'action-status error';
          status.textContent = e.name === 'AbortError' ? 'Timeout - check logs' : String(e);
        }
        btn.disabled = false;
      }

      // ═══ Comments ═══
      async function loadComments() {
        const container = document.getElementById('comments-list');
        container.innerHTML = '<div class="empty-state">Loading comments...</div>';
        const withComments = allContent.filter(c => c.comments > 0);
        if (withComments.length === 0) {
          container.innerHTML = '<div class="empty-state">No comments yet.</div>';
          return;
        }
        let allComments = [];
        for (const item of withComments) {
          try {
            const res = await fetch('/api/admin-actions', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ secret: currentSecret, action: 'list-comments', slug: item.slug }),
            });
            if (res.ok) {
              const data = await res.json();
              allComments.push(...(data.comments || []).map(c => ({
                ...c, postTitle: item.title, postSlug: item.slug,
              })));
            }
          } catch {}
        }
        allComments.sort((a, b) => new Date(b.date) - new Date(a.date));
        if (allComments.length === 0) {
          container.innerHTML = '<div class="empty-state">No comments yet.</div>';
          return;
        }
        container.innerHTML = allComments.map(c => `
          <div class="comment-card" data-slug="${esc(c.postSlug)}" data-index="${c.index}">
            <div class="comment-header">
              <div class="comment-meta">
                <span class="comment-name">${esc(c.name)}</span>
                <span class="comment-date">${new Date(c.date).toLocaleString('ko-KR')}</span>
                <a href="${c.postSlug}" target="_blank" class="comment-slug">${esc(c.postSlug)}</a>
              </div>
              <button class="delete-btn" onclick="deleteComment(this, '${esc(c.postSlug)}', ${c.index})">Delete</button>
            </div>
            <div class="comment-text">${esc(c.text)}</div>
          </div>
        `).join('');
      }

      window.deleteComment = async function(btn, slug, index) {
        if (!confirm('Delete this comment?')) return;
        btn.textContent = '...';
        btn.disabled = true;
        try {
          const res = await fetch('/api/admin-actions', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ secret: currentSecret, action: 'delete-comment', slug, commentIndex: index }),
          });
          if (res.ok) {
            btn.closest('.comment-card').remove();
            if (!document.querySelectorAll('.comment-card').length) {
              document.getElementById('comments-list').innerHTML = '<div class="empty-state">No comments.</div>';
            }
          } else {
            alert((await res.json()).error || 'Failed');
            btn.textContent = 'Delete'; btn.disabled = false;
          }
        } catch {
          alert('Failed'); btn.textContent = 'Delete'; btn.disabled = false;
        }
      };

      // ═══ Platform Stats ═══
      async function loadPlatformStats() {
        try {
          const res = await fetch(`/api/platform-stats?secret=${encodeURIComponent(currentSecret)}`);
          if (!res.ok) return;
          const data = await res.json();

          function setViews(prefix, text) {
            var el = document.getElementById(prefix);
            if (el) el.textContent = text;
            var ov = document.getElementById('ov-' + prefix.replace('-views','') + '-views');
            if (ov) ov.textContent = text;
          }
          if (data.devto) setViews('devto-views', fmt(data.devto.views) + ' views');
          if (data.hashnode) setViews('hashnode-views', fmt(data.hashnode.views) + ' views');
          if (data.blogger) setViews('blogger-views', fmt(data.blogger.views) + ' views');
          var totalText = document.getElementById('stat-total')?.textContent || '0';
          setViews('jidonglab-views', totalText + ' visitors');
        } catch {}
      }

      // ═══ Projects Tab ═══
      let projectsLoaded = false;
      async function loadProjects() {
        if (projectsLoaded) return;
        const wrap = document.getElementById('projects-table-wrap');
        try {
          const res = await fetch(`/api/admin-projects?secret=${encodeURIComponent(currentSecret)}`);
          if (!res.ok) { wrap.innerHTML = '<div class="empty-state">Failed to load.</div>'; return; }
          const data = await res.json();
          const projects = data.projects || [];
          document.getElementById('projects-count').textContent = `(${projects.length})`;

          const statusMap = { '운영중': 'live', '개발중': 'dev', '실험중': 'beta', '중단': 'stopped' };
          const statusEn = { '운영중': 'Live', '개발중': 'Dev', '실험중': 'Beta', '중단': 'Stopped' };

          let html = `<table class="project-table"><thead><tr>
            <th>Project</th><th>Status</th><th>Stack</th><th>Visible</th>
            <th>Last Log</th><th>Commits</th><th>Build Log</th>
          </tr></thead><tbody>`;

          projects.forEach(p => {
            const sc = statusMap[p.status] || '';
            const recentCommit = p.recentCommits?.[0];
            const commitHtml = recentCommit
              ? `<span class="commit-mini"><span class="sha">${esc(recentCommit.sha)}</span> ${esc(recentCommit.message.slice(0, 40))}</span>`
              : '<span style="color:#b0b8c1;font-size:0.7rem;">—</span>';
            const cliCmd = `bash scripts/generate-build-log.sh --project ${p.slug}`;

            html += `<tr>
              <td><strong>${esc(p.title)}</strong><br><span style="font-size:0.68rem;color:#8b95a1;">${esc(p.slug)}</span></td>
              <td><span class="status-badge ${sc}">${statusEn[p.status] || p.status}</span></td>
              <td><div class="stack-tags">${p.stack.map(s => `<span class="stack-tag">${esc(s)}</span>`).join('')}</div></td>
              <td><button class="visible-toggle ${p.visible ? 'on' : 'off'}" data-slug="${esc(p.slug)}" data-visible="${p.visible}"
                onclick="toggleVisible(this)"></button></td>
              <td style="font-family:'JetBrains Mono',monospace;font-size:0.72rem;color:#6b7684;">
                ${p.lastLogDate || '—'} <span style="color:#b0b8c1;">(${p.logCount})</span>
              </td>
              <td>${commitHtml}</td>
              <td><button class="cli-copy-btn" onclick="copyCmd(this, '${esc(cliCmd)}')">Copy CLI</button></td>
            </tr>`;
          });

          html += '</tbody></table>';
          wrap.innerHTML = html;
          projectsLoaded = true;
        } catch (e) {
          wrap.innerHTML = `<div class="empty-state">Error: ${e}</div>`;
        }
      }

      window.toggleVisible = async function(btn) {
        const slug = btn.dataset.slug;
        const newVisible = btn.dataset.visible !== 'true';
        try {
          const res = await fetch('/api/admin-projects', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ secret: currentSecret, action: 'toggle-visible', slug, visible: newVisible }),
          });
          const data = await res.json();
          if (data.command) {
            alert(data.message);
          }
          btn.dataset.visible = String(newVisible);
          btn.className = `visible-toggle ${newVisible ? 'on' : 'off'}`;
        } catch (e) { alert('Error: ' + e); }
      };

      window.copyCmd = function(btn, cmd) {
        navigator.clipboard.writeText(cmd).then(() => {
          btn.textContent = 'Copied!';
          btn.classList.add('copied');
          setTimeout(() => { btn.textContent = 'Copy CLI'; btn.classList.remove('copied'); }, 2000);
        });
      };

      // ═══ Build Logs Tab ═══
      let buildLogsLoaded = false;
      let allBuildLogs = [];
      async function loadBuildLogs() {
        if (buildLogsLoaded) return;
        const wrap = document.getElementById('bl-list-wrap');
        try {
          const res = await fetch(`/api/admin-build-logs?secret=${encodeURIComponent(currentSecret)}`);
          if (!res.ok) { wrap.innerHTML = '<div class="empty-state">Failed to load.</div>'; return; }
          const data = await res.json();
          allBuildLogs = data.logs || [];
          document.getElementById('bl-count').textContent = `(${allBuildLogs.length})`;

          // 프로젝트별 + 언어별 필터 생성
          const projects = [...new Set(allBuildLogs.map(l => l.project))].sort();
          const filterBar = document.getElementById('bl-filter-bar');
          filterBar.innerHTML = `<button class="filter-btn active" data-blfilter="all">All</button>` +
            projects.map(p => `<button class="filter-btn" data-blfilter="project:${esc(p)}">${esc(p)}</button>`).join('') +
            `<button class="filter-btn" data-blfilter="lang:ko">KO</button>` +
            `<button class="filter-btn" data-blfilter="lang:en">EN</button>`;

          filterBar.addEventListener('click', (e) => {
            const btn = e.target.closest('.filter-btn');
            if (!btn) return;
            filterBar.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            renderBuildLogs(btn.dataset.blfilter);
          });

          renderBuildLogs('all');
          buildLogsLoaded = true;
        } catch (e) {
          wrap.innerHTML = `<div class="empty-state">Error: ${e}</div>`;
        }
      }

      function renderBuildLogs(filter) {
        let filtered = allBuildLogs;
        if (filter.startsWith('project:')) {
          filtered = allBuildLogs.filter(l => l.project === filter.replace('project:', ''));
        } else if (filter.startsWith('lang:')) {
          filtered = allBuildLogs.filter(l => l.lang === filter.replace('lang:', ''));
        }

        const wrap = document.getElementById('bl-list-wrap');
        if (filtered.length === 0) {
          wrap.innerHTML = '<div class="empty-state">No build logs.</div>';
          return;
        }

        let html = `<table class="project-table"><thead><tr>
          <th>Title</th><th>Project</th><th>Date</th><th>Lang</th><th>Published</th><th>Actions</th>
        </tr></thead><tbody>`;

        filtered.forEach(l => {
          const badges = (l.published_to || []).map(p =>
            `<span class="published-badge ${p}">${p}</span>`
          ).join('') || '<span style="color:#b0b8c1;font-size:0.65rem;">—</span>';

          html += `<tr>
            <td><a href="/posts/${esc(l.slug)}" target="_blank" class="content-title" style="font-size:0.8rem;">${esc(l.title)}</a></td>
            <td><span style="font-size:0.72rem;color:#6b7684;">${esc(l.project)}</span></td>
            <td style="font-family:'JetBrains Mono',monospace;font-size:0.72rem;">${l.date}</td>
            <td><span style="font-size:0.65rem;font-weight:600;color:#8b95a1;">${l.lang.toUpperCase()}</span></td>
            <td>${badges}</td>
            <td>
              <button class="bl-action-btn" onclick="publishDevto('${esc(l.slug)}', this)">DEV.to</button>
              <button class="bl-action-btn" onclick="copyMarkdown('${esc(l.slug)}', this)">MD Copy</button>
            </td>
          </tr>`;
        });

        html += '</tbody></table>';
        wrap.innerHTML = html;
      }

      window.publishDevto = async function(slug, btn) {
        if (!confirm(`${slug}을 DEV.to에 발행할까?`)) return;
        btn.disabled = true;
        btn.textContent = '...';
        try {
          const res = await fetch('/api/admin-build-logs', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ secret: currentSecret, action: 'publish-devto', slug }),
          });
          const data = await res.json();
          if (data.ok) {
            alert(data.message);
            btn.textContent = 'Done';
          } else {
            alert('Error: ' + (data.error || 'Failed'));
            btn.textContent = 'DEV.to';
            btn.disabled = false;
          }
        } catch (e) {
          alert('Error: ' + e);
          btn.textContent = 'DEV.to';
          btn.disabled = false;
        }
      };

      window.copyMarkdown = async function(slug, btn) {
        btn.disabled = true;
        btn.textContent = '...';
        try {
          const res = await fetch('/api/admin-build-logs', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ secret: currentSecret, action: 'get-markdown', slug }),
          });
          const data = await res.json();
          if (data.ok) {
            await navigator.clipboard.writeText(`# ${data.title}\n\n${data.markdown}`);
            btn.textContent = 'Copied!';
            setTimeout(() => { btn.textContent = 'MD Copy'; btn.disabled = false; }, 2000);
          } else {
            alert('Error: ' + (data.error || 'Failed'));
            btn.textContent = 'MD Copy';
            btn.disabled = false;
          }
        } catch (e) {
          alert('Error: ' + e);
          btn.textContent = 'MD Copy';
          btn.disabled = false;
        }
      };

      function esc(str) {
        const d = document.createElement('div');
        d.textContent = str || '';
        return d.innerHTML;
      }
    </script>
  </body>
</html>
