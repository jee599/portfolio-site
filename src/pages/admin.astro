---
export const prerender = false;
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Admin Dashboard | Jidong Lab</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style is:inline>
      @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+KR:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');

      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: 'IBM Plex Sans KR', sans-serif;
        background: #f9fafb;
        color: #333d4b;
        min-height: 100vh;
      }

      /* Header */
      .admin-header {
        background: #191f28;
        color: #fff;
        padding: 1rem 2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .admin-header h1 { font-size: 1rem; font-weight: 600; letter-spacing: -0.02em; }
      .admin-header-right { display: flex; align-items: center; gap: 1rem; }
      .admin-header a { color: #8b95a1; text-decoration: none; font-size: 0.8rem; }
      .admin-header a:hover { color: #00c471; }
      .logout-btn {
        background: none; border: 1px solid #4e5968; color: #8b95a1;
        padding: 0.25rem 0.6rem; border-radius: 6px; font-size: 0.7rem;
        cursor: pointer; font-family: inherit; display: none;
      }
      .logout-btn:hover { border-color: #e45649; color: #e45649; }

      /* Tabs */
      .tab-nav {
        background: #fff; border-bottom: 1px solid #f2f4f6;
        padding: 0 2rem; display: none; gap: 0;
      }
      .tab-nav.active { display: flex; }
      .tab-btn {
        padding: 0.75rem 1.25rem; border: none; background: none;
        color: #8b95a1; font-size: 0.82rem; font-weight: 500;
        cursor: pointer; border-bottom: 2px solid transparent;
        font-family: inherit; transition: 0.15s ease;
      }
      .tab-btn:hover { color: #333d4b; }
      .tab-btn.active { color: #00c471; border-bottom-color: #00c471; font-weight: 600; }

      /* Auth */
      .auth-wall { max-width: 340px; margin: 8rem auto; text-align: center; }
      .auth-wall h2 { font-size: 1.2rem; margin-bottom: 1.5rem; color: #191f28; }
      .auth-input {
        width: 100%; padding: 0.7rem 1rem; border: 1px solid #e5e8eb;
        border-radius: 8px; font-size: 0.85rem; font-family: 'JetBrains Mono', monospace;
        outline: none; margin-bottom: 0.75rem;
      }
      .auth-input:focus { border-color: #00c471; }
      .auth-btn {
        width: 100%; padding: 0.7rem; background: #00c471; color: #fff;
        border: none; border-radius: 8px; font-size: 0.85rem; font-weight: 600;
        cursor: pointer; font-family: inherit;
      }
      .auth-btn:hover { background: #00a85e; }
      .auth-error { color: #e45649; font-size: 0.8rem; margin-top: 0.5rem; display: none; }

      /* Dashboard */
      .dashboard { display: none; max-width: 1100px; margin: 0 auto; padding: 1.5rem 2rem; }
      .dashboard.active { display: block; }
      .tab-panel { display: none; }
      .tab-panel.active { display: block; }

      /* Stats Grid */
      .stats-grid {
        display: grid; grid-template-columns: repeat(6, 1fr);
        gap: 0.75rem; margin-bottom: 1.5rem;
      }
      .stat-card {
        background: #fff; border: 1px solid #f2f4f6; border-radius: 10px; padding: 1rem;
      }
      .stat-card .label {
        font-size: 0.65rem; color: #8b95a1; text-transform: uppercase;
        letter-spacing: 0.05em; margin-bottom: 0.35rem;
      }
      .stat-card .value {
        font-size: 1.35rem; font-weight: 700; color: #191f28;
        font-family: 'JetBrains Mono', monospace;
      }
      .stat-card .sub { font-size: 0.7rem; color: #8b95a1; margin-top: 0.15rem; }

      /* Section */
      .section {
        background: #fff; border: 1px solid #f2f4f6;
        border-radius: 10px; padding: 1.25rem; margin-bottom: 1.25rem;
      }
      .section-title {
        font-size: 0.85rem; font-weight: 600; color: #191f28;
        margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem;
      }
      .section-subtitle {
        font-size: 0.7rem; color: #8b95a1; font-weight: 400;
      }

      /* ═══ Calendar Heatmap ═══ */
      .heatmap-wrap { overflow-x: auto; }
      .heatmap {
        display: flex; gap: 3px; padding: 0.25rem 0;
      }
      .heatmap-week {
        display: flex; flex-direction: column; gap: 3px;
      }
      .heatmap-cell {
        width: 14px; height: 14px; border-radius: 3px;
        background: #f2f4f6; cursor: pointer; position: relative;
        overflow: visible; font-size: 0; line-height: 0;
      }
      .heatmap-cell.l1 { background: #c6efdb; }
      .heatmap-cell.l2 { background: #6ee7a8; }
      .heatmap-cell.l3 { background: #00c471; }
      .heatmap-cell.l4 { background: #008c50; }
      .heatmap-cell:hover { outline: 2px solid #333d4b; outline-offset: -1px; }
      .heatmap-cell .tip {
        display: none; position: absolute; bottom: calc(100% + 6px); left: 50%;
        transform: translateX(-50%); background: #191f28; color: #fff;
        padding: 0.25rem 0.5rem; border-radius: 5px; font-size: 0.65rem;
        white-space: nowrap; font-family: 'JetBrains Mono', monospace; z-index: 10;
        pointer-events: none;
      }
      .heatmap-cell .tip::after {
        content: ''; position: absolute; top: 100%; left: 50%;
        transform: translateX(-50%); border: 4px solid transparent;
        border-top-color: #191f28;
      }
      .heatmap-cell:hover .tip { display: block; }
      .heatmap-labels {
        display: flex; gap: 3px; margin-bottom: 2px;
      }
      .heatmap-month {
        font-size: 0.6rem; color: #8b95a1; font-family: 'JetBrains Mono', monospace;
      }
      .heatmap-legend {
        display: flex; align-items: center; gap: 4px;
        margin-top: 0.5rem; justify-content: flex-end;
      }
      .heatmap-legend span { font-size: 0.6rem; color: #8b95a1; }
      .heatmap-legend-cell {
        width: 12px; height: 12px; border-radius: 2px;
      }
      .heatmap-day-labels {
        display: flex; flex-direction: column; gap: 3px;
        margin-right: 4px; padding-top: 0;
      }
      .heatmap-day-label {
        height: 14px; font-size: 0.55rem; color: #8b95a1;
        font-family: 'JetBrains Mono', monospace;
        display: flex; align-items: center;
      }

      /* ═══ Content Cards ═══ */
      .filter-bar {
        display: flex; gap: 0.4rem; flex-wrap: wrap; margin-bottom: 1rem;
      }
      .filter-btn {
        padding: 0.3rem 0.7rem; border: 1px solid #e5e8eb; border-radius: 100px;
        background: #fff; color: #6b7684; font-size: 0.72rem; font-weight: 500;
        cursor: pointer; font-family: inherit;
      }
      .filter-btn:hover { border-color: #00c471; color: #00c471; }
      .filter-btn.active { border-color: #00c471; color: #00c471; background: #e6f9f0; font-weight: 600; }

      .content-list { display: flex; flex-direction: column; gap: 0; }
      .content-item {
        display: grid; grid-template-columns: 1fr auto;
        align-items: center; gap: 1rem;
        padding: 0.75rem 0; border-bottom: 1px solid #f2f4f6;
      }
      .content-item:last-child { border-bottom: none; }
      .content-left { min-width: 0; }
      .content-title-row {
        display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.2rem;
      }
      .content-title {
        font-size: 0.85rem; font-weight: 500; color: #191f28;
        text-decoration: none; white-space: nowrap; overflow: hidden;
        text-overflow: ellipsis;
      }
      .content-title:hover { color: #00c471; }
      .content-date { font-size: 0.7rem; color: #b0b8c1; font-family: 'JetBrains Mono', monospace; }

      .type-badge {
        display: inline-block; padding: 0.1rem 0.4rem; border-radius: 100px;
        font-size: 0.6rem; font-weight: 600; text-transform: uppercase; flex-shrink: 0;
      }
      .type-badge.build-log { background: #e6f9f0; color: #00a85e; }
      .type-badge.tip { background: #fef3cd; color: #d97706; }
      .type-badge.ai-news { background: #e6f9f0; color: #00c471; }
      .type-badge.blog { background: #dbeafe; color: #3b82f6; }

      .content-stats {
        display: flex; gap: 1rem; flex-shrink: 0;
      }
      .content-stat {
        display: flex; align-items: center; gap: 0.3rem;
        font-size: 0.75rem; color: #8b95a1;
        font-family: 'JetBrains Mono', monospace;
      }
      .content-stat svg { width: 13px; height: 13px; }
      .content-stat.has-data { color: #333d4b; font-weight: 500; }

      /* ═══ Quick Actions ═══ */
      .actions-grid {
        display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 0.75rem;
      }
      .action-card {
        background: #fff; border: 1px solid #f2f4f6; border-radius: 10px;
        padding: 1.25rem; display: flex; flex-direction: column; gap: 0.5rem;
      }
      .action-card h3 { font-size: 0.9rem; font-weight: 600; color: #191f28; }
      .action-card p { font-size: 0.75rem; color: #8b95a1; line-height: 1.5; }
      .action-btn {
        padding: 0.5rem 1rem; border: none; border-radius: 8px;
        font-size: 0.8rem; font-weight: 600; cursor: pointer;
        font-family: inherit; transition: 0.15s ease; width: fit-content;
      }
      .action-btn.primary { background: #00c471; color: #fff; }
      .action-btn.primary:hover { background: #00a85e; }
      .action-btn.secondary { background: #f2f4f6; color: #333d4b; }
      .action-btn.secondary:hover { background: #e5e8eb; }
      .action-btn:disabled { opacity: 0.5; cursor: not-allowed; }

      .action-status {
        font-size: 0.72rem; padding: 0.35rem 0.6rem; border-radius: 6px; display: none;
      }
      .action-status.success { display: block; background: #e6f9f0; color: #00a85e; }
      .action-status.error { display: block; background: #fef2f2; color: #e45649; }
      .action-status.loading { display: block; background: #f0f9ff; color: #3b82f6; }

      /* ═══ Comments ═══ */
      .comment-card {
        border: 1px solid #f2f4f6; border-radius: 8px;
        padding: 0.75rem 1rem; margin-bottom: 0.5rem;
      }
      .comment-card:last-child { margin-bottom: 0; }
      .comment-header {
        display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.35rem;
      }
      .comment-meta { display: flex; align-items: center; gap: 0.5rem; font-size: 0.75rem; }
      .comment-name { font-weight: 600; color: #191f28; }
      .comment-date { color: #8b95a1; font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; }
      .comment-slug {
        color: #8b95a1; font-size: 0.65rem; font-family: 'JetBrains Mono', monospace;
        background: #f2f4f6; padding: 0.05rem 0.35rem; border-radius: 3px;
      }
      .comment-text { font-size: 0.8rem; color: #333d4b; line-height: 1.5; }
      .delete-btn {
        background: none; border: 1px solid #e5e8eb; color: #8b95a1;
        padding: 0.15rem 0.4rem; border-radius: 4px; font-size: 0.65rem;
        cursor: pointer; font-family: inherit;
      }
      .delete-btn:hover { border-color: #e45649; color: #e45649; }

      .empty-state { text-align: center; padding: 2.5rem; color: #8b95a1; font-size: 0.8rem; }
      .loading { text-align: center; padding: 3rem; color: #8b95a1; font-size: 0.85rem; }

      /* ═══ Top Engagement ═══ */
      .top-list { display: flex; flex-direction: column; gap: 0; }
      .top-item {
        display: flex; align-items: center; gap: 0.75rem;
        padding: 0.5rem 0; border-bottom: 1px solid #f2f4f6; font-size: 0.8rem;
      }
      .top-item:last-child { border-bottom: none; }
      .top-rank {
        font-family: 'JetBrains Mono', monospace; font-size: 0.7rem;
        color: #8b95a1; width: 1.5rem; text-align: center; flex-shrink: 0;
      }
      .top-title {
        flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
        color: #333d4b;
      }
      .top-stats {
        display: flex; gap: 0.75rem; flex-shrink: 0;
        font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: #8b95a1;
      }
      .top-stat-highlight { color: #00c471; font-weight: 500; }

      /* Two-column layout */
      .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }

      /* ═══ Platforms Grid ═══ */
      .platforms-grid {
        display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.75rem;
      }
      .platform-card {
        display: flex; align-items: center; gap: 0.75rem;
        padding: 0.85rem 1rem; border: 1px solid #f2f4f6; border-radius: 10px;
        text-decoration: none; transition: all 0.2s; background: #fff;
      }
      .platform-card:hover {
        border-color: #00c471; box-shadow: 0 2px 12px rgba(0,196,113,0.08);
        transform: translateY(-1px);
      }
      .platform-icon {
        width: 36px; height: 36px; border-radius: 8px;
        display: flex; align-items: center; justify-content: center; flex-shrink: 0;
      }
      .platform-info {
        display: flex; flex-direction: column; gap: 0.1rem; min-width: 0; flex: 1;
      }
      .platform-name {
        font-size: 0.85rem; font-weight: 600; color: #191f28;
      }
      .platform-url {
        font-size: 0.68rem; color: #8b95a1; font-family: 'JetBrains Mono', monospace;
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
      }
      .platform-stats-row {
        display: flex; flex-direction: column; align-items: flex-end; gap: 0.2rem; flex-shrink: 0;
      }
      .platform-lang {
        font-size: 0.6rem; font-weight: 600; color: #8b95a1;
        background: #f2f4f6; padding: 0.15rem 0.45rem; border-radius: 100px;
        font-family: 'JetBrains Mono', monospace;
      }
      .platform-views {
        font-size: 0.75rem; font-weight: 700; color: #00c471;
        font-family: 'JetBrains Mono', monospace;
      }

      /* ═══ Projects Table ═══ */
      .project-table { width: 100%; border-collapse: collapse; font-size: 0.8rem; }
      .project-table th {
        text-align: left; padding: 0.5rem 0.75rem; border-bottom: 2px solid #f2f4f6;
        font-size: 0.7rem; color: #8b95a1; text-transform: uppercase; letter-spacing: 0.05em;
      }
      .project-table td { padding: 0.6rem 0.75rem; border-bottom: 1px solid #f2f4f6; vertical-align: middle; }
      .project-table tr:hover td { background: #f9fafb; }
      .status-badge {
        display: inline-block; padding: 0.1rem 0.45rem; border-radius: 100px;
        font-size: 0.65rem; font-weight: 600;
      }
      .status-badge.live { background: #e6f9f0; color: #00a85e; }
      .status-badge.dev { background: #dbeafe; color: #3b82f6; }
      .status-badge.beta { background: #fef3cd; color: #d97706; }
      .status-badge.stopped { background: #fef2f2; color: #e45649; }
      .visible-toggle {
        width: 36px; height: 20px; border-radius: 10px; border: none;
        cursor: pointer; position: relative; transition: 0.2s;
      }
      .visible-toggle.on { background: #00c471; }
      .visible-toggle.off { background: #e5e8eb; }
      .visible-toggle::after {
        content: ''; position: absolute; width: 16px; height: 16px;
        border-radius: 50%; background: #fff; top: 2px; transition: 0.2s;
      }
      .visible-toggle.on::after { left: 18px; }
      .visible-toggle.off::after { left: 2px; }
      .stack-tags { display: flex; flex-wrap: wrap; gap: 0.2rem; }
      .stack-tag {
        font-size: 0.6rem; font-family: 'JetBrains Mono', monospace;
        padding: 0.1rem 0.35rem; border-radius: 3px; background: #f2f4f6; color: #6b7684;
      }
      .cli-copy-btn {
        padding: 0.25rem 0.5rem; border: 1px solid #e5e8eb; border-radius: 5px;
        background: #fff; color: #333d4b; font-size: 0.7rem; cursor: pointer;
        font-family: 'JetBrains Mono', monospace;
      }
      .cli-copy-btn:hover { border-color: #00c471; color: #00c471; }
      .cli-copy-btn.copied { border-color: #00c471; color: #00c471; background: #e6f9f0; }
      .commit-mini { font-size: 0.7rem; color: #6b7684; font-family: 'JetBrains Mono', monospace; }
      .commit-mini .sha { color: #00c471; }

      /* ═══ Build Logs Table ═══ */
      .bl-filter-bar { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-bottom: 1rem; }
      .published-badge {
        display: inline-block; padding: 0.05rem 0.35rem; border-radius: 100px;
        font-size: 0.58rem; font-weight: 600; margin-right: 0.2rem;
      }
      .published-badge.devto { background: #0a0a0a; color: #fff; }
      .published-badge.naver { background: #03c75a; color: #fff; }
      .published-badge.tistory { background: #eb5d0b; color: #fff; }
      .bl-action-btn {
        padding: 0.2rem 0.5rem; border: 1px solid #e5e8eb; border-radius: 5px;
        background: #fff; color: #333d4b; font-size: 0.68rem; cursor: pointer;
        font-family: inherit; margin-right: 0.3rem;
      }
      .bl-action-btn:hover { border-color: #00c471; color: #00c471; }
      .bl-action-btn:disabled { opacity: 0.4; cursor: not-allowed; }

      /* Responsive */
      @media (max-width: 768px) {
        .dashboard { padding: 1rem; }
        .stats-grid { grid-template-columns: repeat(3, 1fr); }
        .tab-nav { padding: 0 1rem; overflow-x: auto; }
        .tab-btn { white-space: nowrap; padding: 0.65rem 0.75rem; font-size: 0.78rem; }
        .admin-header { padding: 0.75rem 1rem; }
        .actions-grid { grid-template-columns: 1fr; }
        .platforms-grid { grid-template-columns: 1fr; }
        .two-col { grid-template-columns: 1fr; }
        .content-stats { gap: 0.6rem; }
        .hide-mobile { display: none; }
        .heatmap-cell { width: 11px; height: 11px; }
      }
    </style>
  </head>
  <body>
    <header class="admin-header">
      <h1>Admin Dashboard</h1>
      <div class="admin-header-right">
        <a href="/">← Back to Site</a>
        <button class="logout-btn" id="logout-btn">Logout</button>
      </div>
    </header>

    <nav class="tab-nav" id="tab-nav">
      <button class="tab-btn active" data-tab="overview">Overview</button>
      <button class="tab-btn" data-tab="projects">Projects</button>
      <button class="tab-btn" data-tab="build-logs">Build Logs</button>
      <button class="tab-btn" data-tab="actions">Quick Actions</button>
      <button class="tab-btn" data-tab="content">Content</button>
      <button class="tab-btn" data-tab="comments">Comments</button>
    </nav>

    <!-- Auth Wall -->
    <div class="auth-wall" id="auth-wall">
      <h2>Admin Access</h2>
      <input type="password" class="auth-input" id="secret-input" placeholder="Enter admin secret" autocomplete="off" />
      <button class="auth-btn" id="auth-btn">Enter</button>
      <p class="auth-error" id="auth-error">Invalid secret key</p>
    </div>

    <!-- Dashboard -->
    <div class="dashboard" id="dashboard">
      <div class="loading" id="loading">Loading dashboard...</div>

      <!-- ═══ Overview ═══ -->
      <div class="tab-panel active" id="panel-overview">
        <div class="stats-grid" id="stats-grid" style="display:none;">
          <div class="stat-card">
            <div class="label">Today</div>
            <div class="value" id="stat-today">-</div>
            <div class="sub">visitors</div>
          </div>
          <div class="stat-card">
            <div class="label">Total</div>
            <div class="value" id="stat-total">-</div>
            <div class="sub">visitors</div>
          </div>
          <div class="stat-card">
            <div class="label">Views</div>
            <div class="value" id="stat-views">-</div>
            <div class="sub">page views</div>
          </div>
          <div class="stat-card">
            <div class="label">Likes</div>
            <div class="value" id="stat-likes">-</div>
          </div>
          <div class="stat-card">
            <div class="label">Comments</div>
            <div class="value" id="stat-comments">-</div>
          </div>
          <div class="stat-card">
            <div class="label">Posts</div>
            <div class="value" id="stat-posts">-</div>
            <div class="sub" id="stat-posts-sub"></div>
          </div>
        </div>

        <!-- Platforms -->
        <div class="section" id="platforms-overview" style="display:none;">
          <div class="section-title">Publishing Platforms</div>
          <div class="platforms-grid">
            <a href="https://dev.to/ji_ai" target="_blank" class="platform-card">
              <div class="platform-icon" style="background:#0a0a0a;">
