---
import Hero from '../components/home/Hero';
import Projects from '../components/home/Projects';
import TechBlock from '../components/home/TechBlock';
import Lab from '../components/home/Lab';
import Topbar from '../components/home/Topbar.astro';
import NowStrip from '../components/home/NowStrip.astro';
import ShipLog from '../components/home/ShipLog.astro';
import Writing from '../components/home/Writing.astro';
import About from '../components/home/About.astro';
import Wordmark from '../components/home/Wordmark.astro';
import Footer from '../components/home/Footer.astro';
import '../styles/home.css';

const title = 'jidonglab — AI 빌더의 작업실';
const description = '서울에서 혼자 AI 에이전트 인프라 도구를 만드는 사람의 홈. 작업, 실험, 기록, 소개.';
const siteUrl = 'https://jidonglab.com';
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={siteUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:site_name" content="jidonglab" />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:image" content={`${siteUrl}/og/default-og.svg`} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@jidonglab" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="jidonglab" href="/rss.xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: 'jidonglab',
        url: siteUrl,
        description,
        author: { '@type': 'Person', name: 'jidonglab', url: siteUrl },
        inLanguage: ['ko-KR', 'en-US'],
      })}
    />
  </head>
  <body>
    <Topbar />
    <Hero client:load />
    <NowStrip />
    <Projects client:visible />
    <TechBlock client:visible />
    <Lab client:visible />
    <ShipLog />
    <Writing />
    <About />
    <Wordmark />
    <Footer />

    <script is:inline>
      // Footer 시계 (Asia/Seoul)
      (function () {
        var nodes = document.querySelectorAll('[data-home-clock]');
        if (!nodes.length) return;
        function tick() {
          var now = new Date(new Date().toLocaleString('en-US', { timeZone: 'Asia/Seoul' }));
          var hh = String(now.getHours()).padStart(2, '0');
          var mm = String(now.getMinutes()).padStart(2, '0');
          var txt = hh + ':' + mm;
          nodes.forEach(function (n) { n.textContent = txt; });
        }
        tick();
        setInterval(tick, 30000);
      })();

      // 방문 추적 (세션 1회)
      if (!sessionStorage.getItem('v_tracked')) {
        fetch('/api/visitors', { method: 'POST' }).catch(function () {});
        sessionStorage.setItem('v_tracked', '1');
      }

      // 통합 admin 트래킹
      fetch('https://admin.jidonglab.com/api/track', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ project: 'jidonglab', path: location.pathname, referrer: document.referrer }),
        keepalive: true,
      }).catch(function () {});
    </script>
    <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "CF_ANALYTICS_TOKEN"}'></script>
  </body>
</html>
