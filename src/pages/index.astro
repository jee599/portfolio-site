---
import Base from '../layouts/Base.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { fetchArticles } from '../lib/devto';

const buildLogs = (await getCollection('build-logs'))
  .filter((p) => p.data.lang === 'ko')
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const tips = (await getCollection('tips'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const aiNews = (await getCollection('ai-news'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const devtoArticles = await fetchArticles();

type PostItem = {
  title: string;
  href: string;
  date: string;
  type: 'build-log' | 'tip' | 'blog' | 'ai-news';
  project?: string;
  description?: string;
  model?: string;
};

const allPosts: PostItem[] = [
  ...buildLogs.map((p) => ({
    title: p.data.title,
    href: `/posts/${p.slug}`,
    date: p.data.date.toISOString().split('T')[0],
    type: 'build-log' as const,
    project: p.data.project,
  })),
  ...tips.map((p) => ({
    title: p.data.title,
    href: `/posts/${p.slug}`,
    date: p.data.date.toISOString().split('T')[0],
    type: 'tip' as const,
  })),
  ...aiNews.map((p) => ({
    title: p.data.title,
    href: `/ai-news/${p.slug}`,
    date: p.data.date.toISOString().split('T')[0],
    type: 'ai-news' as const,
    description: p.data.summary,
    model: p.data.model,
  })),
  ...devtoArticles.map((a) => ({
    title: a.title,
    href: `/blog/${a.slug}`,
    date: a.published_at.split('T')[0],
    type: 'blog' as const,
    description: a.description,
  })),
].sort((a, b) => b.date.localeCompare(a.date));

const recentPosts = allPosts.slice(0, 10);
// For "popular" section - just pick tips and build logs as they're original content
const popularPosts = [...buildLogs.slice(0, 2).map(p => ({
  title: p.data.title,
  href: `/posts/${p.slug}`,
})), ...tips.slice(0, 1).map(p => ({
  title: p.data.title,
  href: `/posts/${p.slug}`,
}))];
---

<Base title="Home">
  <div class="fade-in" style="display: flex; gap: 3rem; align-items: flex-start;">
    <!-- Main: 전체 아티클 (올린 순서대로) -->
    <div style="flex: 1; min-width: 0;">
      <h2 class="text-sm font-mono text-muted uppercase tracking-widest mb-6">
        전체 아티클
      </h2>
      <div>
        {recentPosts.map((post) => (
          <PostCard
            title={post.title}
            href={post.href}
            date={post.date}
            type={post.type}
            project={post.project}
            description={post.description}
            model={post.model}
          />
        ))}
      </div>
      {allPosts.length > 10 && (
        <div style="text-align: center; margin-top: 2rem;">
          <a href="/posts" style="font-size: 0.9rem; color: #00c471;">모든 글 보기 &rarr;</a>
        </div>
      )}
    </div>

    <!-- Sidebar: 인기 있는 글 -->
    <aside style="width: 280px; flex-shrink: 0; position: sticky; top: 2rem;" class="hidden lg:block">
      <h2 class="text-sm font-mono text-muted uppercase tracking-widest mb-4">
        인기 있는 글
      </h2>
      <div style="display: flex; flex-direction: column; gap: 0;">
        {popularPosts.map((post, i) => (
          <a href={post.href} style="display: flex; gap: 0.75rem; padding: 0.75rem 0; border-bottom: 1px solid #f2f4f6; text-decoration: none; align-items: flex-start;">
            <span style="font-size: 1.25rem; font-weight: 700; color: #00c471; flex-shrink: 0; width: 1.5rem;">
              {i + 1}
            </span>
            <span style="font-size: 0.9rem; color: #333d4b; line-height: 1.5; font-weight: 500;">
              {post.title}
            </span>
          </a>
        ))}
      </div>

      <div style="margin-top: 2.5rem;">
        <h2 class="text-sm font-mono text-muted uppercase tracking-widest mb-4">
          LLM News
        </h2>
        <div style="display: flex; flex-direction: column; gap: 0.5rem;">
          <a href="/ai-news?model=claude" style="font-size: 0.875rem; color: #333d4b; text-decoration: none; padding: 0.4rem 0;">Claude</a>
          <a href="/ai-news?model=gemini" style="font-size: 0.875rem; color: #333d4b; text-decoration: none; padding: 0.4rem 0;">Gemini</a>
          <a href="/ai-news?model=gpt" style="font-size: 0.875rem; color: #333d4b; text-decoration: none; padding: 0.4rem 0;">GPT</a>
          <a href="/ai-news?model=etc" style="font-size: 0.875rem; color: #333d4b; text-decoration: none; padding: 0.4rem 0;">Others</a>
        </div>
      </div>
    </aside>
  </div>
</Base>
