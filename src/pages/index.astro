---
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { fetchArticles } from '../lib/devto';
import { getAllProjects } from '../lib/projects';

const projects = await getAllProjects();
const buildLogs = (await getCollection('build-logs'))
  .filter((p) => p.data.lang === 'ko')
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const tips = (await getCollection('tips'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const devtoArticles = await fetchArticles();

type PostItem = {
  title: string;
  href: string;
  date: string;
  type: 'build-log' | 'tip' | 'blog' | 'ai-news';
  project?: string;
  description?: string;
};

const allPosts: PostItem[] = [
  ...buildLogs.map((p) => ({
    title: p.data.title,
    href: `/posts/${p.slug}`,
    date: p.data.date.toISOString().split('T')[0],
    type: 'build-log' as const,
    project: p.data.project,
  })),
  ...tips.map((p) => ({
    title: p.data.title,
    href: `/posts/${p.slug}`,
    date: p.data.date.toISOString().split('T')[0],
    type: 'tip' as const,
  })),
  ...devtoArticles.map((a) => ({
    title: a.title,
    href: `/blog/${a.slug}`,
    date: a.published_at.split('T')[0],
    type: 'blog' as const,
    description: a.description,
  })),
].sort((a, b) => b.date.localeCompare(a.date));

const recentPosts = allPosts.slice(0, 10);
---

<Base title="Home">
  <section class="mb-16 fade-in">
    <p class="text-sm font-mono text-accent-dark mb-2" style="color: #6c63ff;">jidonglab</p>
    <h1 class="text-4xl font-display font-bold mb-4" style="color: #e8e8f0;">
      AI를 사용하고, <span style="color: #6c63ff;">연구</span>합니다.
    </h1>
    <p class="text-lg max-w-xl leading-relaxed" style="color: #7a7a9a;">
      LLM 모델을 활용한 프로덕트 개발과 AI 연구 과정을 기록합니다.
      Claude, Gemini, GPT 등 최신 AI 소식도 매일 업데이트합니다.
    </p>
  </section>

  <section class="mb-16 fade-in stagger-1">
    <h2 class="text-sm font-mono uppercase tracking-widest mb-6" style="color: #7a7a9a;">
      Projects
    </h2>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {projects.map((p) => (
          <ProjectCard
            slug={p.slug}
            title={p.title}
            one_liner={p.one_liner}
            status={p.status}
            stack={p.stack}
            url={p.url}
            github={p.github}
          />
        ))}
    </div>
  </section>

  <section class="fade-in stagger-2">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-sm font-mono uppercase tracking-widest" style="color: #7a7a9a;">
        Recent Posts
      </h2>
      <a href="/posts" class="text-xs font-mono" style="color: #6c63ff;">모든 글 &rarr;</a>
    </div>
    <div>
      {recentPosts.map((post) => (
        <PostCard
          title={post.title}
          href={post.href}
          date={post.date}
          type={post.type}
          project={post.project}
          description={post.description}
        />
      ))}
    </div>
  </section>
</Base>
