---
import Base from '../layouts/Base.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { fetchArticles } from '../lib/devto';
import { getAllProjects } from '../lib/projects';

const projects = await getAllProjects();
const allBuildLogs = (await getCollection('build-logs'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const buildLogs = allBuildLogs.filter((p) => p.data.lang === 'ko');
const buildLogsEn = allBuildLogs.filter((p) => p.data.lang === 'en');
const tips = (await getCollection('tips'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const aiNews = (await getCollection('ai-news'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const blogPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Dev.to에서 실시간 fetch하되, 이미 로컬 동기화된 글은 제외
const devtoArticles = await fetchArticles();
const syncedDevtoIds = new Set(blogPosts.filter(p => p.data.devto_id).map(p => p.data.devto_id));
const unsyncedDevto = devtoArticles.filter(a => !syncedDevtoIds.has(a.id));

type PostItem = {
  title: string;
  href: string;
  date: string;
  type: 'build-log' | 'tip' | 'blog' | 'ai-news';
  project?: string;
  description?: string;
  model?: string;
  lang?: string;
};

const allPosts: (PostItem & { lang?: string })[] = [
  ...buildLogs.map((p) => ({
    title: p.data.title,
    href: `/posts/${p.slug}`,
    date: p.data.date.toISOString().split('T')[0],
    type: 'build-log' as const,
    project: p.data.project,
    lang: 'ko',
  })),
  ...buildLogsEn.map((p) => ({
    title: p.data.title,
    href: `/posts/${p.slug}`,
    date: p.data.date.toISOString().split('T')[0],
    type: 'build-log' as const,
    project: p.data.project,
    lang: 'en',
  })),
  ...tips.map((p) => ({
    title: p.data.title,
    href: `/posts/${p.slug}`,
    date: p.data.date.toISOString().split('T')[0],
    type: 'tip' as const,
  })),
  ...aiNews.map((p) => ({
    title: p.data.title,
    href: `/ai-news/${p.slug}`,
    date: p.data.date.toISOString().split('T')[0],
    type: 'ai-news' as const,
    description: p.data.summary,
    model: p.data.model,
  })),
  ...blogPosts.map((p) => ({
    title: p.data.title,
    href: `/blog/${p.slug}`,
    date: p.data.date.toISOString().split('T')[0],
    type: 'blog' as const,
    description: p.data.description,
  })),
  ...unsyncedDevto.map((a) => ({
    title: a.title,
    href: `/blog/${a.slug}`,
    date: a.published_at.split('T')[0],
    type: 'blog' as const,
    description: a.description,
  })),
].sort((a, b) => b.date.localeCompare(a.date));

const featuredPost = allPosts[0];
const recentPosts = allPosts.slice(1, 9);
const popularPosts = [...buildLogs.slice(0, 2).map(p => ({
  title: p.data.title,
  href: `/posts/${p.slug}`,
})), ...tips.slice(0, 1).map(p => ({
  title: p.data.title,
  href: `/posts/${p.slug}`,
}))];

const statusColors: Record<string, string> = {
  '운영중': '#00c471',
  '개발중': '#3b82f6',
  '실험중': '#f59e0b',
  '중단': '#ef4444',
};
---

<Base title="Home">
  <!-- Hero Section -->
  <section class="hero fade-in">
    <div class="hero-badge">
      <span class="hero-dot"></span>
      <span data-ko="AI 연구 & 개발" data-en="AI Research & Development">AI 연구 & 개발</span>
    </div>
    <h1 class="hero-title">
      <span data-ko="AI를 사용하고," data-en="Using AI,">AI를 사용하고,</span><br/>
      <span class="hero-accent" data-ko="연구한다." data-en="Researching.">연구한다.</span>
    </h1>
    <p class="hero-desc" data-ko="LLM 모델을 활용한 프로덕트 개발과 AI 연구 과정을 기록한다. Claude, Gemini, GPT 등 최신 AI 소식도 매일 업데이트한다." data-en="Documenting product development with LLM models and AI research. Daily updates on Claude, Gemini, GPT and more.">
      LLM 모델을 활용한 프로덕트 개발과 AI 연구 과정을 기록한다. Claude, Gemini, GPT 등 최신 AI 소식도 매일 업데이트한다.
    </p>
  </section>

  <!-- Articles + Sidebar -->
  <section class="section fade-in stagger-1">
    <div class="content-layout">
      <!-- Main: Articles -->
      <div class="content-main">
        <div class="section-header">
          <h2 class="section-title" data-ko="전체 아티클" data-en="All Articles">전체 아티클</h2>
          <a href="/posts" class="section-link" data-ko="모든 글 →" data-en="All posts →">모든 글 →</a>
        </div>
        <div class="article-list">
          {recentPosts.map((post) => (
            <div class="lang-item" data-lang={post.lang || 'all'}>
              <PostCard
                title={post.title}
                href={post.href}
                date={post.date}
                type={post.type}
                project={post.project}
                description={post.description}
                model={post.model}
              />
            </div>
          ))}
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="content-sidebar">
        <!-- Popular -->
        <div class="sidebar-section">
          <h3 class="sidebar-title" data-ko="인기 있는 글" data-en="Popular">인기 있는 글</h3>
          <div class="popular-list">
            {popularPosts.map((post, i) => (
              <a href={post.href} class="popular-item">
                <span class="popular-rank">{i + 1}</span>
                <span class="popular-title">{post.title}</span>
              </a>
            ))}
          </div>
        </div>

        <!-- LLM News Links -->
        <div class="sidebar-section">
          <h3 class="sidebar-title">LLM News</h3>
          <div class="news-links">
            <a href="/ai-news?model=claude" class="news-link">
              <span class="news-dot" style="background: #d97757;"></span>
              Claude
            </a>
            <a href="/ai-news?model=gemini" class="news-link">
              <span class="news-dot" style="background: #4285f4;"></span>
              Gemini
            </a>
            <a href="/ai-news?model=gpt" class="news-link">
              <span class="news-dot" style="background: #10a37f;"></span>
              GPT
            </a>
            <a href="/ai-news?model=etc" class="news-link">
              <span class="news-dot" style="background: #8b95a1;"></span>
              Others
            </a>
          </div>
        </div>

        <!-- Visitor Counter -->
        <div class="sidebar-section visitor-counter">
          <h3 class="sidebar-title" data-ko="방문자" data-en="Visitors">방문자</h3>
          <div class="visitor-stats">
            <div class="visitor-stat">
              <span class="visitor-label" data-ko="오늘" data-en="Today">오늘</span>
              <span class="visitor-value" id="visitor-today">-</span>
            </div>
            <div class="visitor-divider"></div>
            <div class="visitor-stat">
              <span class="visitor-label" data-ko="전체" data-en="Total">전체</span>
              <span class="visitor-value" id="visitor-total">-</span>
            </div>
          </div>
        </div>

        <!-- Subscribe hint -->
        <div class="sidebar-cta">
          <p class="cta-text" data-ko="매일 아침 9시, AI 소식이 자동으로 올라온다." data-en="Every morning at 9 AM, AI news is auto-published.">매일 아침 9시, AI 소식이 자동으로 올라온다.</p>
          <a href="/ai-news" class="cta-btn" data-ko="AI News 보기" data-en="View AI News">AI News 보기</a>
        </div>
      </aside>
    </div>
  </section>

  <!-- Featured Article -->
  {featuredPost && (
    <section class="featured fade-in stagger-1">
      <a href={featuredPost.href} class="featured-card">
        <div class="featured-badge">{featuredPost.type === 'ai-news' ? 'AI News' : featuredPost.type === 'build-log' ? 'Build Log' : featuredPost.type === 'tip' ? 'AI Tip' : 'Blog'}</div>
        <h2 class="featured-title">{featuredPost.title}</h2>
        {featuredPost.description && <p class="featured-desc">{featuredPost.description}</p>}
        <div class="featured-meta">
          <time>{featuredPost.date}</time>
          {featuredPost.project && <span>&middot; {featuredPost.project}</span>}
        </div>
      </a>
    </section>
  )}

  <!-- Projects -->
  <section class="section fade-in stagger-2">
    <div class="section-header">
      <h2 class="section-title" data-ko="프로젝트" data-en="Projects">프로젝트</h2>
      <a href="/projects" class="section-link" data-ko="전체 보기 →" data-en="View all →">전체 보기 →</a>
    </div>
    <div class="project-grid">
      {projects.slice(0, 4).map(p => (
        <a href={`/projects/${p.slug}`} class="project-card">
          <div class="project-header">
            <span class="project-name">{p.title}</span>
            <span class="project-status" style={`color: ${statusColors[p.status] || '#8b95a1'}`}>
              {p.status}
            </span>
          </div>
          <p class="project-desc">{p.one_liner}</p>
          <div class="project-stack">
            {p.stack.slice(0, 4).map(tech => (
              <span class="stack-tag">{tech}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </section>
</Base>

<style>
  /* ═══ Hero ═══ */
  .hero {
    padding: 3rem 0 2.5rem;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.85rem;
    background: #e6f9f0;
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 500;
    color: #00a85e;
    margin-bottom: 1.5rem;
  }

  .hero-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #00c471;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .hero-title {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 700;
    color: #191f28;
    line-height: 1.3;
    letter-spacing: -0.03em;
    margin-bottom: 1rem;
  }

  .hero-accent {
    color: #00c471;
  }

  .hero-desc {
    font-size: 0.9rem;
    color: #6b7684;
    line-height: 1.7;
    max-width: 520px;
  }

  /* ═══ Featured ═══ */
  .featured {
    margin-bottom: 3.5rem;
  }

  .featured-card {
    display: block;
    padding: 2rem 2.25rem;
    background: linear-gradient(135deg, #f9fafb 0%, #e6f9f0 100%);
    border: 1px solid #e5e8eb;
    border-radius: 16px;
    text-decoration: none;
    transition: all 0.25s;
  }

  .featured-card:hover {
    border-color: #00c471;
    box-shadow: 0 4px 24px rgba(0, 196, 113, 0.08);
    transform: translateY(-2px);
  }

  .featured-badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    font-family: 'JetBrains Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #00c471;
    background: rgba(0, 196, 113, 0.1);
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
    margin-bottom: 1rem;
  }

  .featured-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: #191f28;
    line-height: 1.4;
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }

  .featured-desc {
    font-size: 0.95rem;
    color: #6b7684;
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .featured-meta {
    font-size: 0.8rem;
    color: #8b95a1;
    display: flex;
    gap: 0.5rem;
  }

  /* ═══ Section ═══ */
  .section {
    margin-bottom: 3.5rem;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid #191f28;
  }

  .section-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: #191f28;
    letter-spacing: -0.01em;
  }

  .section-link {
    font-size: 0.8rem;
    font-weight: 500;
    color: #00c471;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .section-link:hover {
    opacity: 0.7;
  }

  /* ═══ Projects ═══ */
  .project-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .project-card {
    display: block;
    padding: 1.5rem;
    background: #fff;
    border: 1px solid #e5e8eb;
    border-radius: 12px;
    text-decoration: none;
    transition: all 0.2s;
  }

  .project-card:hover {
    border-color: #00c471;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
  }

  .project-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.5rem;
  }

  .project-name {
    font-weight: 600;
    font-size: 0.95rem;
    color: #191f28;
  }

  .project-status {
    font-size: 0.7rem;
    font-family: 'JetBrains Mono', monospace;
    font-weight: 500;
  }

  .project-desc {
    font-size: 0.85rem;
    color: #6b7684;
    line-height: 1.5;
    margin-bottom: 0.75rem;
  }

  .project-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .stack-tag {
    font-size: 0.7rem;
    font-family: 'JetBrains Mono', monospace;
    padding: 0.15rem 0.5rem;
    background: #f2f4f6;
    color: #6b7684;
    border-radius: 4px;
  }

  /* ═══ Content Layout ═══ */
  .content-layout {
    display: flex;
    gap: 3rem;
    align-items: flex-start;
  }

  .content-main {
    flex: 1;
    min-width: 0;
  }

  .content-sidebar {
    width: 280px;
    flex-shrink: 0;
    position: sticky;
    top: 80px;
  }

  /* ═══ Sidebar ═══ */
  .sidebar-section {
    margin-bottom: 2rem;
  }

  .sidebar-title {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #8b95a1;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #f2f4f6;
  }

  .popular-list {
    display: flex;
    flex-direction: column;
  }

  .popular-item {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    padding: 0.65rem 0;
    border-bottom: 1px solid #f9fafb;
    text-decoration: none;
    transition: all 0.15s;
  }

  .popular-item:hover .popular-title {
    color: #00c471;
  }

  .popular-rank {
    font-size: 1.1rem;
    font-weight: 700;
    color: #00c471;
    flex-shrink: 0;
    width: 1.5rem;
    font-family: 'JetBrains Mono', monospace;
  }

  .popular-title {
    font-size: 0.875rem;
    color: #333d4b;
    line-height: 1.5;
    font-weight: 500;
    transition: color 0.15s;
  }

  .news-links {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .news-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.6rem;
    font-size: 0.85rem;
    color: #333d4b;
    text-decoration: none;
    border-radius: 6px;
    transition: all 0.15s;
  }

  .news-link:hover {
    background: #f2f4f6;
    color: #191f28;
  }

  .news-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .sidebar-cta {
    margin-top: 1.5rem;
    padding: 1.25rem;
    background: #f9fafb;
    border-radius: 12px;
    border: 1px solid #f2f4f6;
  }

  .cta-text {
    font-size: 0.825rem;
    color: #6b7684;
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .cta-btn {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 600;
    color: #00c471;
    text-decoration: none;
    padding: 0.4rem 0.85rem;
    border: 1px solid #00c471;
    border-radius: 6px;
    transition: all 0.15s;
  }

  .cta-btn:hover {
    background: #00c471;
    color: #fff;
  }

  /* ═══ Visitor Counter ═══ */
  .visitor-stats {
    display: flex;
    align-items: center;
    gap: 0;
    background: #f9fafb;
    border: 1px solid #f2f4f6;
    border-radius: 10px;
    overflow: hidden;
  }

  .visitor-stat {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0.75rem 0.5rem;
    gap: 0.25rem;
  }

  .visitor-label {
    font-size: 0.7rem;
    color: #8b95a1;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .visitor-value {
    font-size: 1.25rem;
    font-weight: 700;
    color: #191f28;
    font-family: 'JetBrains Mono', monospace;
  }

  .visitor-divider {
    width: 1px;
    height: 2rem;
    background: #e5e8eb;
    flex-shrink: 0;
  }

  /* ═══ Responsive ═══ */
  @media (max-width: 768px) {
    .project-grid {
      grid-template-columns: 1fr;
    }
    .content-layout {
      flex-direction: column;
    }
    .content-sidebar {
      width: 100%;
      position: static;
    }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', async () => {
    const visited = sessionStorage.getItem('visited');
    try {
      const res = visited
        ? await fetch('/api/visitors')
        : await fetch('/api/visitors', { method: 'POST' });
      if (!res.ok) return;
      const data = await res.json();
      if (!visited) sessionStorage.setItem('visited', '1');
      const todayEl = document.getElementById('visitor-today');
      const totalEl = document.getElementById('visitor-total');
      if (todayEl) todayEl.textContent = (data.today || 0).toLocaleString();
      if (totalEl) totalEl.textContent = (data.total || 0).toLocaleString();
    } catch (e) {
      console.error('Visitor counter error:', e);
    }
  });
</script>
