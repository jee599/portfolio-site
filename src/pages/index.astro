---
import Base from '../layouts/Base.astro';
import PostCard from '../components/PostCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import { getAllProjects } from '../lib/projects';

const statusOrder: Record<string, number> = { '운영중': 0, '실험중': 1, '개발중': 2, '중단': 3 };
const projects = (await getAllProjects()).sort((a, b) =>
  (statusOrder[a.status] ?? 9) - (statusOrder[b.status] ?? 9) || a.order - b.order
);
const allBuildLogs = (await getCollection('build-logs'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const buildLogs = allBuildLogs.filter((p) => p.data.lang === 'ko');
const buildLogsEn = allBuildLogs.filter((p) => p.data.lang === 'en');
const tips = (await getCollection('tips'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const aiNews = (await getCollection('ai-news'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const blogPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

type PostItem = {
  title: string;
  href: string;
  date: string;
  type: 'build-log' | 'tip' | 'blog' | 'ai-news';
  project?: string;
  description?: string;
  model?: string;
  lang?: string;
};

const allPosts: (PostItem & { lang?: string })[] = [
  ...tips.map((p) => ({
    title: p.data.title,
    href: `/posts/${p.slug}`,
    date: p.data.date.toISOString().split('T')[0],
    type: 'tip' as const,
  })),
  ...aiNews.map((p) => ({
    title: p.data.title,
    href: `/ai-news/${p.slug}`,
    date: p.data.date.toISOString().split('T')[0],
    type: 'ai-news' as const,
    description: p.data.summary,
    model: p.data.model,
    lang: 'all',
  })),
  ...blogPosts.map((p) => ({
    title: p.data.title,
    href: `/blog/${p.slug}`,
    date: p.data.date.toISOString().split('T')[0],
    type: 'blog' as const,
    description: p.data.description,
  })),
].sort((a, b) => b.date.localeCompare(a.date));

const featuredPost = allPosts[0];
const recentPosts = allPosts.slice(1, 6);
const popularPosts = [...buildLogs.slice(0, 2).map(p => ({
  title: p.data.title,
  href: `/posts/${p.slug}`,
})), ...tips.slice(0, 1).map(p => ({
  title: p.data.title,
  href: `/posts/${p.slug}`,
}))];

const statusColors: Record<string, string> = {
  '운영중': '#00c471',
  '개발중': '#3b82f6',
  '실험중': '#f59e0b',
  '중단': '#ef4444',
};

const statusEn: Record<string, string> = {
  '운영중': 'Live',
  '개발중': 'In Dev',
  '실험중': 'Beta',
  '중단': 'Stopped',
};

const topProjects = projects.slice(0, 5);

// 프로젝트별 빌드 로그 메타 (한 번만 계산)
const logMeta: Record<string, { count: number; latestTitle?: string; latestSlug?: string }> = {};
for (const p of projects) {
  const logs = buildLogs.filter(l => l.data.project === p.slug);
  const latest = logs[0];
  logMeta[p.slug] = {
    count: logs.length,
    latestTitle: latest?.data.title,
    latestSlug: latest?.slug,
  };
}
const latestPosts = allPosts.slice(0, 4);
---

<Base title="Home">
  <!-- Hero -->
  <section class="fade-in" style="padding: 4.5rem 0 3rem; max-width: 1080px; margin: 0 auto;">
    <p style="font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; font-weight: 600; color: #00c471; letter-spacing: 0.04em; margin-bottom: 1rem;"
      data-ko="1인 개발자" data-en="Solo Developer">1인 개발자</p>
    <h1 style="font-size: clamp(2rem, 5vw, 3rem); font-weight: 800; color: #191f28; line-height: 1.2; letter-spacing: -0.03em; margin: 0 0 1rem 0;">
      jidong
    </h1>
    <p style="font-size: 1.05rem; color: #6b7684; line-height: 1.7; max-width: 560px; margin: 0 0 2rem 0;"
      data-ko="AI로 프로덕트를 만들고, 과정을 기록한다."
      data-en="Building products with AI. Documenting the process.">
      AI로 프로덕트를 만들고, 과정을 기록한다.
    </p>
    <div style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
      <a href="/projects"
        style="display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.65rem 1.4rem; background: #191f28; color: #fff; font-size: 0.85rem; font-weight: 600; border-radius: 8px; text-decoration: none; transition: background 0.15s;"
        onmouseover="this.style.background='#333d4b'"
        onmouseout="this.style.background='#191f28'"
        data-ko="프로젝트 보기" data-en="View Projects">
        프로젝트 보기
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
      <a href="/posts"
        style="display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.65rem 1.4rem; background: #f2f4f6; color: #333d4b; font-size: 0.85rem; font-weight: 600; border-radius: 8px; text-decoration: none; transition: background 0.15s;"
        onmouseover="this.style.background='#e5e8eb'"
        onmouseout="this.style.background='#f2f4f6'"
        data-ko="블로그" data-en="Blog">
        블로그
      </a>
    </div>
  </section>

  <!-- Sites I Built -->
  <section class="fade-in stagger-1" style="padding: 0 0 3rem; max-width: 1080px; margin: 0 auto;">
    <h2 style="font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #8b95a1; margin: 0 0 1rem 0;"
      data-ko="만든 것들" data-en="What I Built">만든 것들</h2>
    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem;">
      {projects.filter(p => p.url).map(p => (
        <a href={p.url} target="_blank" rel="noopener"
          style="display:flex;align-items:center;gap:0.75rem;padding:0.85rem 1rem;background:#fff;border:1px solid #e5e8eb;border-radius:10px;text-decoration:none;transition:all 0.2s;"
          onmouseover="this.style.borderColor='#00c471';this.style.boxShadow='0 4px 16px rgba(0,0,0,0.04)';this.style.transform='translateY(-1px)'"
          onmouseout="this.style.borderColor='#e5e8eb';this.style.boxShadow='none';this.style.transform='none'">
          <div style={`width:36px;height:36px;border-radius:8px;background:${p.status === '운영중' ? '#e6f9f0' : '#f2f4f6'};display:flex;align-items:center;justify-content:center;flex-shrink:0;`}>
            <span style={`font-size:1rem;font-weight:800;color:${p.status === '운영중' ? '#00c471' : '#8b95a1'};font-family:'JetBrains Mono',monospace;`}>{p.title.charAt(0).toUpperCase()}</span>
          </div>
          <div style="min-width:0;flex:1;">
            <div style="font-size:0.85rem;font-weight:700;color:#191f28;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{p.title}</div>
            <div style="font-size:0.68rem;color:#8b95a1;font-family:'JetBrains Mono',monospace;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{p.url?.replace('https://','')}</div>
          </div>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#b0b8c1" stroke-width="2" style="flex-shrink:0;"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        </a>
      ))}
    </div>
  </section>

  <!-- GitHub Projects -->
  <section class="fade-in stagger-1" style="padding: 0 0 3rem; max-width: 1080px; margin: 0 auto;">
    <h2 style="font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #8b95a1; margin: 0 0 1rem 0;"
      data-ko="오픈소스 / 개발중" data-en="Open Source / In Development">오픈소스 / 개발중</h2>
    <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.75rem;">
      {projects.filter(p => !p.url && p.github && ['contextzip', 'agentcrow'].includes(p.slug)).map(p => (
        <a href={p.github} target="_blank" rel="noopener"
          style="display:flex;align-items:center;gap:0.6rem;padding:0.7rem 0.85rem;background:#f9fafb;border:1px solid #f2f4f6;border-radius:8px;text-decoration:none;transition:all 0.2s;"
          onmouseover="this.style.borderColor='#e5e8eb';this.style.background='#fff'"
          onmouseout="this.style.borderColor='#f2f4f6';this.style.background='#f9fafb'">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="#8b95a1" style="flex-shrink:0;"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          <div style="min-width:0;">
            <div style="font-size:0.8rem;font-weight:600;color:#333d4b;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{p.title}</div>
            <div style="font-size:0.62rem;color:#8b95a1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{p.one_liner || p.slug}</div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Divider -->
  <div style="max-width: 1080px; margin: 0 auto; height: 1px; background: #f2f4f6;"></div>

  <!-- Latest Posts Section -->
  <section class="fade-in stagger-2" style="padding: 3.5rem 0 4rem; max-width: 1080px; margin: 0 auto;">
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
      <h2 style="font-size: 1.25rem; font-weight: 700; color: #191f28; letter-spacing: -0.02em; margin: 0;"
        data-ko="최근 글" data-en="Latest Posts">최근 글</h2>
      <a href="/posts"
        style="font-size: 0.8rem; font-weight: 500; color: #6b7684; text-decoration: none; transition: color 0.15s;"
        onmouseover="this.style.color='#00c471'"
        onmouseout="this.style.color='#6b7684'"
        data-ko="모든 글 →" data-en="All posts →">모든 글 →</a>
    </div>
    <div>
      {latestPosts.map((post) => (
        <div class="lang-item" data-lang={post.lang || 'all'}>
          <PostCard
            title={post.title}
            href={post.href}
            date={post.date}
            type={post.type}
            project={post.project}
            description={post.description}
            model={post.model}
          />
        </div>
      ))}
    </div>
  </section>
</Base>

<style>
  /* Project grid */
  .project-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .project-grid > :first-child {
    grid-column: 1 / -1;
  }

  @media (max-width: 640px) {
    .project-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Animations */
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .fade-in {
    animation: fadeIn 0.5s ease-out both;
  }

  .stagger-1 { animation-delay: 0.1s; }
  .stagger-2 { animation-delay: 0.2s; }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  @media (max-width: 768px) {
    div[style*="grid-template-columns: repeat(3"] {
      grid-template-columns: 1fr !important;
    }
    div[style*="grid-template-columns: repeat(4"] {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }
</style>
