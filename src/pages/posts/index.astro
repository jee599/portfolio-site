---
import Base from '../../layouts/Base.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';
const buildLogs = (await getCollection('build-logs'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const tips = (await getCollection('tips'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const blogPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

type PostItem = {
  title: string;
  href: string;
  date: string;
  type: 'build-log' | 'tip' | 'blog';
  project?: string;
  description?: string;
  lang?: string;
};

const allPosts: PostItem[] = [
  ...buildLogs.map((p) => ({
    title: p.data.title,
    href: `/posts/${p.slug}`,
    date: p.data.date.toISOString().split('T')[0],
    type: 'build-log' as const,
    project: p.data.project,
    lang: p.data.lang,
  })),
  ...tips.map((p) => ({
    title: p.data.title,
    href: `/posts/${p.slug}`,
    date: p.data.date.toISOString().split('T')[0],
    type: 'tip' as const,
  })),
  ...blogPosts.map((p) => ({
    title: p.data.title,
    href: `/blog/${p.slug}`,
    date: p.data.date.toISOString().split('T')[0],
    type: 'blog' as const,
    description: p.data.description,
  })),
].sort((a, b) => b.date.localeCompare(a.date));

const categories = [
  { key: 'all', label: '전체', color: '#191f28' },
  { key: 'build-log', label: 'Build Log', color: '#00a85e' },
  { key: 'tip', label: 'AI Tip', color: '#d97706' },
  { key: 'blog', label: 'Blog', color: '#3b82f6' },
];
---

<Base title="AI Posts">
  <div class="page-header fade-in">
    <h1 class="page-title" data-ko="AI Posts" data-en="AI Posts">AI Posts</h1>
    <p class="page-desc" data-ko="빌드 로그, AI 팁, 블로그 글을 모아 놓은 곳이다." data-en="Build logs, AI tips, and blog posts all in one place.">빌드 로그, AI 팁, 블로그 글을 모아 놓은 곳이다.</p>
  </div>

  <!-- Category Filter Buttons -->
  <div class="category-filters fade-in stagger-1" id="category-filters">
    {categories.map(cat => (
      <button
        class:list={['cat-btn', { active: cat.key === 'all' }]}
        data-category={cat.key}
        style={`--cat-color: ${cat.color}`}
      >
        <span class="cat-dot" style={`background: ${cat.color}`}></span>
        {cat.label}
        <span class="cat-count">
          {cat.key === 'all' ? allPosts.length : allPosts.filter(p => p.type === cat.key).length}
        </span>
      </button>
    ))}
  </div>

  <div class="post-list fade-in stagger-2" id="post-list">
    {allPosts.map((post) => (
      <div class={`post-item${post.lang ? ' lang-item' : ''}`} data-type={post.type} data-lang={post.lang || 'all'}>
        <PostCard
          title={post.title}
          href={post.href}
          date={post.date}
          type={post.type}
          project={post.project}
          description={post.description}
        />
      </div>
    ))}
  </div>

  {allPosts.length === 0 && (
    <p class="text-muted" data-ko="아직 글이 없다. 작업하고 push하면 빌드 로그가 자동으로 생긴다." data-en="No posts yet. Push code and build logs will appear automatically.">아직 글이 없다. 작업하고 push하면 빌드 로그가 자동으로 생긴다.</p>
  )}
</Base>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const buttons = document.querySelectorAll('.cat-btn');
    const items = document.querySelectorAll('.post-item');

    function filterPosts() {
      const activeBtn = document.querySelector('.cat-btn.active');
      const cat = activeBtn ? activeBtn.dataset.category : 'all';
      const lang = localStorage.getItem('lang') || 'ko';

      items.forEach(item => {
        const matchesCat = cat === 'all' || item.dataset.type === cat;
        const itemLang = item.dataset.lang;
        const matchesLang = !itemLang || itemLang === 'all' || itemLang === lang;
        item.style.display = matchesCat && matchesLang ? '' : 'none';
      });
    }

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        buttons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        filterPosts();
      });
    });

    // Re-filter when language changes
    window.addEventListener('storage', (e) => {
      if (e.key === 'lang') filterPosts();
    });

    // Listen for lang toggle within same page
    const langBtn = document.getElementById('lang-toggle');
    if (langBtn) {
      langBtn.addEventListener('click', () => {
        setTimeout(filterPosts, 0);
      });
    }

    filterPosts();
  });
</script>

<style>
  .page-header {
    padding: 3rem 0 1.5rem;
  }

  .page-title {
    font-size: 2rem;
    font-weight: 700;
    color: #191f28;
    letter-spacing: -0.03em;
    margin-bottom: 0.5rem;
  }

  .page-desc {
    font-size: 0.95rem;
    color: #8b95a1;
  }

  .category-filters {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid #f2f4f6;
  }

  .cat-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 1rem;
    border: 1px solid #e5e8eb;
    border-radius: 100px;
    background: #fff;
    color: #6b7684;
    font-size: 0.8rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    font-family: 'IBM Plex Sans KR', sans-serif;
  }

  .cat-btn:hover {
    border-color: var(--cat-color);
    color: var(--cat-color);
    background: #f9fafb;
  }

  .cat-btn.active {
    border-color: var(--cat-color);
    color: var(--cat-color);
    background: #f9fafb;
    font-weight: 600;
  }

  .cat-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .cat-count {
    font-size: 0.7rem;
    font-family: 'JetBrains Mono', monospace;
    color: #8b95a1;
    background: #f2f4f6;
    padding: 0.1rem 0.4rem;
    border-radius: 100px;
  }

  .cat-btn.active .cat-count {
    background: rgba(0, 196, 113, 0.1);
  }
</style>
