---
import Base from '../../layouts/Base.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const modelFilter = Astro.url.searchParams.get('model');

let aiNews = (await getCollection('ai-news'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

if (modelFilter && ['claude', 'gemini', 'gpt', 'etc'].includes(modelFilter)) {
  aiNews = aiNews.filter(n => n.data.model === modelFilter);
}

const modelLabels: Record<string, string> = {
  claude: 'Claude',
  gemini: 'Gemini',
  gpt: 'GPT',
  etc: 'Others',
};
---

<Base title="AI News">
  <div class="fade-in">
    <h1 class="text-3xl font-display font-bold text-heading mb-4">
      AI News
    </h1>
    <p class="text-muted mb-8" style="font-size: 0.95rem;">
      매일 아침 9시, 주요 LLM 모델 소식을 자동으로 수집하고 포스팅합니다.
    </p>

    <div class="flex gap-2 mb-8 flex-wrap">
      <a
        href="/ai-news"
        class={`text-xs font-mono px-3 py-1.5 rounded-full transition-all ${!modelFilter ? 'bg-accent-light text-accent-dark border border-accent/30' : 'bg-surface text-muted border border-border'}`}
      >
        All
      </a>
      {Object.entries(modelLabels).map(([key, name]) => (
        <a
          href={`/ai-news?model=${key}`}
          class={`text-xs font-mono px-3 py-1.5 rounded-full transition-all ${modelFilter === key ? 'bg-accent-light text-accent-dark border border-accent/30' : 'bg-surface text-muted border border-border'}`}
        >
          {name}
        </a>
      ))}
    </div>
  </div>

  <div class="fade-in stagger-1">
    {aiNews.map((news) => (
      <PostCard
        title={news.data.title}
        href={`/ai-news/${news.slug}`}
        date={news.data.date.toISOString().split('T')[0]}
        type="ai-news"
        model={news.data.model}
        description={news.data.summary}
      />
    ))}
  </div>

  {aiNews.length === 0 && (
    <p class="text-muted fade-in stagger-1">
      {modelFilter ? `${modelLabels[modelFilter] || modelFilter} 관련 소식이 아직 없습니다.` : '아직 AI 뉴스가 없습니다. 매일 아침 9시에 자동으로 생성됩니다.'}
    </p>
  )}
</Base>
