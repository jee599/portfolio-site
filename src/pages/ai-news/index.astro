---
import Base from '../../layouts/Base.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const modelFilter = Astro.url.searchParams.get('model');

let aiNews = (await getCollection('ai-news'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

if (modelFilter && ['claude', 'gemini', 'gpt', 'etc'].includes(modelFilter)) {
  aiNews = aiNews.filter(n => n.data.model === modelFilter);
}

const modelLabels: Record<string, { name: string; color: string }> = {
  claude: { name: 'Claude', color: '#d97757' },
  gemini: { name: 'Gemini', color: '#4285f4' },
  gpt: { name: 'GPT', color: '#10a37f' },
  etc: { name: 'Others', color: '#7a7a9a' },
};
---

<Base title="AI News">
  <div class="fade-in">
    <h1 class="text-3xl font-display font-bold mb-4" style="color: #e8e8f0;">
      AI News
    </h1>
    <p class="mb-8" style="color: #7a7a9a; font-size: 0.95rem;">
      매일 아침 9시, 주요 LLM 모델 소식을 자동으로 수집하고 포스팅합니다.
    </p>

    <div class="flex gap-2 mb-8 flex-wrap">
      <a
        href="/ai-news"
        class="text-xs font-mono px-3 py-1.5 rounded-full transition-all"
        style={`${!modelFilter ? 'background: rgba(108,99,255,0.15); color: #8b83ff; border: 1px solid rgba(108,99,255,0.3);' : 'background: #1a1a2e; color: #7a7a9a; border: 1px solid #2a2a3e;'}`}
      >
        All
      </a>
      {Object.entries(modelLabels).map(([key, { name, color }]) => (
        <a
          href={`/ai-news?model=${key}`}
          class="text-xs font-mono px-3 py-1.5 rounded-full transition-all"
          style={`${modelFilter === key ? `background: ${color}20; color: ${color}; border: 1px solid ${color}50;` : 'background: #1a1a2e; color: #7a7a9a; border: 1px solid #2a2a3e;'}`}
        >
          {name}
        </a>
      ))}
    </div>
  </div>

  <div class="fade-in stagger-1">
    {aiNews.map((news) => (
      <PostCard
        title={news.data.title}
        href={`/ai-news/${news.slug}`}
        date={news.data.date.toISOString().split('T')[0]}
        type="ai-news"
        model={news.data.model}
        description={news.data.summary}
      />
    ))}
  </div>

  {aiNews.length === 0 && (
    <p style="color: #7a7a9a;" class="fade-in stagger-1">
      {modelFilter ? `${modelLabels[modelFilter]?.name || modelFilter} 관련 소식이 아직 없습니다.` : '아직 AI 뉴스가 없습니다. 매일 아침 9시에 자동으로 생성됩니다.'}
    </p>
  )}
</Base>
