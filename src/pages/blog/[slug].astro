---
import Base from '../../layouts/Base.astro';
import { fetchArticles, fetchArticleBySlug } from '../../lib/devto';

export async function getStaticPaths() {
  const articles = await fetchArticles();
  return articles.map((a) => ({
    params: { slug: a.slug },
    props: { articleSlug: a.slug },
  }));
}

const { articleSlug } = Astro.props;
const article = await fetchArticleBySlug(articleSlug);

if (!article) return Astro.redirect('/posts');

const dateStr = article.published_at.split('T')[0];
---

<Base title={article.title} description={article.description}>
  <link rel="canonical" href={article.url} slot="head" />

  <article class="fade-in">
    <header class="mb-10">
      <span class="text-xs font-mono text-blue-500">DEV.to</span>
      <h1 class="text-3xl font-display font-bold text-heading mt-2 mb-4 leading-tight">
        {article.title}
      </h1>
      <div class="flex items-center gap-4 text-sm text-text/60">
        <time datetime={dateStr}>{dateStr}</time>
        <span>{article.reading_time_minutes}분</span>
        <a href={article.url} target="_blank" rel="noopener" class="font-mono text-xs">
          DEV.to에서 보기 →
        </a>
      </div>
      {article.tag_list.length > 0 && (
        <div class="flex gap-2 mt-3">
          {article.tag_list.map((tag) => (
            <span class="text-xs font-mono px-2 py-0.5 rounded bg-accent-light text-accent-dark">
              {tag}
            </span>
          ))}
        </div>
      )}
    </header>

    <div class="prose" set:html={article.body_html} />
  </article>
</Base>
