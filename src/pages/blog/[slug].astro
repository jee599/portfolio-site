---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { fetchArticles, fetchArticleBySlug } from '../../lib/devto';

export async function getStaticPaths() {
  // Local blog collection posts
  const blogPosts = await getCollection('blog');
  const syncedDevtoIds = new Set(
    blogPosts.filter(p => p.data.devto_id).map(p => p.data.devto_id)
  );

  const localPaths = blogPosts.map((p) => ({
    params: { slug: p.slug },
    props: { entry: p, source: 'local' },
  }));

  // Dev.to articles not yet synced locally
  const localSlugs = new Set(blogPosts.map(p => p.slug));
  const devtoArticles = await fetchArticles();
  const devtoPaths = devtoArticles
    .filter(a => !syncedDevtoIds.has(a.id) && !localSlugs.has(a.slug))
    .map((a) => ({
      params: { slug: a.slug },
      props: { entry: null, source: 'devto', articleSlug: a.slug },
    }));

  return [...localPaths, ...devtoPaths];
}

const { entry, source, articleSlug } = Astro.props;

// Normalize data from either source
let title = '';
let description = '';
let dateStr = '';
let tags: string[] = [];
let sourceLabel = 'Blog';
let sourceUrl = '';
let bodyHtml = '';
let ContentComponent: any = null;
let readingTime = 0;
const blogSlug = Astro.url.pathname;

if (source === 'local' && entry) {
  title = entry.data.title;
  description = entry.data.description || '';
  dateStr = entry.data.date.toISOString().split('T')[0];
  tags = entry.data.tags || [];
  sourceLabel = entry.data.source === 'devto' ? 'DEV.to' : 'Blog';
  sourceUrl = entry.data.source_url || '';
  const rendered = await entry.render();
  ContentComponent = rendered.Content;
} else if (source === 'devto') {
  const article = await fetchArticleBySlug(articleSlug);
  if (!article) return Astro.redirect('/posts');
  title = article.title;
  description = article.description;
  dateStr = article.published_at.split('T')[0];
  tags = Array.isArray(article.tag_list) ? article.tag_list : (typeof article.tag_list === "string" ? article.tag_list.split(", ") : []);
  sourceLabel = 'DEV.to';
  sourceUrl = article.url;
  bodyHtml = article.body_html;
  readingTime = article.reading_time_minutes;
}
---

<Base title={title} description={description}>
  <article class="blog-post fade-in">
    <header class="blog-header">
      <span class="blog-source">{sourceLabel}</span>
      <h1 class="blog-title">{title}</h1>
      <div class="blog-meta">
        <time datetime={dateStr}>{dateStr}</time>
        {readingTime > 0 && (
          <>
            <span class="blog-sep">&middot;</span>
            <span>{readingTime}분</span>
          </>
        )}
        {sourceUrl && (
          <>
            <span class="blog-sep">&middot;</span>
            <a href={sourceUrl} target="_blank" rel="noopener" class="blog-external">
              원문 보기 →
            </a>
          </>
        )}
        <span class="blog-sep">&middot;</span>
        <span class="blog-views" id="view-count">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          <span id="view-num">0</span>
        </span>
      </div>
      {tags.length > 0 && (
        <div class="blog-tags">
          {tags.map((tag: string) => (
            <span class="blog-tag">#{tag}</span>
          ))}
        </div>
      )}
    </header>

    <div class="prose">
      {ContentComponent ? <ContentComponent /> : <Fragment set:html={bodyHtml} />}
    </div>

    <!-- Engagement: 추천 -->
    <div class="engagement" id="engagement">
      <button class="like-btn" id="btn-like">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3H14z"/><path d="M7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>
        <span data-ko="추천" data-en="Like">추천</span>
        <span class="like-count" id="like-count">0</span>
      </button>
    </div>

    <!-- Comments: 댓글 -->
    <div class="comments-section" id="comments-section">
      <h3 class="comments-title">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        <span data-ko="댓글" data-en="Comments">댓글</span>
        <span class="comment-count" id="comment-count">0</span>
      </h3>
      <form class="comment-form" id="comment-form">
        <div class="comment-form-row">
          <input type="text" id="comment-name" class="comment-input comment-name-input" placeholder="이름" maxlength="50" required />
        </div>
        <textarea id="comment-text" class="comment-input comment-textarea" placeholder="댓글을 남겨주세요..." maxlength="1000" rows="3" required></textarea>
        <div class="comment-form-actions">
          <span class="comment-char-count" id="char-count">0 / 1000</span>
          <button type="submit" class="comment-submit" id="comment-submit">
            <span data-ko="등록" data-en="Submit">등록</span>
          </button>
        </div>
      </form>
      <div class="comment-list" id="comment-list"></div>
      <p class="comments-empty" id="comments-empty" style="display:none;" data-ko="아직 댓글이 없다. 첫 댓글을 남겨보자." data-en="No comments yet. Be the first!">아직 댓글이 없다. 첫 댓글을 남겨보자.</p>
    </div>

    <footer class="blog-footer">
      <a href="/posts" class="blog-back">&larr; 모든 글 보기</a>
    </footer>
  </article>
</Base>

<style>
  .blog-post {
    max-width: 680px;
    margin: 0 auto;
    padding: 2rem 0 6rem;
  }

  .blog-header {
    margin-bottom: 3.5rem;
  }

  .blog-source {
    font-size: 0.7rem;
    font-weight: 600;
    font-family: 'JetBrains Mono', monospace;
    text-transform: uppercase;
    color: #3b82f6;
    background: #eff6ff;
    padding: 0.15rem 0.45rem;
    border-radius: 3px;
  }

  .blog-title {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 700;
    color: #191f28;
    line-height: 1.35;
    letter-spacing: -0.03em;
    margin: 0.75rem 0 1rem;
    word-break: keep-all;
  }

  .blog-meta {
    font-size: 0.9rem;
    color: #8b95a1;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
  }

  .blog-sep {
    margin: 0 0.4rem;
    color: #d1d6db;
  }

  .blog-external {
    font-size: 0.8rem;
    font-family: 'JetBrains Mono', monospace;
    color: #8b95a1;
    text-decoration: none;
    transition: color 0.15s;
  }

  .blog-external:hover {
    color: #00c471;
  }

  .blog-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 1rem;
  }

  .blog-tag {
    font-size: 0.8rem;
    color: #8b95a1;
    padding: 0.2rem 0.6rem;
    background: #f2f4f6;
    border-radius: 4px;
  }

  .blog-footer {
    margin-top: 5rem;
    padding-top: 2rem;
    border-top: 1px solid #f2f4f6;
  }

  .blog-back {
    font-size: 0.9rem;
    color: #8b95a1;
    text-decoration: none;
    transition: color 0.15s;
  }

  .blog-back:hover {
    color: #00c471;
  }

  .blog-views {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: #8b95a1;
  }

  /* ═══ Engagement ═══ */
  .engagement {
    display: flex;
    justify-content: center;
    margin-top: 3rem;
    padding: 1.5rem;
    background: #f9fafb;
    border-radius: 12px;
    border: 1px solid #f2f4f6;
  }

  .like-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1.5rem;
    border: 1px solid #e5e8eb;
    border-radius: 100px;
    background: #fff;
    color: #8b95a1;
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    -webkit-user-select: none;
    user-select: none;
  }

  .like-btn:hover {
    border-color: #00c471;
    color: #00c471;
    transform: translateY(-1px);
    box-shadow: 0 2px 8px rgba(0, 196, 113, 0.1);
  }

  .like-btn.active {
    background: #e6f9f0;
    border-color: #00c471;
    color: #00a85e;
  }

  .like-btn.active svg {
    fill: #00c471;
  }

  .like-count {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    min-width: 1.5ch;
    text-align: center;
  }

  /* ═══ Comments ═══ */
  .comments-section {
    margin-top: 3rem;
  }

  .comments-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.1rem;
    font-weight: 700;
    color: #191f28;
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid #191f28;
  }

  .comment-count {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    color: #00c471;
    font-weight: 600;
  }

  .comment-form {
    margin-bottom: 2rem;
  }

  .comment-form-row {
    margin-bottom: 0.5rem;
  }

  .comment-input {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid #e5e8eb;
    border-radius: 8px;
    font-size: 0.9rem;
    font-family: inherit;
    color: #333d4b;
    background: #fff;
    transition: border-color 0.15s;
    box-sizing: border-box;
  }

  .comment-input:focus {
    outline: none;
    border-color: #00c471;
    box-shadow: 0 0 0 3px rgba(0, 196, 113, 0.1);
  }

  .comment-input::placeholder {
    color: #b0b8c1;
  }

  .comment-name-input {
    max-width: 240px;
  }

  .comment-textarea {
    resize: vertical;
    min-height: 80px;
    max-height: 300px;
    line-height: 1.6;
  }

  .comment-form-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 0.5rem;
  }

  .comment-char-count {
    font-size: 0.75rem;
    color: #b0b8c1;
    font-family: 'JetBrains Mono', monospace;
  }

  .comment-submit {
    padding: 0.5rem 1.25rem;
    background: #00c471;
    color: #fff;
    border: none;
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
  }

  .comment-submit:hover {
    background: #00a85e;
  }

  .comment-submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .comment-list {
    display: flex;
    flex-direction: column;
  }

  .comments-empty {
    text-align: center;
    color: #b0b8c1;
    font-size: 0.9rem;
    padding: 2rem 0;
  }
</style>

<script is:inline define:vars={{ blogSlug }}>
  const API = '/api/engagement';
  const slug = blogSlug;
  const likedKey = `liked:${slug}`;
  const viewedKey = `viewed:${slug}`;
  const savedName = localStorage.getItem('comment-name') || '';

  const viewEl = document.getElementById('view-num');
  const likeCountEl = document.getElementById('like-count');
  const likeBtnEl = document.getElementById('btn-like');
  const commentCountEl = document.getElementById('comment-count');
  const commentListEl = document.getElementById('comment-list');
  const commentFormEl = document.getElementById('comment-form');
  const commentNameEl = document.getElementById('comment-name');
  const commentTextEl = document.getElementById('comment-text');
  const commentSubmitEl = document.getElementById('comment-submit');
  const charCountEl = document.getElementById('char-count');
  const emptyEl = document.getElementById('comments-empty');

  if (commentNameEl && savedName) commentNameEl.value = savedName;

  if (commentTextEl && charCountEl) {
    commentTextEl.addEventListener('input', () => {
      charCountEl.textContent = `${commentTextEl.value.length} / 1000`;
    });
  }

  async function trackView() {
    if (!sessionStorage.getItem(viewedKey)) {
      try {
        const res = await fetch(API, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ slug, action: 'view' }),
        });
        const data = await res.json();
        if (viewEl && data.views) viewEl.textContent = String(data.views);
        sessionStorage.setItem(viewedKey, '1');
      } catch {}
    }
  }

  async function loadEngagement() {
    try {
      const res = await fetch(`${API}?slug=${encodeURIComponent(slug)}`);
      const data = await res.json();
      if (viewEl) viewEl.textContent = String(data.views || 0);
      if (likeCountEl) likeCountEl.textContent = String(data.likes || 0);
      if (likeBtnEl && localStorage.getItem(likedKey)) likeBtnEl.classList.add('active');
      renderComments(data.comments || []);
    } catch {}
  }

  function renderComments(comments) {
    if (!commentListEl || !commentCountEl || !emptyEl) return;
    commentCountEl.textContent = String(comments.length);
    if (comments.length === 0) {
      commentListEl.innerHTML = '';
      emptyEl.style.display = 'block';
      return;
    }
    emptyEl.style.display = 'none';
    commentListEl.innerHTML = comments.map(c => {
      const d = new Date(c.date);
      const ds = `${d.getFullYear()}.${String(d.getMonth()+1).padStart(2,'0')}.${String(d.getDate()).padStart(2,'0')} ${String(d.getHours()).padStart(2,'0')}:${String(d.getMinutes()).padStart(2,'0')}`;
      const safeName = escapeHtml(c.name);
      const safeText = escapeHtml(c.text).replace(/\n/g, '<br/>');
      return `<div class="comment"><div class="comment-header"><span class="comment-author">${safeName}</span><span class="comment-date">${ds}</span></div><div class="comment-body">${safeText}</div></div>`;
    }).join('');
  }

  function escapeHtml(str) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  if (likeBtnEl) {
    likeBtnEl.addEventListener('click', async () => {
      const isLiked = localStorage.getItem(likedKey);
      const action = isLiked ? 'unlike' : 'like';
      try {
        const res = await fetch(API, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ slug, action }),
        });
        const data = await res.json();
        if (likeCountEl && data.likes !== undefined) likeCountEl.textContent = String(data.likes);
        if (isLiked) { localStorage.removeItem(likedKey); likeBtnEl.classList.remove('active'); }
        else { localStorage.setItem(likedKey, '1'); likeBtnEl.classList.add('active'); }
      } catch {}
    });
  }

  if (commentFormEl) {
    commentFormEl.addEventListener('submit', async (e) => {
      e.preventDefault();
      const name = commentNameEl?.value.trim();
      const text = commentTextEl?.value.trim();
      if (!name || !text) return;
      if (commentSubmitEl) { commentSubmitEl.disabled = true; commentSubmitEl.textContent = '...'; }
      try {
        const res = await fetch(API, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ slug, action: 'comment', name, text }),
        });
        const data = await res.json();
        if (data.success) {
          localStorage.setItem('comment-name', name);
          if (commentTextEl) commentTextEl.value = '';
          if (charCountEl) charCountEl.textContent = '0 / 1000';
          await loadEngagement();
        }
      } catch {}
      if (commentSubmitEl) { commentSubmitEl.disabled = false; commentSubmitEl.textContent = '등록'; }
    });
  }

  trackView();
  loadEngagement();
</script>

<style is:global>
  .comment {
    padding: 1.25rem 0;
    border-bottom: 1px solid #f2f4f6;
  }
  .comment:last-child { border-bottom: none; }
  .comment-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }
  .comment-author {
    font-size: 0.9rem;
    font-weight: 600;
    color: #191f28;
  }
  .comment-date {
    font-size: 0.75rem;
    color: #b0b8c1;
    font-family: 'JetBrains Mono', monospace;
  }
  .comment-body {
    font-size: 0.9rem;
    color: #333d4b;
    line-height: 1.7;
    word-break: keep-all;
  }
</style>
