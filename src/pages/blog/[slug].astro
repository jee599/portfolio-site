---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { fetchArticles, fetchArticleBySlug } from '../../lib/devto';

export async function getStaticPaths() {
  // Local blog collection posts
  const blogPosts = await getCollection('blog');
  const syncedDevtoIds = new Set(
    blogPosts.filter(p => p.data.devto_id).map(p => p.data.devto_id)
  );

  const localPaths = blogPosts.map((p) => ({
    params: { slug: p.slug },
    props: { entry: p, source: 'local' },
  }));

  // Dev.to articles not yet synced locally
  const devtoArticles = await fetchArticles();
  const devtoPaths = devtoArticles
    .filter(a => !syncedDevtoIds.has(a.id))
    .map((a) => ({
      params: { slug: a.slug },
      props: { entry: null, source: 'devto', articleSlug: a.slug },
    }));

  return [...localPaths, ...devtoPaths];
}

const { entry, source, articleSlug } = Astro.props;

// Normalize data from either source
let title = '';
let description = '';
let dateStr = '';
let tags: string[] = [];
let sourceLabel = 'Blog';
let sourceUrl = '';
let bodyHtml = '';
let ContentComponent: any = null;
let readingTime = 0;

if (source === 'local' && entry) {
  title = entry.data.title;
  description = entry.data.description || '';
  dateStr = entry.data.date.toISOString().split('T')[0];
  tags = entry.data.tags || [];
  sourceLabel = entry.data.source === 'devto' ? 'DEV.to' : 'Blog';
  sourceUrl = entry.data.source_url || '';
  const rendered = await entry.render();
  ContentComponent = rendered.Content;
} else if (source === 'devto') {
  const article = await fetchArticleBySlug(articleSlug);
  if (!article) return Astro.redirect('/posts');
  title = article.title;
  description = article.description;
  dateStr = article.published_at.split('T')[0];
  tags = article.tag_list || [];
  sourceLabel = 'DEV.to';
  sourceUrl = article.url;
  bodyHtml = article.body_html;
  readingTime = article.reading_time_minutes;
}
---

<Base title={title} description={description}>
  <article class="blog-post fade-in">
    <header class="blog-header">
      <span class="blog-source">{sourceLabel}</span>
      <h1 class="blog-title">{title}</h1>
      <div class="blog-meta">
        <time datetime={dateStr}>{dateStr}</time>
        {readingTime > 0 && (
          <>
            <span class="blog-sep">&middot;</span>
            <span>{readingTime}분</span>
          </>
        )}
        {sourceUrl && (
          <>
            <span class="blog-sep">&middot;</span>
            <a href={sourceUrl} target="_blank" rel="noopener" class="blog-external">
              원문 보기 →
            </a>
          </>
        )}
      </div>
      {tags.length > 0 && (
        <div class="blog-tags">
          {tags.map((tag: string) => (
            <span class="blog-tag">#{tag}</span>
          ))}
        </div>
      )}
    </header>

    <div class="prose">
      {ContentComponent ? <ContentComponent /> : <Fragment set:html={bodyHtml} />}
    </div>

    <footer class="blog-footer">
      <a href="/posts" class="blog-back">&larr; 모든 글 보기</a>
    </footer>
  </article>
</Base>

<style>
  .blog-post {
    max-width: 680px;
    margin: 0 auto;
    padding: 2rem 0 6rem;
  }

  .blog-header {
    margin-bottom: 3.5rem;
  }

  .blog-source {
    font-size: 0.7rem;
    font-weight: 600;
    font-family: 'JetBrains Mono', monospace;
    text-transform: uppercase;
    color: #3b82f6;
    background: #eff6ff;
    padding: 0.15rem 0.45rem;
    border-radius: 3px;
  }

  .blog-title {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 700;
    color: #191f28;
    line-height: 1.35;
    letter-spacing: -0.03em;
    margin: 0.75rem 0 1rem;
    word-break: keep-all;
  }

  .blog-meta {
    font-size: 0.9rem;
    color: #8b95a1;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
  }

  .blog-sep {
    margin: 0 0.4rem;
    color: #d1d6db;
  }

  .blog-external {
    font-size: 0.8rem;
    font-family: 'JetBrains Mono', monospace;
    color: #8b95a1;
    text-decoration: none;
    transition: color 0.15s;
  }

  .blog-external:hover {
    color: #00c471;
  }

  .blog-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 1rem;
  }

  .blog-tag {
    font-size: 0.8rem;
    color: #8b95a1;
    padding: 0.2rem 0.6rem;
    background: #f2f4f6;
    border-radius: 4px;
  }

  .blog-footer {
    margin-top: 5rem;
    padding-top: 2rem;
    border-top: 1px solid #f2f4f6;
  }

  .blog-back {
    font-size: 0.9rem;
    color: #8b95a1;
    text-decoration: none;
    transition: color 0.15s;
  }

  .blog-back:hover {
    color: #00c471;
  }
</style>
