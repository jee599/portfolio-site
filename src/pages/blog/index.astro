---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const tagSet = new Set<string>();
posts.forEach(p => p.data.tags?.forEach((t: string) => tagSet.add(t)));
const allTags = [...tagSet].sort();
---

<Base title="Blog" description="Deep dives into AI engineering, model optimization, and modern development practices.">
  <div class="blog-listing">
    <!-- Hero -->
    <section class="blog-hero fade-in">
      <div class="hero-label">
        <span class="hero-dot"></span>
        Blog
      </div>
      <h1 class="hero-title">Deep Dives &<br/>Technical Insights</h1>
      <p class="hero-desc">AI engineering, model optimization, and modern dev practices.</p>
    </section>

    <!-- Tag Filter -->
    <div class="tag-bar fade-in stagger-1">
      <button class="tag-chip active" data-tag="all">All</button>
      {allTags.map(tag => (
        <button class="tag-chip" data-tag={tag}>{tag}</button>
      ))}
    </div>

    <!-- Post Grid -->
    <div class="post-grid fade-in stagger-2" id="post-grid">
      {posts.map((post, i) => {
        const dateStr = post.data.date.toISOString().split('T')[0];
        const tags = post.data.tags || [];
        return (
          <a href={`/blog/${post.slug}`} class="grid-card" data-tags={tags.join(',')}>
            <div class="card-number">{String(i + 1).padStart(2, '0')}</div>
            <div class="card-content">
              <div class="card-meta">
                <time>{dateStr}</time>
                {tags.slice(0, 3).map((tag: string) => (
                  <span class="card-tag">{tag}</span>
                ))}
              </div>
              <h2 class="card-title">{post.data.title}</h2>
              {post.data.description && (
                <p class="card-desc">{post.data.description}</p>
              )}
            </div>
            <div class="card-arrow">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
            </div>
          </a>
        );
      })}
    </div>

    {posts.length === 0 && (
      <div class="empty-state">
        <p>No posts yet. Stay tuned.</p>
      </div>
    )}
  </div>
</Base>

<script is:inline>
  document.querySelectorAll('.tag-chip').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.tag-chip').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      var tag = btn.dataset.tag;
      document.querySelectorAll('.grid-card').forEach(function(card) {
        if (tag === 'all') {
          card.style.display = '';
        } else {
          var tags = (card.dataset.tags || '').split(',');
          card.style.display = tags.includes(tag) ? '' : 'none';
        }
      });
    });
  });
</script>

<style>
  .blog-listing {
    max-width: 780px;
    margin: 0 auto;
    padding: 0 0 6rem;
  }

  /* ═══ Hero ═══ */
  .blog-hero {
    padding: 4rem 0 3rem;
  }

  .hero-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    font-family: 'JetBrains Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #00c471;
    margin-bottom: 1.25rem;
  }

  .hero-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #00c471;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .hero-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    color: #191f28;
    line-height: 1.15;
    letter-spacing: -0.04em;
    margin: 0 0 1rem;
  }

  .hero-desc {
    font-size: 1.05rem;
    color: #8b95a1;
    line-height: 1.6;
    max-width: 480px;
  }

  /* ═══ Tag Filter ═══ */
  .tag-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid #f2f4f6;
  }

  .tag-chip {
    padding: 0.35rem 0.85rem;
    border: 1px solid #e5e8eb;
    border-radius: 100px;
    background: #fff;
    color: #6b7684;
    font-size: 0.8rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s;
    font-family: 'JetBrains Mono', monospace;
  }

  .tag-chip:hover {
    border-color: #00c471;
    color: #00c471;
  }

  .tag-chip.active {
    background: #191f28;
    border-color: #191f28;
    color: #fff;
  }

  /* ═══ Post Grid ═══ */
  .post-grid {
    display: flex;
    flex-direction: column;
  }

  .grid-card {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    padding: 1.75rem 0;
    border-bottom: 1px solid #f2f4f6;
    text-decoration: none;
    transition: all 0.2s;
  }

  .grid-card:hover {
    padding-left: 0.75rem;
  }

  .grid-card:hover .card-title {
    color: #00c471;
  }

  .grid-card:hover .card-arrow {
    opacity: 1;
    transform: translate(2px, -2px);
  }

  .card-number {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    font-weight: 600;
    color: #d1d6db;
    min-width: 2rem;
    padding-top: 0.15rem;
  }

  .card-content {
    flex: 1;
    min-width: 0;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }

  .card-meta time {
    font-size: 0.75rem;
    font-family: 'JetBrains Mono', monospace;
    color: #8b95a1;
  }

  .card-tag {
    font-size: 0.65rem;
    font-family: 'JetBrains Mono', monospace;
    color: #00c471;
    background: #e6f9f0;
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    font-weight: 500;
  }

  .card-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: #191f28;
    line-height: 1.45;
    letter-spacing: -0.02em;
    transition: color 0.15s;
    word-break: keep-all;
  }

  .card-desc {
    font-size: 0.875rem;
    color: #8b95a1;
    line-height: 1.5;
    margin-top: 0.35rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-arrow {
    color: #d1d6db;
    opacity: 0;
    transition: all 0.2s;
    flex-shrink: 0;
    padding-top: 0.15rem;
  }

  /* ═══ Empty ═══ */
  .empty-state {
    text-align: center;
    padding: 4rem 0;
    color: #b0b8c1;
    font-size: 0.95rem;
  }

  /* ═══ Animations ═══ */
  .fade-in {
    animation: fadeUp 0.5s ease-out both;
  }
  .stagger-1 { animation-delay: 0.1s; }
  .stagger-2 { animation-delay: 0.2s; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 640px) {
    .blog-hero { padding: 2.5rem 0 2rem; }
    .card-number { display: none; }
    .grid-card { gap: 0; }
    .card-arrow { display: none; }
  }
</style>
