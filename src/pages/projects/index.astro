---
import Base from '../../layouts/Base.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getAllProjects } from '../../lib/projects';

const statusOrder: Record<string, number> = { '운영중': 0, '개발중': 1, '실험중': 2, '중단': 3 };
const projects = (await getAllProjects()).sort((a, b) =>
  (statusOrder[a.status] ?? 9) - (statusOrder[b.status] ?? 9) || a.order - b.order
);

const activeProjects = projects.filter(p => p.status === '운영중' || p.status === '개발중');
const otherProjects = projects.filter(p => p.status !== '운영중' && p.status !== '개발중');
---

<Base title="Projects" description="AI 프로젝트 포트폴리오">
  <div class="fade-in" style="max-width:880px;margin:0 auto;">
    <h1 style="font-size:1.8rem;font-weight:800;color:#191f28;letter-spacing:-0.03em;margin-bottom:0.15rem;">
      Projects
    </h1>
    <p style="font-size:0.9rem;color:#8b95a1;margin-bottom:2rem;"
      data-ko="만들고 있는 것들" data-en="What I'm building">만들고 있는 것들</p>

    {activeProjects.length > 0 && (
      <section style="margin-bottom:2rem;">
        <h2 style="font-size:0.68rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#00c471;margin-bottom:0.75rem;"
          data-ko="진행중" data-en="Active">진행중</h2>
        <div style="display:grid;gap:0.75rem;grid-template-columns:repeat(2,1fr);">
          {activeProjects.map((p) => (
            <ProjectCard
              slug={p.slug}
              title={p.title}
              one_liner={p.one_liner}
              status={p.status}
              stack={p.stack}
              url={p.url}
              github={p.github}
            />
          ))}
        </div>
      </section>
    )}

    {otherProjects.length > 0 && (
      <section>
        <h2 style="font-size:0.68rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:#8b95a1;margin-bottom:0.75rem;padding-top:1rem;border-top:1px solid #f2f4f6;"
          data-ko="실험 / 기타" data-en="Experiments">실험 / 기타</h2>
        <div style="display:grid;gap:0.75rem;grid-template-columns:repeat(3,1fr);">
          {otherProjects.map((p) => (
            <ProjectCard
              slug={p.slug}
              title={p.title}
              one_liner={p.one_liner}
              status={p.status}
              stack={p.stack}
              url={p.url}
              github={p.github}
            />
          ))}
        </div>
      </section>
    )}
  </div>
</Base>

<style>
  @media (max-width: 768px) {
    div[style*="grid-template-columns:repeat(2"] {
      grid-template-columns: 1fr !important;
    }
    div[style*="grid-template-columns:repeat(3"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>
