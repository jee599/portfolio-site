---
import Base from '../../layouts/Base.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
---

<Base title="Projects">
  <h1 class="text-3xl font-display font-bold text-heading mb-8 fade-in">Projects</h1>
  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 fade-in stagger-1">
    {projects
      .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
      .map((p) => (
        <ProjectCard
          slug={p.id.replace('.yaml', '')}
          title={p.data.title}
          one_liner={p.data.one_liner}
          status={p.data.status}
          stack={p.data.stack}
          url={p.data.url}
          github={p.data.github}
        />
      ))}
  </div>
</Base>
