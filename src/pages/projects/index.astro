---
import Base from '../../layouts/Base.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getAllProjects } from '../../lib/projects';

const statusOrder: Record<string, number> = { '운영중': 0, '개발중': 1, '실험중': 2, '중단': 3 };
const projects = (await getAllProjects()).sort((a, b) =>
  (statusOrder[a.status] ?? 9) - (statusOrder[b.status] ?? 9) || a.order - b.order
);
---

<Base title="Projects">
  <h1 class="text-3xl font-display font-bold mb-8 fade-in" style="color: #e8e8f0;">Projects</h1>
  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 fade-in stagger-1">
    {projects.map((p) => (
        <ProjectCard
          slug={p.slug}
          title={p.title}
          one_liner={p.one_liner}
          status={p.status}
          stack={p.stack}
          url={p.url}
          github={p.github}
        />
      ))}
  </div>
</Base>
