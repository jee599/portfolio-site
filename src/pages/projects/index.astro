---
import Base from '../../layouts/Base.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getAllProjects } from '../../lib/projects';

const projects = await getAllProjects();
---

<Base title="Projects">
  <h1 class="text-3xl font-display font-bold text-heading mb-8 fade-in">Projects</h1>
  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 fade-in stagger-1">
    {projects.map((p) => (
        <ProjectCard
          slug={p.slug}
          title={p.title}
          one_liner={p.one_liner}
          status={p.status}
          stack={p.stack}
          url={p.url}
          github={p.github}
        />
      ))}
  </div>
</Base>
