---
import Base from '../../layouts/Base.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getAllProjects } from '../../lib/projects';
import { getCollection } from 'astro:content';

const statusOrder: Record<string, number> = { '운영중': 0, '실험중': 1, '개발중': 2, '중단': 3 };
const projects = (await getAllProjects()).sort((a, b) =>
  (statusOrder[a.status] ?? 9) - (statusOrder[b.status] ?? 9) || a.order - b.order
);

const buildLogs = (await getCollection('build-logs'))
  .filter(l => l.data.lang === 'ko')
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const totalLogs = buildLogs.length;
const activeCount = projects.filter(p => p.status === '운영중' || p.status === '실험중').length;

// 프로젝트별 빌드 로그 메타 (한 번만 계산)
const logMeta: Record<string, { count: number; latestTitle?: string; latestSlug?: string }> = {};
for (const p of projects) {
  const logs = buildLogs.filter(l => l.data.project === p.slug);
  logMeta[p.slug] = {
    count: logs.length,
    latestTitle: logs[0]?.data.title,
    latestSlug: logs[0]?.slug,
  };
}

const featured = projects.filter(p => p.status === '운영중');
const beta = projects.filter(p => p.status === '실험중');
const inDev = projects.filter(p => p.status === '개발중');
const archived = projects.filter(p => p.status === '중단');
---

<Base title="Projects" description="AI 프로젝트 포트폴리오">
  <div class="fade-in" style="max-width:920px;margin:0 auto;">

    <h1 style="font-size:2.1rem;font-weight:900;color:#191f28;letter-spacing:-0.04em;margin-bottom:0.25rem;">
      Projects
    </h1>
    <p style="font-size:0.95rem;color:#6b7684;margin-bottom:1.25rem;"
      data-ko="AI로 만들고, 자동화하고, 실험한다." data-en="Build with AI. Automate everything. Ship fast.">
      AI로 만들고, 자동화하고, 실험한다.
    </p>
    <div style="display:flex;align-items:center;gap:1.25rem;padding:0.8rem 1.2rem;background:#f9fafb;border-radius:12px;border:1px solid #f2f4f6;width:fit-content;margin-bottom:2.5rem;">
      <div style="display:flex;align-items:baseline;gap:0.35rem;">
        <span style="font-size:1.3rem;font-weight:800;color:#191f28;font-family:'JetBrains Mono',monospace;">{projects.length}</span>
        <span style="font-size:0.7rem;color:#8b95a1;" data-ko="프로젝트" data-en="projects">프로젝트</span>
      </div>
      <div style="width:1px;height:18px;background:#e5e8eb;"></div>
      <div style="display:flex;align-items:baseline;gap:0.35rem;">
        <span style="font-size:1.3rem;font-weight:800;color:#191f28;font-family:'JetBrains Mono',monospace;">{activeCount}</span>
        <span style="font-size:0.7rem;color:#8b95a1;" data-ko="진행중" data-en="active">진행중</span>
      </div>
      <div style="width:1px;height:18px;background:#e5e8eb;"></div>
      <div style="display:flex;align-items:baseline;gap:0.35rem;">
        <span style="font-size:1.3rem;font-weight:800;color:#191f28;font-family:'JetBrains Mono',monospace;">{totalLogs}</span>
        <span style="font-size:0.7rem;color:#8b95a1;" data-ko="빌드 로그" data-en="build logs">빌드 로그</span>
      </div>
    </div>

    {featured.length > 0 && (
      <section style="margin-bottom:2.5rem;">
        <div style="display:flex;align-items:center;gap:0.45rem;margin-bottom:0.85rem;">
          <span style="width:8px;height:8px;border-radius:50%;background:#00c471;"></span>
          <h2 style="font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#333d4b;margin:0;"
            data-ko="운영중" data-en="Live">운영중</h2>
        </div>
        <div style="display:grid;gap:0.85rem;grid-template-columns:repeat(2,1fr);">
          {featured.map((p) => (
            <ProjectCard slug={p.slug} title={p.title} one_liner={p.one_liner} status={p.status} stack={p.stack} url={p.url} github={p.github} logCount={logMeta[p.slug]?.count || 0} latestLogTitle={logMeta[p.slug]?.latestTitle} latestLogSlug={logMeta[p.slug]?.latestSlug} />
          ))}
        </div>
      </section>
    )}

    {beta.length > 0 && (
      <section style="margin-bottom:2.5rem;">
        <div style="display:flex;align-items:center;gap:0.45rem;margin-bottom:0.85rem;">
          <span style="width:8px;height:8px;border-radius:50%;background:#f59e0b;"></span>
          <h2 style="font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#333d4b;margin:0;"
            data-ko="베타" data-en="Beta">베타</h2>
        </div>
        <div style="display:grid;gap:0.85rem;grid-template-columns:repeat(2,1fr);">
          {beta.map((p) => (
            <ProjectCard slug={p.slug} title={p.title} one_liner={p.one_liner} status={p.status} stack={p.stack} url={p.url} github={p.github} logCount={logMeta[p.slug]?.count || 0} latestLogTitle={logMeta[p.slug]?.latestTitle} latestLogSlug={logMeta[p.slug]?.latestSlug} />
          ))}
        </div>
      </section>
    )}

    {inDev.length > 0 && (
      <section style="margin-bottom:2.5rem;">
        <div style="display:flex;align-items:center;gap:0.45rem;margin-bottom:0.85rem;">
          <span style="width:8px;height:8px;border-radius:50%;background:#6c63ff;"></span>
          <h2 style="font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#333d4b;margin:0;"
            data-ko="개발중" data-en="In Development">개발중</h2>
        </div>
        <div style="display:grid;gap:0.75rem;grid-template-columns:repeat(2,1fr);">
          {inDev.map((p) => (
            <ProjectCard slug={p.slug} title={p.title} one_liner={p.one_liner} status={p.status} stack={p.stack} url={p.url} github={p.github} logCount={logMeta[p.slug]?.count || 0} />
          ))}
        </div>
      </section>
    )}

    {archived.length > 0 && (
      <section style="margin-bottom:2rem;">
        <div style="display:flex;align-items:center;gap:0.45rem;margin-bottom:0.85rem;">
          <span style="width:8px;height:8px;border-radius:50%;background:#d1d5db;"></span>
          <h2 style="font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#8b95a1;margin:0;"
            data-ko="아카이브" data-en="Archive">아카이브</h2>
        </div>
        <div style="display:grid;gap:0.75rem;grid-template-columns:repeat(3,1fr);">
          {archived.map((p) => (
            <ProjectCard slug={p.slug} title={p.title} one_liner={p.one_liner} status={p.status} stack={p.stack} url={p.url} github={p.github} logCount={logMeta[p.slug]?.count || 0} />
          ))}
        </div>
      </section>
    )}
  </div>
</Base>

<style>
  @media (max-width: 768px) {
    div[style*="grid-template-columns:repeat(2"] { grid-template-columns: 1fr !important; }
    div[style*="grid-template-columns:repeat(3"] { grid-template-columns: 1fr !important; }
  }
</style>
