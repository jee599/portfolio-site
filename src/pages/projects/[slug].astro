---
import Base from '../../layouts/Base.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { getAllProjects } from '../../lib/projects';

export async function getStaticPaths() {
  const projects = await getAllProjects();
  return projects.map((p) => ({
    params: { slug: p.slug },
    props: { project: p },
  }));
}

const { project } = Astro.props;
const slug = Astro.params.slug;
const d = project;

const buildLogs = (await getCollection('build-logs'))
  .filter((p) => p.data.project === slug && p.data.lang === 'ko')
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const statusColor: Record<string, string> = {
  '운영중': 'text-accent',
  '개발중': 'text-blue-500',
  '실험중': 'text-warning',
  '중단': 'text-danger',
};

const statusEn: Record<string, string> = {
  '운영중': 'Live',
  '개발중': 'In Dev',
  '실험중': 'Beta',
  '중단': 'Stopped',
};

// GitHub API로 최근 커밋 fetch (빌드타임)
interface Commit {
  sha: string;
  message: string;
  date: string;
}

let recentCommits: Commit[] = [];
try {
  const repoPath = d.github.replace('https://github.com/', '').replace(/\/$/, '');
  const token = import.meta.env.GITHUB_TOKEN || '';
  const headers: Record<string, string> = {
    Accept: 'application/vnd.github.v3+json',
    ...(token ? { Authorization: `Bearer ${token}` } : {}),
  };
  const res = await fetch(`https://api.github.com/repos/${repoPath}/commits?per_page=10`, { headers });
  if (res.ok) {
    const data = await res.json();
    recentCommits = data.map((c: any) => ({
      sha: c.sha?.slice(0, 7),
      message: c.commit?.message?.split('\n')[0] || '',
      date: c.commit?.author?.date?.split('T')[0] || '',
    }));
  }
} catch {}

// 커밋 + 빌드 로그를 날짜순 타임라인으로 통합
type TimelineItem = { type: 'commit'; date: string; sha: string; message: string }
  | { type: 'build-log'; date: string; title: string; slug: string };

const timeline: TimelineItem[] = [
  ...recentCommits.map((c) => ({
    type: 'commit' as const,
    date: c.date,
    sha: c.sha,
    message: c.message,
  })),
  ...buildLogs.map((log) => ({
    type: 'build-log' as const,
    date: log.data.date.toISOString().split('T')[0],
    title: log.data.title,
    slug: log.slug,
  })),
].sort((a, b) => b.date.localeCompare(a.date));
---

<Base title={d.title} description={d.one_liner}>
  <article class="fade-in">
    <header class="mb-10">
      <div class="flex items-center gap-3 mb-3">
        <span class={`text-xs font-mono ${statusColor[d.status] || 'text-muted'}`} data-ko={d.status} data-en={statusEn[d.status] || d.status}>
          {d.status}
        </span>
      </div>
      <h1 class="text-3xl font-display font-bold text-heading mb-3">{d.title}</h1>
      <p class="text-lg text-muted mb-4">{d.one_liner}</p>

      <div class="flex gap-3 text-sm">
        {d.url && (
          <a href={d.url} target="_blank" rel="noopener" class="font-mono text-accent">
            <span data-ko="사이트" data-en="Site">사이트</span> &rarr;
          </a>
        )}
        <a href={d.github} target="_blank" rel="noopener" class="font-mono text-accent">
          GitHub &rarr;
        </a>
      </div>

      <div class="flex flex-wrap gap-2 mt-4">
        {d.stack.map((tech: string) => (
          <span class="text-xs font-mono px-2 py-0.5 rounded bg-accent-light text-accent-dark">
            {tech}
          </span>
        ))}
      </div>
    </header>

    {timeline.length > 0 ? (
      <section>
        <h2 class="text-sm font-mono text-muted uppercase tracking-widest mb-6">
          <span data-ko="타임라인" data-en="Timeline">타임라인</span>
        </h2>
        <div class="relative pl-6 border-l-2 border-gray-200">
          {timeline.map((item) => (
            <div class="mb-4 relative">
              <div class={`absolute -left-[25px] w-3 h-3 rounded-full ${item.type === 'build-log' ? 'bg-accent' : 'bg-gray-300'}`} />
              <div class="flex items-baseline gap-2">
                <span class="text-xs font-mono text-muted">{item.date}</span>
                {item.type === 'build-log' ? (
                  <a href={`/posts/${item.slug}`} class="text-sm font-medium text-accent hover:underline">
                    {item.title}
                  </a>
                ) : (
                  <span class="text-sm text-body">
                    <span class="font-mono text-xs text-accent">{item.sha}</span>
                    {' '}{item.message}
                  </span>
                )}
              </div>
            </div>
          ))}
        </div>
      </section>
    ) : (
      <p class="text-muted text-sm" data-ko="아직 빌드 로그가 없다. 작업하고 push하면 자동으로 생긴다." data-en="No build logs yet. They are generated automatically when you push.">아직 빌드 로그가 없다. 작업하고 push하면 자동으로 생긴다.</p>
    )}
  </article>
</Base>
