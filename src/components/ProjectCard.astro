---
interface Props {
  slug: string;
  title: string;
  one_liner: string;
  status: string;
  stack: string[];
  url?: string;
  github: string;
  featured?: boolean;
  logCount?: number;
  latestLogTitle?: string;
  latestLogSlug?: string;
}

const { slug, title, one_liner, status, stack, url, github, featured = false, logCount = 0, latestLogTitle, latestLogSlug } = Astro.props;

const statusConfig: Record<string, { bg: string; color: string; border: string; en: string }> = {
  '운영중': { bg: '#e6f9f0', color: '#00a85e', border: '#00c471', en: 'Live' },
  '개발중': { bg: '#eff0ff', color: '#6c63ff', border: '#6c63ff', en: 'In Dev' },
  '실험중': { bg: '#fef8e8', color: '#d97706', border: '#f59e0b', en: 'Beta' },
  '중단': { bg: '#fef2f2', color: '#dc2626', border: '#e5e8eb', en: 'Stopped' },
};

const sc = statusConfig[status] || statusConfig['중단'];

const cardPadding = featured ? '1.5rem' : '1.25rem 1.35rem';
const titleSize = featured ? '1.2rem' : '1rem';
---

<div style={`display:block;background:#fff;border:1px solid #e5e8eb;border-left:4px solid ${sc.border};border-radius:14px;padding:${cardPadding};transition:all 0.2s;position:relative;`}
  onmouseover="this.style.boxShadow='0 8px 30px rgba(0,0,0,0.06)';this.style.transform='translateY(-2px)'"
  onmouseout="this.style.boxShadow='none';this.style.transform='none'">

  {/* Row 1: Status + External Links */}
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.6rem;">
    <span style={`display:inline-flex;align-items:center;gap:0.25rem;padding:0.15rem 0.55rem;border-radius:100px;font-size:0.6rem;font-weight:700;font-family:'JetBrains Mono',monospace;background:${sc.bg};color:${sc.color};`}
      data-ko={status} data-en={sc.en}>
      <span style={`display:inline-block;width:6px;height:6px;border-radius:50%;background:${sc.color};`}></span>
      {status}
    </span>
    <div style="display:flex;gap:0.25rem;">
      {url && (
        <a href={url} target="_blank" rel="noopener" title="사이트"
          style="display:flex;align-items:center;justify-content:center;width:26px;height:26px;border-radius:6px;color:#8b95a1;">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        </a>
      )}
      <a href={github} target="_blank" rel="noopener" title="GitHub"
        style="display:flex;align-items:center;justify-content:center;width:26px;height:26px;border-radius:6px;color:#b0b8c1;">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
      </a>
    </div>
  </div>

  {/* Row 2: Title (link to detail) */}
  <a href={`/projects/${slug}`}
    style={`display:block;font-size:${titleSize};font-weight:800;color:#191f28;text-decoration:none;letter-spacing:-0.02em;line-height:1.3;margin-bottom:0.3rem;`}>
    {title}
  </a>

  {/* Row 3: Description */}
  <p style="font-size:0.83rem;color:#6b7684;line-height:1.55;margin:0 0 0.75rem 0;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
    {one_liner}
  </p>

  {/* Row 4: Stack + Log Count */}
  <div style="display:flex;align-items:center;justify-content:space-between;gap:0.5rem;">
    <div style="display:flex;flex-wrap:wrap;gap:0.25rem;">
      {stack.slice(0, featured ? 6 : 4).map((tech) => (
        <span style="font-size:0.6rem;font-family:'JetBrains Mono',monospace;padding:0.12rem 0.45rem;border-radius:5px;background:#f2f4f6;color:#6b7684;font-weight:500;">
          {tech}
        </span>
      ))}
    </div>
    {logCount > 0 && (
      <span style="font-size:0.62rem;font-family:'JetBrains Mono',monospace;color:#00c471;font-weight:700;white-space:nowrap;">
        {logCount} <span data-ko="빌드 로그" data-en="logs">빌드 로그</span>
      </span>
    )}
  </div>

  {/* Row 5: Latest build log (featured only) */}
  {featured && latestLogTitle && latestLogSlug && (
    <div style="margin-top:0.75rem;padding-top:0.65rem;border-top:1px solid #f2f4f6;display:flex;align-items:center;gap:0.4rem;">
      <span style="font-size:0.52rem;font-family:'JetBrains Mono',monospace;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:#00c471;background:#e6f9f0;padding:0.1rem 0.35rem;border-radius:3px;">Latest</span>
      <a href={`/posts/${latestLogSlug}`}
        style="font-size:0.72rem;color:#333d4b;font-weight:500;text-decoration:none;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
        {latestLogTitle}
      </a>
    </div>
  )}
</div>
