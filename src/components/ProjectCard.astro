---
interface Props {
  slug: string;
  title: string;
  one_liner: string;
  status: string;
  stack: string[];
  url?: string;
  github: string;
}

const { slug, title, one_liner, status, stack, url, github } = Astro.props;

const statusConfig: Record<string, { bg: string; color: string; border: string; dot: string; en: string }> = {
  '운영중': { bg: '#e6f9f0', color: '#00a85e', border: '#00c471', dot: '#00c471', en: 'Live' },
  '개발중': { bg: '#eff0ff', color: '#6c63ff', border: '#6c63ff', dot: '#6c63ff', en: 'In Dev' },
  '실험중': { bg: '#fef8e8', color: '#d97706', border: '#f59e0b', dot: '#f59e0b', en: 'Beta' },
  '중단': { bg: '#fef2f2', color: '#dc2626', border: '#e5e8eb', dot: '#ef4444', en: 'Stopped' },
};

const sc = statusConfig[status] || statusConfig['중단'];
---

<div
  class="pcard"
  style={`border-left: 3px solid ${sc.border};`}
>
  <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:0.5rem;margin-bottom:0.5rem;">
    <div style="display:flex;align-items:center;gap:0.4rem;min-width:0;">
      <a href={`/projects/${slug}`}
        style="font-size:1rem;font-weight:700;color:#191f28;text-decoration:none;letter-spacing:-0.02em;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
        {title}
      </a>
      {url && (
        <a href={url} target="_blank" rel="noopener"
          style="display:inline-flex;align-items:center;color:#8b95a1;flex-shrink:0;" title={url}>
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
            <polyline points="15 3 21 3 21 9"/>
            <line x1="10" y1="14" x2="21" y2="3"/>
          </svg>
        </a>
      )}
      <a href={github} target="_blank" rel="noopener"
        style="display:inline-flex;align-items:center;color:#b0b8c1;flex-shrink:0;" title="GitHub">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
      </a>
    </div>
    <span style={`display:inline-flex;align-items:center;gap:0.3rem;padding:0.15rem 0.5rem;border-radius:100px;font-size:0.62rem;font-weight:600;font-family:'JetBrains Mono',monospace;white-space:nowrap;flex-shrink:0;background:${sc.bg};color:${sc.color};`}
      data-ko={status} data-en={sc.en}>
      <span style={`display:inline-block;width:6px;height:6px;border-radius:50%;background:${sc.dot};${status === '운영중' ? 'animation:pulsedot 2s ease-in-out infinite;' : ''}`}></span>
      {status}
    </span>
  </div>

  <p style="font-size:0.83rem;color:#6b7684;line-height:1.5;margin:0 0 0.75rem 0;">{one_liner}</p>

  <div style="display:flex;flex-wrap:wrap;gap:0.25rem;">
    {stack.map((tech) => (
      <span style="font-size:0.65rem;font-family:'JetBrains Mono',monospace;padding:0.12rem 0.45rem;border-radius:4px;background:#f2f4f6;color:#6b7684;">
        {tech}
      </span>
    ))}
  </div>
</div>

<style is:global>
  .pcard {
    display: block;
    background: #fff;
    border: 1px solid #f2f4f6;
    border-radius: 12px;
    padding: 1.1rem 1.25rem;
    transition: all 0.2s ease;
  }
  .pcard:hover {
    border-color: #e5e8eb;
    box-shadow: 0 4px 16px rgba(0,0,0,0.04);
    transform: translateY(-1px);
  }
  .pcard a:hover svg { color: #00c471; }
  @keyframes pulsedot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }
</style>
