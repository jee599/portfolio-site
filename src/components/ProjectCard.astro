---
interface Props {
  slug: string;
  title: string;
  one_liner: string;
  status: string;
  stack: string[];
  url?: string;
  github: string;
  featured?: boolean;
  logCount?: number;
  latestLogTitle?: string;
  latestLogSlug?: string;
}

const { slug, title, one_liner, status, stack, url, github, featured = false, logCount = 0, latestLogTitle, latestLogSlug } = Astro.props;

const statusConfig: Record<string, { bg: string; color: string; border: string; en: string }> = {
  '운영중': { bg: '#eff6ff', color: '#2563eb', border: '#2563eb', en: 'Live' },
  '개발중': { bg: '#f5f3ff', color: '#7c3aed', border: '#7c3aed', en: 'In Dev' },
  '실험중': { bg: '#fffbeb', color: '#d97706', border: '#d97706', en: 'Beta' },
  '중단': { bg: '#f9fafb', color: '#6b7280', border: '#6b7280', en: 'Stopped' },
};

const sc = statusConfig[status] || statusConfig['중단'];
---

<div class="pcard-wrap">
  {/* Default view */}
  <div class="pcard-default" style={`border-left:4px solid ${sc.border};`}>
    {/* Header */}
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.5rem;">
      <span style={`display:inline-flex;align-items:center;gap:0.25rem;padding:0.15rem 0.5rem;border-radius:100px;font-size:0.6rem;font-weight:700;font-family:'JetBrains Mono',monospace;background:${sc.bg};color:${sc.color};`}
        data-ko={status} data-en={sc.en}>
        <span style={`display:inline-block;width:6px;height:6px;border-radius:50%;background:${sc.color};`}></span>
        {sc.en}
      </span>
      <div style="display:flex;gap:0.2rem;">
        {url && (
          <a href={url} target="_blank" rel="noopener" style="display:flex;align-items:center;color:#94a3b8;" onclick="event.stopPropagation()">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </a>
        )}
        <a href={github} target="_blank" rel="noopener" style="display:flex;align-items:center;color:#94a3b8;" onclick="event.stopPropagation()">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        </a>
      </div>
    </div>

    {/* Title */}
    <a href={`/projects/${slug}`} style="display:block;font-size:1rem;font-weight:800;color:#0f172a;text-decoration:none;letter-spacing:-0.02em;line-height:1.3;margin-bottom:0.25rem;">
      {title}
    </a>

    {/* Stack tags */}
    <div style="display:flex;flex-wrap:wrap;gap:0.2rem;margin-top:0.4rem;">
      {stack.slice(0, 4).map((tech) => (
        <span style="font-size:0.58rem;font-family:'JetBrains Mono',monospace;padding:0.1rem 0.4rem;border-radius:4px;background:#f1f5f9;color:#475569;font-weight:500;">
          {tech}
        </span>
      ))}
      {logCount > 0 && (
        <span style="font-size:0.58rem;font-family:'JetBrains Mono',monospace;padding:0.1rem 0.4rem;border-radius:4px;background:#eff6ff;color:#2563eb;font-weight:700;">
          {logCount} logs
        </span>
      )}
    </div>
  </div>

  {/* Hover overlay */}
  <div class="pcard-overlay" style={`border-left:4px solid ${sc.border};`}>
    <div style="flex:1;">
      <a href={`/projects/${slug}`} style="display:block;font-size:1rem;font-weight:800;color:#0f172a;text-decoration:none;letter-spacing:-0.02em;margin-bottom:0.5rem;">
        {title}
      </a>
      <p style="font-size:0.8rem;color:#475569;line-height:1.6;margin:0 0 0.75rem;">
        {one_liner}
      </p>
      <div style="display:flex;flex-wrap:wrap;gap:0.25rem;">
        {stack.map((tech) => (
          <span style="font-size:0.58rem;font-family:'JetBrains Mono',monospace;padding:0.1rem 0.4rem;border-radius:4px;background:#f1f5f9;color:#475569;">
            {tech}
          </span>
        ))}
      </div>
    </div>
    {/* Bottom: latest log or links */}
    <div style="border-top:1px solid #e2e8f0;padding-top:0.6rem;display:flex;align-items:center;justify-content:space-between;">
      {latestLogTitle && latestLogSlug ? (
        <a href={`/posts/${latestLogSlug}`} style="font-size:0.7rem;color:#2563eb;text-decoration:none;font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1;" onclick="event.stopPropagation()">
          <span style="font-size:0.55rem;font-family:'JetBrains Mono',monospace;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;color:#2563eb;background:#eff6ff;padding:0.08rem 0.3rem;border-radius:3px;margin-right:0.3rem;">Latest</span>
          {latestLogTitle}
        </a>
      ) : (
        <span style="font-size:0.7rem;color:#94a3b8;">
          <span data-ko="상세 보기" data-en="View details">View details</span> →
        </span>
      )}
      <div style="display:flex;gap:0.4rem;flex-shrink:0;margin-left:0.5rem;">
        {url && (
          <a href={url} target="_blank" rel="noopener" style="font-size:0.65rem;font-weight:600;color:#2563eb;text-decoration:none;" onclick="event.stopPropagation()"
            data-ko="사이트" data-en="Site">Site ↗</a>
        )}
        <a href={github} target="_blank" rel="noopener" style="font-size:0.65rem;font-weight:600;color:#64748b;text-decoration:none;" onclick="event.stopPropagation()">GitHub ↗</a>
      </div>
    </div>
  </div>
</div>

<style is:inline>
  .pcard-wrap {
    position: relative;
    border-radius: 14px;
    overflow: hidden;
    background: #ffffff;
    border: 1px solid #e2e8f0;
    transition: all 0.25s ease;
    cursor: pointer;
  }
  .pcard-wrap:hover {
    border-color: #93c5fd;
    box-shadow: 0 8px 24px rgba(37,99,235,0.08);
    transform: translateY(-2px);
  }
  .pcard-default {
    padding: 1.1rem 1.2rem;
    transition: opacity 0.25s ease;
  }
  .pcard-overlay {
    position: absolute;
    inset: 0;
    padding: 1.1rem 1.2rem;
    background: #ffffff;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .pcard-wrap:hover .pcard-default {
    opacity: 0;
  }
  .pcard-wrap:hover .pcard-overlay {
    opacity: 1;
  }
</style>
