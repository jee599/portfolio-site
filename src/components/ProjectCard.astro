---
import { getCollection } from 'astro:content';

interface Props {
  slug: string;
  title: string;
  one_liner: string;
  status: string;
  stack: string[];
  url?: string;
  github: string;
  featured?: boolean;
}

const { slug, title, one_liner, status, stack, url, github, featured = false } = Astro.props;

const statusConfig: Record<string, { bg: string; color: string; border: string; dot: string; en: string }> = {
  '운영중': { bg: '#e6f9f0', color: '#00a85e', border: '#00c471', dot: '#00c471', en: 'Live' },
  '개발중': { bg: '#eff0ff', color: '#6c63ff', border: '#6c63ff', dot: '#6c63ff', en: 'In Dev' },
  '실험중': { bg: '#fef8e8', color: '#d97706', border: '#f59e0b', dot: '#f59e0b', en: 'Beta' },
  '중단': { bg: '#fef2f2', color: '#dc2626', border: '#e5e8eb', dot: '#ef4444', en: 'Stopped' },
};

const sc = statusConfig[status] || statusConfig['중단'];

const buildLogs = (await getCollection('build-logs'))
  .filter((l) => l.data.project === slug && l.data.lang === 'ko');
const logCount = buildLogs.length;
const latestLog = buildLogs.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())[0];
---

<a href={`/projects/${slug}`} class:list={["pcard", { "pcard-featured": featured }]}
  style={`border-left: 4px solid ${sc.border};`}>

  {/* Header: status + links */}
  <div class="pcard-top">
    <span class="pcard-status" style={`background:${sc.bg};color:${sc.color};`}
      data-ko={status} data-en={sc.en}>
      <span class="pcard-dot" style={`background:${sc.dot};${status === '운영중' ? 'animation:pulsedot 2s ease-in-out infinite;' : ''}`}></span>
      {status}
    </span>
    <div class="pcard-links" onclick="event.preventDefault(); event.stopPropagation();">
      {url && (
        <a href={url} target="_blank" rel="noopener" class="pcard-link" title="사이트">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
            <polyline points="15 3 21 3 21 9"/>
            <line x1="10" y1="14" x2="21" y2="3"/>
          </svg>
        </a>
      )}
      <a href={github} target="_blank" rel="noopener" class="pcard-link" title="GitHub">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
      </a>
    </div>
  </div>

  {/* Title */}
  <h3 class="pcard-title">{title}</h3>

  {/* Description */}
  <p class="pcard-desc">{one_liner}</p>

  {/* Stack + Meta */}
  <div class="pcard-footer">
    <div class="pcard-stack">
      {stack.slice(0, featured ? 6 : 4).map((tech) => (
        <span class="pcard-tag">{tech}</span>
      ))}
    </div>
    {logCount > 0 && (
      <span class="pcard-meta">
        {logCount} <span data-ko="빌드 로그" data-en="build logs">빌드 로그</span>
      </span>
    )}
  </div>

  {/* Featured: show latest build log */}
  {featured && latestLog && (
    <div class="pcard-latest">
      <span class="pcard-latest-label">Latest</span>
      <span class="pcard-latest-title">{latestLog.data.title}</span>
    </div>
  )}
</a>

<style is:global>
  .pcard {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid #e5e8eb;
    border-radius: 14px;
    padding: 1.25rem 1.5rem;
    text-decoration: none;
    color: inherit;
    transition: all 0.25s ease;
    position: relative;
  }
  .pcard:hover {
    border-color: #d1d5db;
    box-shadow: 0 8px 30px rgba(0,0,0,0.06);
    transform: translateY(-3px);
  }
  .pcard-featured {
    padding: 1.5rem 1.75rem;
  }
  .pcard-featured .pcard-title {
    font-size: 1.25rem;
  }
  .pcard-featured .pcard-desc {
    font-size: 0.9rem;
    -webkit-line-clamp: 3;
  }

  .pcard-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }
  .pcard-status {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
    font-size: 0.62rem;
    font-weight: 700;
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.02em;
  }
  .pcard-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }
  .pcard-links {
    display: flex;
    gap: 0.35rem;
  }
  .pcard-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 8px;
    color: #b0b8c1;
    transition: all 0.15s;
  }
  .pcard-link:hover {
    color: #00c471;
    background: #f2f4f6;
  }

  .pcard-title {
    font-size: 1.05rem;
    font-weight: 800;
    color: #191f28;
    letter-spacing: -0.025em;
    margin-bottom: 0.35rem;
    line-height: 1.3;
  }
  .pcard-desc {
    font-size: 0.83rem;
    color: #6b7684;
    line-height: 1.55;
    margin-bottom: 0.85rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .pcard-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }
  .pcard-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }
  .pcard-tag {
    font-size: 0.62rem;
    font-family: 'JetBrains Mono', monospace;
    padding: 0.15rem 0.5rem;
    border-radius: 5px;
    background: #f2f4f6;
    color: #6b7684;
    font-weight: 500;
  }
  .pcard-meta {
    font-size: 0.65rem;
    font-family: 'JetBrains Mono', monospace;
    color: #00c471;
    font-weight: 600;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .pcard-latest {
    margin-top: 0.85rem;
    padding-top: 0.75rem;
    border-top: 1px solid #f2f4f6;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .pcard-latest-label {
    font-size: 0.55rem;
    font-family: 'JetBrains Mono', monospace;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #00c471;
    background: #e6f9f0;
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    flex-shrink: 0;
  }
  .pcard-latest-title {
    font-size: 0.75rem;
    color: #333d4b;
    font-weight: 500;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  @keyframes pulsedot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }
</style>
