---
interface Props {
  slug: string;
  title: string;
  one_liner: string;
  status: string;
  stack: string[];
  url?: string;
  github: string;
}

const { slug, title, one_liner, status, stack, url, github } = Astro.props;

const statusColor: Record<string, string> = {
  '운영중': 'color: #10b981',
  '개발중': 'color: #6c63ff',
  '실험중': 'color: #f59e0b',
  '중단': 'color: #ef4444',
};
---

<a
  href={`/projects/${slug}`}
  class="block group p-5 rounded-lg no-underline transition-all duration-300"
  style="background: #1a1a2e; border: 1px solid #2a2a3e;"
>
  <div class="flex items-start justify-between mb-3">
    <h3 class="font-display font-bold transition-colors" style="color: #e8e8f0;">
      {title}
    </h3>
    <span class="text-xs font-mono" style={statusColor[status] || 'color: #7a7a9a'}>
      {status}
    </span>
  </div>
  <p class="text-sm mb-4 leading-relaxed" style="color: #7a7a9a;">{one_liner}</p>
  <div class="flex flex-wrap gap-1.5">
    {stack.map((tech) => (
      <span class="text-xs font-mono px-1.5 py-0.5 rounded" style="background: rgba(108,99,255,0.1); color: #8b83ff;">
        {tech}
      </span>
    ))}
  </div>
</a>
