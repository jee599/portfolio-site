---
import { SHIP_ROWS } from '../../data/home';

const heatmap = Array.from({ length: 52 }, (_, i) =>
  Math.abs(Math.sin(i * 0.7) * Math.cos(i * 0.3)),
);
---
<section class="section" style="padding-top: 24px;">
  <div class="container">
    <div class="shiplog">
      <h3><span class="dot"></span>SHIP LOG · 최근 커밋</h3>
      <div class="sub">What's been pushed lately · 지난 7일간 34 commits across 6 repos</div>
      <div class="shiplog-table">
        <div class="th c-hash">commit</div>
        <div class="th">when</div>
        <div class="th">message</div>
        <div class="th" style="text-align: right;">status</div>
        <div class="th c-diff" style="text-align: right;">diff</div>
        {SHIP_ROWS.map((r) => (
          <>
            <div class="td hash c-hash">{r.h}</div>
            <div class="td date">{r.date}</div>
            <div class="td msg">{r.msg}<span class="ko">· {r.ko}</span></div>
            <div class="td status-pill">
              <span class={`pill ${r.status}`}>
                {r.status === 'ok' ? 'deployed' : r.status === 'build' ? 'building' : 'testing'}
              </span>
            </div>
            <div class="td diff c-diff">
              <span class="add">+{r.diff.a}</span>
              <span class="del">−{r.diff.d}</span>
            </div>
          </>
        ))}
      </div>
      <div class="shiplog-foot">
        <span>contributions · last 52 weeks</span>
        <div class="bar">
          {heatmap.map((v, i) => (
            <span style={`left: ${(i / 52) * 100}%; opacity: ${0.3 + v * 0.7}; height: ${40 + v * 60}%; top: ${50 - v * 30}%;`}></span>
          ))}
        </div>
        <span>34 commits this week</span>
      </div>
    </div>
  </div>
</section>
