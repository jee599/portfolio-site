<script is:inline>
  (function () {
    var nav = document.getElementById('home-topbar');
    if (!nav) return;
    function onScroll() {
      if (window.scrollY > 40) nav.classList.add('scrolled');
      else nav.classList.remove('scrolled');
    }
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  })();
</script>
