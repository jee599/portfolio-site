---
import { getCollection } from 'astro:content';

const buildLogs = (await getCollection('build-logs'))
  .filter((p) => p.data.lang === 'ko')
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 7);

const tips = (await getCollection('tips'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

type PostRow = {
  slug: string;
  date: string;
  title: string;
  titleKo: string;
  tag: string;
};

const fmtDate = (d: Date) => {
  const y = d.getFullYear();
  const m = String(d.getMonth() + 1).padStart(2, '0');
  const dd = String(d.getDate()).padStart(2, '0');
  return `${y}.${m}.${dd}`;
};

const posts: PostRow[] = [
  ...buildLogs.map((p) => ({
    slug: p.slug,
    date: fmtDate(p.data.date),
    title: p.data.title,
    titleKo: p.data.description ?? p.data.project,
    tag: p.data.tags?.[0] ?? 'builder-log',
  })),
  ...tips.map((p) => ({
    slug: p.slug,
    date: fmtDate(p.data.date),
    title: p.data.title,
    titleKo: p.data.tags?.[0] ?? 'tip',
    tag: 'tip',
  })),
]
  .sort((a, b) => (a.date < b.date ? 1 : -1))
  .slice(0, 8);
---
<section id="log" class="section" data-screen-label="03 Writing">
  <div class="container">
    <div class="section-head">
      <span class="section-kicker">기록</span>
      <h2 class="section-title">미래의 나에게 남기는 메모</h2>
      <p class="section-sub">만들다가 배운 것들을 잊기 전에 적어둬요. 주로 일요일 밤에 써요.</p>
    </div>
    <div class="writing-list">
      {posts.map((post) => (
        <a class="post-row" href={`/posts/${post.slug}`}>
          <span class="date">{post.date}</span>
          <span class="title">
            {post.title}
            <span class="ko">{post.titleKo}</span>
          </span>
          <span class="cat">#{post.tag}</span>
          <span class="arrow">→</span>
        </a>
      ))}
    </div>
  </div>
</section>
