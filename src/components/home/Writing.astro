---
const links = [
  {
    kind: 'dev.to',
    name: 'DEV.to',
    handle: '@jee599',
    desc: '영문 기술 포스트. 매주 일요일 발행.',
    href: 'https://dev.to/jee599',
    external: true,
  },
  {
    kind: 'spoonai',
    name: 'SpoonAI',
    handle: 'spoonai.me',
    desc: 'AI 뉴스 자동 큐레이션. 매일 아침 KST.',
    href: 'https://spoonai.me',
    external: true,
  },
  {
    kind: 'feed',
    name: 'RSS',
    handle: '/rss.xml',
    desc: '전체 빌드 로그·AI 뉴스 피드.',
    href: '/rss.xml',
    external: false,
  },
];
---
<section id="writing" class="sec">
  <div class="sec-head">
    <div class="sec-kicker">
      <span class="ln"></span>
      <span class="n">05</span>
      <span>Writing · 글</span>
    </div>
    <h2 class="sec-h" data-ko="다른 곳에도 쓴다." data-en="Also writes here.">
      다른 곳에도 쓴다.
    </h2>
    <p class="sec-desc" data-ko="플랫폼별로 톤이 다르다. 요점만 남긴 피드." data-en="Tone varies by platform. Pointers only.">
      플랫폼별로 톤이 다르다. 요점만 남긴 피드.
    </p>
  </div>

  <div class="writing">
    {links.map((l) => (
      <a
        class="writing-link"
        href={l.href}
        target={l.external ? '_blank' : undefined}
        rel={l.external ? 'noreferrer' : undefined}
      >
        <span class="wl-kind">{l.kind}</span>
        <span class="wl-name">
          {l.name}
          <span class="arr">→</span>
        </span>
        <span class="wl-desc">
          {l.handle} · {l.desc}
        </span>
      </a>
    ))}
  </div>
</section>
