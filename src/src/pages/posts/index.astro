---
import Base from '../../layouts/Base.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { fetchArticles } from '../../lib/devto';

const buildLogs = (await getCollection('build-logs'))
  .filter((p) => p.data.lang === 'ko')
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const tips = (await getCollection('tips'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const devtoArticles = await fetchArticles();

type PostItem = {
  title: string;
  href: string;
  date: string;
  type: 'build-log' | 'tip' | 'blog';
  project?: string;
  description?: string;
};

const allPosts: PostItem[] = [
  ...buildLogs.map((p) => ({
    title: p.data.title,
    href: `/posts/${p.slug}`,
    date: p.data.date.toISOString().split('T')[0],
    type: 'build-log' as const,
    project: p.data.project,
  })),
  ...tips.map((p) => ({
    title: p.data.title,
    href: `/posts/${p.slug}`,
    date: p.data.date.toISOString().split('T')[0],
    type: 'tip' as const,
  })),
  ...devtoArticles.map((a) => ({
    title: a.title,
    href: `/blog/${a.slug}`,
    date: a.published_at.split('T')[0],
    type: 'blog' as const,
    description: a.description,
  })),
].sort((a, b) => b.date.localeCompare(a.date));
---

<Base title="Posts">
  <h1 class="text-3xl font-display font-bold text-heading mb-8 fade-in">Posts</h1>
  <div class="fade-in stagger-1">
    {allPosts.map((post) => (
      <PostCard
        title={post.title}
        href={post.href}
        date={post.date}
        type={post.type}
        project={post.project}
        description={post.description}
      />
    ))}
  </div>
  {allPosts.length === 0 && (
    <p class="text-muted">아직 글이 없다. 작업하고 push하면 빌드 로그가 자동으로 생긴다.</p>
  )}
</Base>
