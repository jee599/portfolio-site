---
import Base from '../../layouts/Base.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((p) => ({
    params: { slug: p.id.replace('.yaml', '') },
    props: { project: p },
  }));
}

const { project } = Astro.props;
const slug = Astro.params.slug;
const d = project.data;

const buildLogs = (await getCollection('build-logs'))
  .filter((p) => p.data.project === slug && p.data.lang === 'ko')
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const statusStyle: Record<string, string> = {
  '운영중': 'color:#10b981',
  '개발중': 'color:#3b82f6',
  '실험중': 'color:#f59e0b',
  '중단': 'color:#ef4444',
};
---

<Base title={d.title} description={d.one_liner}>
  <article class="fade-in">
    <header class="mb-10">
      <span class="text-xs font-mono" style={statusStyle[d.status] || 'color:#9ca3af'}>{d.status}</span>
      <h1 class="text-2xl font-display font-bold mt-1 mb-2" style="color:#111827">{d.title}</h1>
      <p class="text-sm mb-4" style="color:#6b7280">{d.one_liner}</p>

      <div class="flex gap-3 text-xs">
        {d.url && (
          <a href={d.url} target="_blank" rel="noopener" class="font-mono">사이트 →</a>
        )}
        <a href={d.github} target="_blank" rel="noopener" class="font-mono">GitHub →</a>
      </div>

      <div class="flex flex-wrap gap-1 mt-3">
        {d.stack.map((tech: string) => (
          <span class="text-xs font-mono px-1.5 py-0.5 rounded" style="background:#f0fdf4;color:#059669;font-size:0.7rem">
            {tech}
          </span>
        ))}
      </div>
    </header>

    {buildLogs.length > 0 && (
      <section>
        <h2 class="text-xs font-mono uppercase tracking-widest mb-4" style="color:#d1d5db">Build Logs</h2>
        <div>
          {buildLogs.map((log) => (
            <PostCard
              title={log.data.title}
              href={`/posts/${log.slug}`}
              date={log.data.date.toISOString().split('T')[0]}
              type="build-log"
              project={log.data.project}
            />
          ))}
        </div>
      </section>
    )}

    {buildLogs.length === 0 && (
      <p class="text-sm" style="color:#9ca3af">아직 빌드 로그가 없다.</p>
    )}
  </article>
</Base>
