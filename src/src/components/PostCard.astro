---
interface Props {
  title: string;
  href: string;
  date: string;
  type: 'build-log' | 'tip' | 'blog';
  project?: string;
  tags?: string[];
  description?: string;
}

const { title, href, date, type, project, description } = Astro.props;

const typeStyle: Record<string, { text: string; color: string }> = {
  'build-log': { text: 'Build Log', color: '#059669' },
  tip: { text: 'Tip', color: '#d97706' },
  blog: { text: 'Blog', color: '#3b82f6' },
};

const { text: labelText, color } = typeStyle[type];
---

<a
  href={href}
  class="block group py-3 no-underline hover:no-underline"
  style="border-bottom:1px solid #f3f4f6"
>
  <div class="flex items-center gap-2 mb-1">
    <span class="text-xs font-mono" style={`color:${color}`}>{labelText}</span>
    {project && <span class="text-xs font-mono" style="color:#d1d5db">{project}</span>}
    <time class="text-xs ml-auto" style="color:#d1d5db">{date}</time>
  </div>
  <h3 class="text-sm font-display font-medium" style="color:#111827">{title}</h3>
  {description && <p class="text-xs mt-0.5" style="color:#9ca3af">{description}</p>}
</a>
