---
interface Props {
  slug: string;
  title: string;
  one_liner: string;
  status: string;
  stack: string[];
  url?: string;
  github: string;
}

const { slug, title, one_liner, status, stack } = Astro.props;

const statusStyle: Record<string, string> = {
  '운영중': 'color:#10b981',
  '개발중': 'color:#3b82f6',
  '실험중': 'color:#f59e0b',
  '중단': 'color:#ef4444',
};
---

<a
  href={`/projects/${slug}`}
  class="block group p-4 rounded-lg no-underline hover:no-underline transition-all duration-200"
  style="background:#f9fafb;border:1px solid #e5e7eb"
  onmouseover="this.style.borderColor='#a7f3d0'"
  onmouseout="this.style.borderColor='#e5e7eb'"
>
  <div class="flex items-start justify-between mb-2">
    <h3 class="font-display font-bold text-sm" style="color:#111827">{title}</h3>
    <span class="text-xs font-mono" style={statusStyle[status] || 'color:#9ca3af'}>{status}</span>
  </div>
  <p class="text-xs mb-3" style="color:#6b7280;line-height:1.6">{one_liner}</p>
  <div class="flex flex-wrap gap-1">
    {stack.map((tech) => (
      <span class="text-xs font-mono px-1.5 py-0.5 rounded" style="background:#f0fdf4;color:#059669;font-size:0.7rem">
        {tech}
      </span>
    ))}
  </div>
</a>
