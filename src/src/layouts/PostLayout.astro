---
import Base from './Base.astro';

interface Props {
  title: string;
  date: Date;
  project?: string;
  tags?: string[];
  pair?: string;
  lang?: string;
}

const { title, date, project, tags = [], pair, lang } = Astro.props;
const dateStr = date.toISOString().split('T')[0];
---

<Base title={title}>
  <article class="fade-in">
    <header class="mb-12">
      <div class="flex items-center gap-2 mb-4">
        {project && (
          <a
            href={`/projects/${project}`}
            class="text-xs font-mono px-2 py-0.5 rounded-full no-underline hover:no-underline"
            style="background:#f0fdf4;color:#059669"
          >
            {project}
          </a>
        )}
        <time class="text-xs" style="color:#9ca3af" datetime={dateStr}>{dateStr}</time>
        {lang && pair && (
          <a
            href={`/posts/${pair}`}
            class="text-xs font-mono px-2 py-0.5 rounded-full no-underline hover:no-underline"
            style="background:#f3f4f6;color:#6b7280"
          >
            {lang === 'ko' ? '🌐 EN' : '🌐 KO'}
          </a>
        )}
      </div>

      <h1 class="text-2xl font-display font-bold leading-snug mb-4" style="color:#111827;letter-spacing:-0.02em">
        {title}
      </h1>

      {tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5">
          {tags.map((tag) => (
            <span class="text-xs font-mono px-2 py-0.5 rounded-full" style="background:#f9fafb;color:#9ca3af;border:1px solid #f3f4f6">
              {tag}
            </span>
          ))}
        </div>
      )}

      <div style="margin-top:1.5rem;height:1px;background:linear-gradient(to right, #10b981, #d1fae5, transparent)"></div>
    </header>

    <div class="prose">
      <slot />
    </div>

    <footer style="margin-top:4rem;padding-top:1.5rem;border-top:1px solid #f3f4f6">
      <a href="/posts" class="text-sm font-mono no-underline" style="color:#9ca3af">
        ← 전체 글 목록
      </a>
    </footer>
  </article>
</Base>
