---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'AI로 프로덕트를 만들고 수익화하는 기록', ogImage } = Astro.props;
const siteUrl = 'https://jidonglab.com';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | jidonglab</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage || `${siteUrl}/og/default.png`} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="alternate" type="application/rss+xml" title="jidonglab" href="/rss.xml" />
  </head>
  <body class="min-h-screen bg-bg antialiased">
    <header class="border-b border-gray-100">
      <nav class="max-w-2xl mx-auto px-5 py-4 flex items-center justify-between">
        <a href="/" class="font-display font-bold text-lg text-heading no-underline hover:no-underline">
          jidong<span class="text-accent">lab</span>
        </a>
        <div class="flex items-center gap-5 text-sm" style="color:#9ca3af">
          <a href="/projects" class="no-underline hover:no-underline" style="color:inherit">Projects</a>
          <a href="/posts" class="no-underline hover:no-underline" style="color:inherit">Posts</a>
          <a href="/about" class="no-underline hover:no-underline" style="color:inherit">About</a>
          <a href="https://github.com/jee599" target="_blank" rel="noopener" class="no-underline hover:no-underline" style="color:inherit">GitHub</a>
        </div>
      </nav>
    </header>

    <main class="max-w-2xl mx-auto px-5 py-10">
      <slot />
    </main>

    <footer class="border-t border-gray-100 mt-16">
      <div class="max-w-2xl mx-auto px-5 py-6 text-center text-xs" style="color:#d1d5db">
        © {new Date().getFullYear()} jidonglab
      </div>
    </footer>
  </body>
</html>
